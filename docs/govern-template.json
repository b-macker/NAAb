        "eval_usage":            { "enabled": true, "level": "hard" },
        "for_in_array":          { "enabled": true, "level": "soft" },
        "prototype_pollution":   { "enabled": true, "level": "hard" },
        "document_write":        { "enabled": true, "level": "soft" },
