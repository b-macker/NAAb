        "using_namespace_std_header": { "enabled": true, "level": "soft" },
        "c_style_casts":         { "enabled": true, "level": "soft" },
        "goto_usage":            { "enabled": true, "level": "soft" },
        "manual_memory":         { "enabled": true, "level": "soft" },
        "macro_functions":       { "enabled": true, "level": "advisory" },
        "missing_virtual_dtor":  { "enabled": true, "level": "soft" },
        "exception_by_value":    { "enabled": true, "level": "soft" },
        "string_c_str_misuse":   { "enabled": true, "level": "soft" },
