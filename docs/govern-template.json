        "polyglot_no_binding":   { "enabled": true, "level": "advisory" },
        "throw_raw_string":      { "enabled": true, "level": "advisory" },
        "oversized_polyglot":    { "enabled": true, "level": "soft", "max_lines": 100 },
        "top_level_let":         { "enabled": true, "level": "hard" },
        "arrow_lambda":          { "enabled": true, "level": "soft" },
        "missing_export":        { "enabled": true, "level": "advisory" },
        "dict_bracket_access":   { "enabled": true, "level": "soft" },
        "python_return_in_block": { "enabled": true, "level": "hard" }
      },
      "cpp": {
