        "panic_in_library":      { "enabled": true, "level": "soft" },
        "empty_interface_abuse": { "enabled": true, "level": "advisory" },
        "error_string_format":   { "enabled": true, "level": "advisory" },
        "shadow_err":            { "enabled": true, "level": "soft" },
        "naked_return":          { "enabled": true, "level": "advisory" },
