        "import_inside_function": { "enabled": true, "level": "advisory" },
        "mutable_class_vars":    { "enabled": true, "level": "advisory" },
        "string_format_mix":     { "enabled": true, "level": "advisory" },
        "duplicate_dict_key":    { "enabled": true, "level": "hard" },
        "f_string_without_expression": { "enabled": true, "level": "advisory" }
      },
      "javascript": {
