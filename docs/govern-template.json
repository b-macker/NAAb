  "_comment_scanner": "Code Quality Scanner — auto-runs on every execution when this section exists",
  "scanner": {
    "version": "1.0",
    "mode": "enforce",

    "_comment_scan_settings": "Controls which files to scan and size limits",
    "scan": {
      "max_files": 200,
      "max_file_size_kb": 500,
      "include_tests": false,
      "follow_symlinks": false,
      "exclude_patterns": ["node_modules", ".git", "__pycache__", "build", "dist"]
    },

    "_comment_categories": "139 checks across 6 categories + 6 language modules. Each check: enabled (bool), level (hard/soft/advisory), options (thresholds)",

    "redundancy": {
      "obvious_comments":       { "enabled": true, "level": "advisory" },
      "over_abstraction":       { "enabled": true, "level": "advisory" },
      "redundant_try_catch":    { "enabled": true, "level": "soft" },
      "suspicious_try_catch":   { "enabled": true, "level": "soft" },
      "generic_variable_names": { "enabled": true, "level": "soft", "names": ["data", "temp", "tmp", "val", "x", "y", "foo", "bar", "baz", "stuff", "thing", "obj", "item", "result"] },
      "excessive_comments":     { "enabled": true, "level": "advisory", "threshold": 0.6 },
      "apologetic_comments":    { "enabled": true, "level": "soft" },
      "placeholder_code":       { "enabled": true, "level": "soft" },
      "gaming_comments":        { "enabled": true, "level": "soft" },
      "trivial_constant_alias": { "enabled": true, "level": "soft" },
      "restating_docstrings":   { "enabled": true, "level": "advisory" },
      "unnecessary_else_after_return": { "enabled": true, "level": "advisory" },
      "wrapper_classes":        { "enabled": true, "level": "advisory" },
      "unused_imports":         { "enabled": true, "level": "soft" },
      "single_use_variable":    { "enabled": false, "level": "advisory" },
      "copy_paste_signatures":  { "enabled": true, "level": "advisory" },
      "excessive_type_checks":  { "enabled": true, "level": "advisory" },
      "decorative_separators":  { "enabled": true, "level": "advisory" }
    },

    "code_quality": {
      "empty_catch":            { "enabled": true, "level": "hard" },
      "catch_and_ignore":       { "enabled": true, "level": "soft" },
      "magic_numbers":          { "enabled": true, "level": "soft", "allowed": [0, 1, -1, 2, 10, 100, 1000] },
      "magic_strings":          { "enabled": true, "level": "soft", "min_length": 5, "min_occurrences": 3 },
      "dead_code_after_return": { "enabled": true, "level": "hard" },
      "dead_conditional":       { "enabled": true, "level": "hard" },
      "god_functions":          { "enabled": true, "level": "soft", "max_lines": 80 },
      "god_classes":            { "enabled": true, "level": "soft", "max_lines": 300, "max_methods": 20 },
      "deep_nesting":           { "enabled": true, "level": "soft", "max_depth": 4 },
      "long_parameter_list":    { "enabled": true, "level": "soft", "max_params": 5 },
      "complex_boolean_expr":   { "enabled": true, "level": "soft", "max_conditions": 3 },
      "mutable_global_state":   { "enabled": true, "level": "soft" },
      "boolean_function_returns": { "enabled": true, "level": "advisory" },
      "string_concat_in_loop":  { "enabled": true, "level": "advisory" },
      "recursive_no_base_case": { "enabled": true, "level": "soft" }
    },

    "complexity": {
      "cyclomatic_complexity":  { "enabled": true, "level": "soft", "max": 15 },
      "cognitive_complexity":   { "enabled": true, "level": "soft", "max": 20 },
      "file_length":            { "enabled": true, "level": "soft", "max_lines": 500 },
      "function_count":         { "enabled": true, "level": "advisory", "max": 25 },
      "class_count":            { "enabled": true, "level": "advisory", "max": 5 },
      "import_count":           { "enabled": true, "level": "advisory", "max": 30 },
      "return_count":           { "enabled": true, "level": "advisory", "max": 5 },
      "nested_ternary":         { "enabled": true, "level": "soft" }
    },

    "style": {
      "inconsistent_naming":    { "enabled": true, "level": "advisory" },
      "debug_leftovers":        { "enabled": true, "level": "soft" },
      "commented_out_code":     { "enabled": true, "level": "soft", "min_lines": 3 },
      "inconsistent_spacing":   { "enabled": true, "level": "advisory" },
      "long_lines":             { "enabled": true, "level": "advisory", "max_length": 120 },
      "missing_final_newline":  { "enabled": true, "level": "advisory" },
      "multiple_blank_lines":   { "enabled": true, "level": "advisory", "max_consecutive": 2 },
      "inconsistent_quotes":    { "enabled": false, "level": "advisory" },
      "import_ordering":        { "enabled": true, "level": "advisory" }
    },

    "security": {
      "hardcoded_credentials":    { "enabled": true, "level": "hard" },
      "sql_string_concat":        { "enabled": true, "level": "hard" },
      "shell_injection":           { "enabled": true, "level": "hard" },
      "insecure_random":           { "enabled": true, "level": "soft" },
      "weak_crypto":               { "enabled": true, "level": "soft" },
      "hardcoded_ip":              { "enabled": false, "level": "advisory" },
      "hardcoded_url":             { "enabled": true, "level": "advisory" },
      "path_traversal":            { "enabled": true, "level": "hard" },
      "insecure_deserialization":  { "enabled": true, "level": "hard" },
      "exposed_stack_traces":      { "enabled": true, "level": "advisory" }
    },

    "_comment_lang_rules": "Language-specific checks (only run for matching file types)",
    "lang_rules": {
