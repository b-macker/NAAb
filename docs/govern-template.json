  "polyglot": {
    "variable_binding": {
      "require_explicit": false,
      "require_explicit_level": "advisory",
      "max_bound_variables": 0,
      "validate_types": false
    },
    "output": {
      "require_json_pipe": false,
      "require_naab_return": false,
      "max_output_lines": 0,
      "strip_whitespace": false,
      "validate_encoding": true
    },
    "context_isolation": {
      "enabled": false,
      "level": "advisory",
      "no_shared_state": false,
      "no_env_pollution": true,
      "clean_temp_files": true
    },
    "parallel": {
      "max_parallel_blocks": 4,
      "timeout_per_block": 30,
      "fail_strategy": "fail_fast",
      "allow_shared_variables": false
    },
    "persistent_runtime": {
      "max_sessions": 5,
      "session_timeout": 300,
      "max_memory_per_session_mb": 256,
      "allow_state_persistence": true
    }
  },

  "polyglot_optimization": {
    "enabled": true,
    "enforcement_level": "advisory",

    "pattern_detection": {
      "enabled": true,
      "task_inference": {
        "numerical_operations": {
          "patterns": ["\\bnp\\.", "\\bnumpy\\.", "matrix", "\\bsum\\(", "\\bmean\\(", "\\blinspace\\(", "\\beigenval", "\\bdet\\(", "\\bfft\\("],
          "optimal_languages": ["python", "nim"],
          "suboptimal_languages": ["javascript", "shell"],
          "message": "Numerical operations perform best in Python (NumPy) or Nim"
        },
        "string_processing": {
          "patterns": ["\\bsplit\\(", "\\bjoin\\(", "\\breplace\\(", "\\bregex\\b", "\\bmatch\\(", "\\bsearch\\(", "\\bfindall\\(", "\\bstrip\\(", "\\btrim\\("],
          "optimal_languages": ["python", "ruby", "nim"],
          "suboptimal_languages": ["go", "shell"],
          "message": "String operations benefit from high-level language built-ins"
        },
        "file_operations": {
          "patterns": ["\\bfind\\b", "\\bgrep\\b", "\\bsed\\b", "\\bawk\\b", "\\bls\\b", "\\bcat\\b", "\\bwc\\b", "\\bsort\\b", "\\bglob\\b", "\\bwalk\\b"],
          "optimal_languages": ["shell"],
          "suboptimal_languages": ["javascript"],
          "message": "Shell tools are purpose-built for file operations"
        },
        "systems_calls": {
          "patterns": ["\\bmalloc\\b", "\\bfree\\b", "pointer", "\\bunsafe\\b", "\\bsyscall\\b", "\\bmmap\\b"],
          "optimal_languages": ["nim", "go", "rust", "cpp"],
          "suboptimal_languages": ["python", "javascript", "ruby"],
          "message": "Systems operations need compiled languages with low-level control"
        },
        "web_apis": {
          "patterns": ["\\bfetch\\(", "\\bhttp\\.", "\\burl\\.", "\\bapi\\b", "\\brequest\\(", "XMLHttpRequest"],
          "optimal_languages": ["javascript", "python", "go"],
          "suboptimal_languages": ["shell", "nim"],
          "message": "Web APIs best handled by languages with rich HTTP libraries"
        },
        "json_processing": {
          "patterns": ["JSON\\.parse", "JSON\\.stringify", "json\\.", "\\bparse_json\\b", "json\\.dumps", "json\\.loads"],
          "optimal_languages": ["javascript", "python", "nim"],
          "suboptimal_languages": ["cpp", "shell"],
          "message": "JSON processing best in languages with native JSON support"
        },
        "concurrency": {
          "patterns": ["\\bgoroutine\\b", "\\basync\\b", "\\bawait\\b", "\\bthread\\b", "\\bparallel\\b", "sync\\.WaitGroup", "\\bchannel\\b", "Promise\\."],
          "optimal_languages": ["go", "javascript"],
          "suboptimal_languages": ["python", "ruby"],
          "message": "Concurrency best in Go (goroutines) or JavaScript (async/await)"
        },
        "data_parsing": {
          "patterns": ["\\bcsv\\.", "\\bxml\\.", "\\byaml\\.", "BeautifulSoup", "\\bparse\\(", "DictReader"],
          "optimal_languages": ["python", "javascript"],
          "suboptimal_languages": ["shell", "go"],
          "message": "Data parsing benefits from Python's rich ecosystem"
        }
      }
    },

    "profiling": {
      "enabled": true,
      "profile_path": "~/.naab/profile.json",
      "max_entries": 10000,
      "include_code_hash": true
    },

    "calibration": {
      "enabled": true,
      "calibration_path": "~/.naab/calibration.json",
      "max_age_days": 30,
      "iterations": 3
    },

    "confidence": {
      "min_display_level": "estimated",
      "suppress_unknown": true,
      "show_measurement_details": true
    },

    "verification": {
      "enabled": false,
      "enforcement_level": "advisory",
      "consensus_languages": ["python", "javascript", "go"],
      "tolerance": 1e-10,
      "verify_task_types": [
        "numerical_computation",
        "string_manipulation",
        "data_parsing",
        "file_operations",
        "cli_tool",
        "web_service",
        "async_operations",
        "systems_programming"
      ],
      "min_consensus": 2,
      "max_verification_time_ms": 5000,
      "show_drift_details": true,
      "drift_tracking": {
        "enabled": false,
        "path": "~/.naab/drift.jsonl",
        "max_entries": 1000,
        "trend_window": 10,
        "escalation_threshold": 0.3,
        "include_code_hash": true
      }
    },

    "language_diversity": {
      "enabled": true,
      "min_languages": 2,
      "max_single_language_percent": 80,
      "message": "Consider using specialized languages for different task types"
    },

    "helper_errors": {
      "enabled": true,
      "show_alternative_language": true,
      "show_example_code": true,
      "fuzzy_match_threshold": 0.7
    },

    "ai_guidance": {
      "enabled": true,
      "include_in_errors": true,
      "suggest_refactoring": true,
      "show_benchmarks": false
    },

