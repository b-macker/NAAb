    "on_override": {
      "command": "",
      "args": [],
      "timeout": 5
    },
    "on_complete": {
      "command": "",
      "args": [],
      "timeout": 5
    },
    "pre_check": {
      "command": "",
      "args": [],
      "timeout": 5
    },
    "post_check": {
      "command": "",
      "args": [],
