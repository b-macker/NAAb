// Helix/modules/fabric_utils.naab
// FABRIC UTILITIES (STRICT FORMAT)

use io
use file

export fn cool_down(state) {
    let new_state = state
    new_state["temp"] = state["temp"] * 0.8
    new_state["pressure"] = state["pressure"] * 0.7
    return new_state
}

export fn shred_artifacts() {
    let vessels_dir = "verification/ch0_full_projects/Helix/vessels/"
    <<shell[vessels_dir]
    rm -f "${vessels_dir}"*
>>
}
