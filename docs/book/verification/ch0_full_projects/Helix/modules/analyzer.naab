// Helix/modules/analyzer.naab
// THE ANALYST (STRICT FORMAT)

use json

export fn analyze_efficiency(state) {
    let result = <<python[state]
import json
t, p = float(state['temp']), float(state['pressure'])
score = 1.0 - (abs(5500 - t) / 10000.0) - (abs(1.5 - p) / 10.0)
print(json.dumps({"score": round(max(0, score), 4)}))
>>
    return json.parse("" + result)
}
