// Aegis/modules/shield.naab
// THE SHIELD: Traffic Generator (Shell)

use io
use file

export fn generate_traffic(base, generation) {
    let path = base + "/logs/traffic_gen_" + generation + ".dat"

    // Generate 5000 random numbers
    <<shell[path]
    mkdir -p "$(dirname "$path")"
    for i in $(seq 1 5000); do
        echo $((RANDOM % 10000))
    done > "$path"
>>
    return path
}
