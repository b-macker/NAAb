{
  "version": "3.0",
  "mode": "enforce",
  "description": "Personal governance config — strict security, quality-focused, LLM anti-drift",

  "languages": {
    "allowed": ["python", "javascript", "shell", "go", "ruby", "nim"],
    "blocked": [],
    "require_explicit": false,
    "per_language": {
      "python": {
        "timeout": 15,
        "max_lines": 200,
        "banned_functions": ["eval(", "exec(", "compile(", "__import__("],
        "imports": {
          "mode": "blocklist",
          "blocked": ["subprocess", "ctypes", "os.system", "pickle"],
          "blocked_from": ["os:system,popen,exec"]
        },
        "no_star_imports": true,
        "no_star_imports_level": "soft"
      },
      "javascript": {
        "timeout": 10,
        "max_lines": 150,
        "banned_functions": ["eval(", "Function("],
        "imports": {
          "mode": "blocklist",
          "blocked": ["child_process", "fs", "net"]
        },
        "no_var": true,
        "no_var_level": "soft"
      },
      "shell": {
        "timeout": 10,
        "max_lines": 50,
        "banned_commands": ["rm -rf /", "mkfs", "dd if=/dev/zero"],
        "shell_injection": true,
        "shell_injection_level": "hard",
        "no_curl_pipe_sh": true,
        "no_curl_pipe_sh_level": "hard",
        "no_wget_pipe_bash": true,
        "no_wget_pipe_bash_level": "hard"
      },
      "go": {
        "timeout": 30,
        "max_lines": 200,
        "banned_imports": ["unsafe", "syscall"]
      },
      "ruby": {
        "timeout": 10,
        "max_lines": 100,
        "banned_functions": ["eval(", "system(", "exec("]
      },
      "nim": {
        "timeout": 30,
        "max_lines": 200,
        "banned_functions": []
      }
    }
  },

  "capabilities": {
    "network": {
      "enabled": true,
      "http_allowed": true,
      "blocked_hosts": ["169.254.169.254", "metadata.google.internal"],
      "allow_raw_sockets": false
    },
    "filesystem": {
      "mode": "write",
      "blocked_paths": ["/etc/shadow", "/etc/passwd"],
      "blocked_extensions": [".exe", ".dll", ".so"]
    },
    "shell": {
      "enabled": true,
      "blocked_commands": ["sudo", "su", "chmod +s"],
      "allow_backgrounding": false
    },
    "env_vars": {
      "read": true,
      "write": false,
      "blocked_read": ["AWS_SECRET_ACCESS_KEY", "GITHUB_TOKEN"],
      "blocked_write": ["PATH", "HOME", "LD_PRELOAD"]
    }
  },

  "limits": {
    "timeout": {
      "global": 60,
      "per_block": 30,
      "total_polyglot": 120
    },
    "execution": {
      "call_depth": 100,
      "loop_iterations": 1000000,
      "polyglot_blocks": 50,
      "parallel_blocks": 4
    },
    "code": {
      "max_lines_per_block": 500,
      "max_nesting_depth": 4,
      "max_functions": 100
    },
    "data": {
      "nesting_depth": 20,
      "output_size": 1000000
    }
  },

  "requirements": {
    "main_block": {
      "enabled": true,
      "level": "soft",
      "message": "Programs should have a main block"
    },
    "naming_conventions": {
      "enabled": true,
      "level": "advisory",
      "variables": "snake_case",
      "functions": "snake_case",
      "constants": "UPPER_SNAKE_CASE",
      "check_naab_code": true,
      "check_polyglot_code": false
    },
    "documentation": {
      "enabled": true,
      "level": "advisory",
      "require_file_comment": false,
      "require_function_comment": false
    }
  },

  "restrictions": {
    "dangerous_calls": {
      "enabled": true,
      "level": "hard"
    },
    "shell_injection": {
      "enabled": true,
      "level": "hard"
    },
    "privilege_escalation": {
      "enabled": true,
      "level": "hard",
      "block_sudo": true,
      "block_su": true,
      "block_chmod_suid": true,
      "block_setuid": true
    },
    "imports": {
      "enabled": true,
      "level": "soft",
      "mode": "blocklist",
      "blocked": {
        "python": ["subprocess", "ctypes", "pickle", "os.system"],
        "javascript": ["child_process", "fs", "net", "cluster"],
        "ruby": ["open3", "pty"]
      }
    },
    "resource_abuse": {
      "enabled": true,
      "level": "hard",
      "block_fork_bomb": true,
      "block_recursive_file_ops": true,
      "block_disk_filling": true
    },
    "code_injection": {
      "enabled": true,
      "level": "hard",
      "block_dynamic_code_gen": true,
      "block_sql_injection_patterns": true,
      "block_command_injection": true
    }
  },

  "code_quality": {
    "no_secrets": {
      "enabled": true,
      "level": "hard",
      "entropy_check": {
        "enabled": true,
        "threshold": 4.5,
        "min_length": 20
      },
      "suspicious_variable_names": {
        "enabled": true,
        "names": ["password", "secret", "api_key", "token", "private_key"]
      },
      "allowlist": ["example.com", "localhost", "127.0.0.1"]
    },
    "no_placeholders": {
      "enabled": true,
      "level": "hard",
      "markers": ["TODO", "FIXME", "STUB", "PLACEHOLDER", "HACK", "XXX", "TEMP"],
      "case_sensitive": false
    },
    "no_oversimplification": {
      "enabled": true,
      "level": "hard",
      "check_empty_bodies": true,
      "check_trivial_returns": true,
      "check_identity_functions": true,
      "check_not_implemented": true,
      "check_comment_only_bodies": true,
      "check_fabricated_results": true,
      "min_function_lines": 2
    },
    "no_incomplete_logic": {
      "enabled": true,
      "level": "hard",
      "check_empty_catch": true,
      "check_swallowed_exceptions": true,
      "check_generic_errors": true,
      "check_vague_error_messages": true,
      "check_single_iteration_loops": true,
      "check_always_true_false": true
    },
    "no_simulation_markers": {
      "enabled": true,
      "level": "hard"
    },
    "no_hardcoded_results": {
      "enabled": true,
      "level": "soft",
      "check_return_true_false": true,
      "check_fabricated_results": true,
      "check_perfect_scores": true
    },
    "no_temporary_code": {
      "enabled": true,
      "level": "soft"
    },
    "no_sql_injection": {
      "enabled": true,
      "level": "hard"
    },
    "no_path_traversal": {
      "enabled": true,
      "level": "hard"
    },
    "no_unsafe_deserialization": {
      "enabled": true,
      "level": "hard"
    },
    "no_dead_code": {
      "enabled": true,
      "level": "advisory",
      "detect_unreachable_after_return": true,
      "detect_always_true_conditions": true,
      "detect_empty_except_blocks": true,
      "detect_commented_out_code": true
    },
    "no_debug_artifacts": {
      "enabled": true,
      "level": "soft",
      "check_polyglot_only": true
    },
    "no_mock_data": {
      "enabled": true,
      "level": "advisory",
      "ignore_in_test_context": true
    },
    "no_pii": {
      "enabled": true,
      "level": "advisory",
      "detect_ssn": true,
      "detect_credit_card": true,
      "detect_email": true,
      "mask_in_errors": true
    },
    "no_hallucinated_apis": {
      "enabled": true,
      "level": "soft"
    },
    "max_complexity": {
      "enabled": true,
      "level": "soft",
      "max_lines_per_block": 100,
      "max_nesting_depth": 4,
      "max_parameters": 6,
      "max_cyclomatic_complexity": 10,
      "max_cognitive_complexity": 15
    },
    "encoding": {
      "enabled": true,
      "level": "advisory",
      "require_utf8": true,
      "block_null_bytes": true,
      "block_unicode_bidi": true
    }
  },

  "custom_rules": [
    {
      "id": "PERSONAL-001",
      "name": "no_eval_anywhere",
      "description": "Block eval() across all languages",
      "pattern": "\\beval\\s*\\(",
      "languages": ["python", "javascript", "ruby", "php"],
      "level": "hard",
      "message": "eval() is forbidden — use safe alternatives (json.loads, JSON.parse, etc.)",
      "enabled": true
    },
    {
      "id": "PERSONAL-002",
      "name": "no_exec_system",
      "description": "Block system() and exec() shell calls",
      "pattern": "\\b(system|exec|popen)\\s*\\(",
      "languages": ["python", "ruby", "php", "cpp"],
      "level": "hard",
      "message": "Direct system calls are forbidden — use language-native alternatives",
      "enabled": true
    }
  ],

  "scopes": [
    {
      "glob": "tests/**",
      "overrides": {
        "code_quality.no_placeholders.level": "advisory",
        "code_quality.no_mock_data": "false",
        "code_quality.no_oversimplification.level": "advisory",
        "code_quality.no_hardcoded_results": "false",
        "code_quality.max_complexity": "false"
      }
    }
  ],

  "output": {
    "summary": {
      "enabled": true,
      "format": "detailed",
      "show_passing": false,
      "group_by": "category",
      "sort_by": "severity"
    },
    "errors": {
      "verbose": true,
      "show_line_preview": true,
      "show_help": true,
      "show_examples": true,
      "show_fix_suggestions": true,
      "max_errors_per_rule": 5,
      "max_total_errors": 50
    },
    "formatting": {
      "color": true,
      "unicode_symbols": true
    }
  },

  "audit": {
    "level": "basic",
    "output_file": ".governance-audit.jsonl",
    "log_events": {
      "checks_failed": true,
      "checks_warned": true,
      "overrides": true,
      "config_loaded": true
    }
  },

  "polyglot": {
    "variable_binding": {
      "require_explicit": false,
      "require_explicit_level": "advisory"
    },
    "context_isolation": {
      "enabled": false,
      "no_env_pollution": true,
      "clean_temp_files": true
    },
    "parallel": {
      "max_parallel_blocks": 4,
      "timeout_per_block": 30,
      "fail_strategy": "fail_fast"
    }
  },

  "polyglot_optimization": {
    "enabled": true,
    "enforcement_level": "advisory",
    "pattern_detection": {
      "enabled": true
    },
    "helper_errors": {
      "enabled": true,
      "show_alternative_language": true,
      "show_example_code": true
    },
    "ai_guidance": {
      "enabled": true,
      "suggest_refactoring": true
    }
  }
}
