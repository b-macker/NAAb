// Before/After Optimization Examples
// Shows 10 side-by-side comparisons of suboptimal vs optimal language choices

// ============================================================================
// EXAMPLE 1: Matrix Operations
// ============================================================================

function example1_before() {
    print("BEFORE: Python for matrix operations")
    let result = <<python
import numpy as np
matrix = np.random.randn(1000, 1000)
eigenvalues = np.linalg.eigvals(matrix)
"Computed in Python"
    >>
    print(result)
}

function example1_after() {
    print("AFTER: Julia for matrix operations")
    let result = <<julia
using LinearAlgebra
matrix = randn(1000, 1000)
eigenvalues = eigvals(matrix)
"Computed in Julia - 10-50x faster!"
    >>
    print(result)
}

// Performance: Julia 10-50x faster than Python
// Reason: JIT-compiled, built-in BLAS/LAPACK

// ============================================================================
// EXAMPLE 2: File Operations
// ============================================================================

function example2_before() {
    print("BEFORE: Python for file searching")
    let result = <<python
import os
import glob

files = []
for root, dirs, filenames in os.walk('.'):
    for f in filenames:
        if f.endswith('.txt'):
            files.append(os.path.join(root, f))
len(files)
    >>
    print("Found " + result + " files with Python")
}

function example2_after() {
    print("AFTER: Shell for file searching")
    let result = <<shell
find . -name "*.txt" -type f | wc -l
    >>
    print("Found files with Shell - 2-5x faster!")
}

// Performance: Shell 2-5x faster
// Reason: Find command optimized for filesystem operations

// ============================================================================
// EXAMPLE 3: String Processing
// ============================================================================

function example3_before() {
    print("BEFORE: JavaScript for regex matching")
    let result = <<javascript
const text = "hello world hello universe";
const pattern = /hello/g;
const matches = text.match(pattern);
matches ? matches.length : 0;
    >>
    print("Found " + result + " matches")
}

function example3_after() {
    print("AFTER: Python for regex matching")
    let result = <<python
import re
text = "hello world hello universe"
matches = re.findall(r'hello', text)
len(matches)
    >>
    print("Found " + result + " matches - Better string API")
}

// Performance: Python slightly faster + better regex features
// Reason: Rich string API, compiled regex caching

// ============================================================================
// EXAMPLE 4: JSON Processing
// ============================================================================

function example4_before() {
    print("BEFORE: Python for JSON parsing")
    let result = <<python
import json
data = '{"name": "Alice", "age": 30}'
parsed = json.loads(data)
parsed['name']
    >>
    print("Parsed: " + result)
}

function example4_after() {
    print("AFTER: JavaScript for JSON parsing")
    let result = <<javascript
const data = '{"name": "Alice", "age": 30}';
const parsed = JSON.parse(data);
parsed.name;
    >>
    print("Parsed: " + result + " - Native JSON support")
}

// Performance: JavaScript native JSON = fastest
// Reason: JSON.parse/stringify built into language

// ============================================================================
// EXAMPLE 5: Concurrent Operations
// ============================================================================

function example5_before() {
    print("BEFORE: Python threads for concurrency")
    let result = <<python
import threading

def worker(n):
    return n * 2

threads = []
for i in range(5):
    t = threading.Thread(target=worker, args=(i,))
    threads.append(t)
    t.start()

for t in threads:
    t.join()

"5 threads completed"
    >>
    print(result + " (limited by GIL)")
}

function example5_after() {
    print("AFTER: Go goroutines for concurrency")
    let result = <<go
package main
import (
    "fmt"
    "sync"
)

func main() {
    var wg sync.WaitGroup
    for i := 0; i < 5; i++ {
        wg.Add(1)
        go func(n int) {
            defer wg.Done()
            _ = n * 2
        }(i)
    }
    wg.Wait()
    fmt.Println("5 goroutines completed")
}
    >>
}

// Performance: Go 5-20x faster for parallel work
// Reason: True parallelism, lightweight goroutines

// ============================================================================
// EXAMPLE 6: Systems Programming
// ============================================================================

function example6_before() {
    print("BEFORE: Python for pointer operations")
    let result = <<python
# Python doesn't have real pointers
# Using ctypes for low-level work is awkward
import ctypes
ptr = ctypes.pointer(ctypes.c_int(42))
"Pointer operations in Python - not ideal"
    >>
    print(result)
}

function example6_after() {
    print("AFTER: Zig for pointer operations")
    let result = <<zig
const std = @import("std");

pub fn main() !void {
    var value: i32 = 42;
    const ptr: *i32 = &value;
    ptr.* = 100;

    const stdout = std.io.getStdOut().writer();
    try stdout.print("Pointer operations in Zig - explicit and safe\n", .{});
}
    >>
}

// Performance: Zig 50-200x faster + memory safe
// Reason: Compiled, explicit memory control

// ============================================================================
// EXAMPLE 7: Web API Calls
// ============================================================================

function example7_before() {
    print("BEFORE: Shell for HTTP requests")
    let result = <<shell
curl -s https://api.example.com/data | head -n 1
    >>
    print("Fetched with curl")
}

function example7_after() {
    print("AFTER: JavaScript for HTTP requests")
    let result = <<javascript
// Native async/await + fetch
fetch('https://api.example.com/data')
    .then(r => r.json())
    .then(data => console.log('Fetched with fetch'))
    .catch(err => console.error(err));
"Request sent";
    >>
    print(result + " - Better error handling")
}

// Performance: JavaScript better for complex API logic
// Reason: Native async, JSON parsing, error handling

// ============================================================================
// EXAMPLE 8: Data Aggregation
// ============================================================================

function example8_before() {
    print("BEFORE: Shell for data aggregation")
    let result = <<shell
cat data.txt | awk '{sum+=$1; count++} END {print sum/count}'
    >>
    print("Calculated average with awk")
}

function example8_after() {
    print("AFTER: Python for data aggregation")
    let result = <<python
# For complex aggregation, Python is clearer
data = [10, 20, 30, 40, 50]
average = sum(data) / len(data)
median = sorted(data)[len(data)//2]
f"avg={average}, median={median}"
    >>
    print("Calculated statistics: " + result)
}

// Performance: Python better for complex logic
// Reason: Readability, maintainability, complex calculations

// ============================================================================
// EXAMPLE 9: Image Processing
// ============================================================================

function example9_before() {
    print("BEFORE: Python for image filtering")
    let result = <<python
# from PIL import Image
# img = Image.open('input.jpg')
# img = img.filter(ImageFilter.BLUR)
"Image processed in Python - slow for large images"
    >>
    print(result)
}

function example9_after() {
    print("AFTER: C++ for image filtering")
    let result = <<cpp
#include <iostream>
// #include <opencv2/opencv.hpp>
// cv::Mat img = cv::imread("input.jpg");
// cv::GaussianBlur(img, img, cv::Size(5,5), 0);
int main() {
    std::cout << "Image processed in C++ - 10-50x faster!" << std::endl;
    return 0;
}
    >>
}

// Performance: C++ 10-50x faster
// Reason: Optimized libraries, compiled code

// ============================================================================
// EXAMPLE 10: CLI Tool
// ============================================================================

function example10_before() {
    print("BEFORE: Python for CLI tool")
    let result = <<python
import sys
import argparse

parser = argparse.ArgumentParser()
parser.add_argument('--name')
# Slow startup time (~50ms)
"Python CLI tool"
    >>
    print(result)
}

function example10_after() {
    print("AFTER: Go for CLI tool")
    let result = <<go
package main
import "flag"
import "fmt"

func main() {
    name := flag.String("name", "", "Name")
    flag.Parse()
    fmt.Println("Go CLI tool - instant startup")
}
    >>
}

// Performance: Go 10-20x faster startup
// Reason: Compiled binary, no interpreter overhead

