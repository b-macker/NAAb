// Test: Governance under degraded/partial configuration
// Tests that missing or incomplete config sections don't crash

use math

fn add_stock(inventory, product_id, quantity, tx_type) {
    return {"inventory": inventory, "transaction": {}}
}

fn test_basic_execution() {
    let passed = 0
    let total = 0

    // Test 1: Basic function execution should work
    total = total + 1
    let result = add_stock({}, "prod_1", 10, "restock")
    if result.get("inventory") != null {
        passed = passed + 1
    }

    return [passed, total]
}

fn test_polyglot_still_works() {
    let passed = 0
    let total = 0

    // Test 2: Python polyglot should still execute
    total = total + 1
    let val = <<python
print(42)
>>
    if string(val) == "42" {
        passed = passed + 1
    }

    return [passed, total]
}

fn test_math_operations() {
    let passed = 0
    let total = 0

    // Test 3: Normal math operations unaffected
    total = total + 1
    let x = math.max(0, -5)
    if x == 0 {
        passed = passed + 1
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_basic_execution()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_polyglot_still_works()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_math_operations()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    print(string(total_passed) + "/" + string(total_tests) + " degraded config tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL")
    }
}
