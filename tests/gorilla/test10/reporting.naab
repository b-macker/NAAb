use array
use math
use string
use csv
import "./suppliers.naab" as sup

export fn generate_inventory_report(inventory, products) {
    let lines = []
    lines.push(string.pad_right("SKU", 12) + string.pad_right("Name", 20) + string.pad_right("Stock", 8) + string.pad_right("Min", 8) + string.pad_right("Max", 8) + string.pad_right("ROP", 8) + string.pad_right("Value", 12) + "Status")
    lines.push(string.repeat("-", 86))

    let total_value = 0.0
    let items_below_reorder = 0
    let items_overstocked = 0

    for product in products {
        let pid = string(product.get("id"))
        let stock = inventory.get(pid, 0)
        let min_s = int(product.get("min_stock", 0))
        let max_s = int(product.get("max_stock", 0))
        let rop = int(product.get("reorder_point", 0))
        let cost = float(product.get("unit_cost", 0.0))
        let val = float(stock) * cost
        
        total_value = total_value + val
        
        let status = "OK"
        if stock < rop {
            status = "LOW"
            items_below_reorder = items_below_reorder + 1
        } else if stock > max_s {
            status = "OVER"
            items_overstocked = items_overstocked + 1
        }
        
        let line = string.pad_right(string(product.get("sku", "")), 12)
        line = line + string.pad_right(string(product.get("name", "")), 20)
        line = line + string.pad_right(string(stock), 8)
        line = line + string.pad_right(string(min_s), 8)
        line = line + string.pad_right(string(max_s), 8)
        line = line + string.pad_right(string(rop), 8)
        line = line + string.pad_right(string(int(val)), 12)
        line = line + status
        lines.push(line)
    }

    return {
        "report_text": array.join(lines, "\n"),
        "total_value": total_value,
        "items_below_reorder": items_below_reorder,
        "items_overstocked": items_overstocked
    }
}

export fn generate_supplier_scorecard(suppliers, order_history) {
    let scorecard = {}
    for supplier in suppliers {
        let s_name = string(supplier.get("name", "Unknown"))
        let metrics = sup.score_supplier(supplier, order_history)
        scorecard.set(s_name, metrics)
    }
    return scorecard
}

export fn generate_purchase_summary(orders, date_range) {
    let total_spent = 0.0
    let order_count = len(orders)
    let by_status = {}
    let by_priority = {}

    for order in orders {
        let total = float(order.get("total", 0.0))
        total_spent = total_spent + total
        
        let status = string(order.get("status", "unknown"))
        by_status.set(status, int(by_status.get(status, 0)) + 1)
        
        let priority = string(order.get("priority", "normal"))
        by_priority.set(priority, int(by_priority.get(priority, 0)) + 1)
    }

    let avg_val = 0.0
    if order_count > 0 {
        avg_val = total_spent / float(order_count)
    }

    return {
        "total_spent": total_spent,
        "order_count": order_count,
        "avg_order_value": avg_val,
        "by_status": by_status,
        "by_priority": by_priority
    }
}

export fn export_to_csv(data, headers) {
    let rows = [headers]
    for row in data {
        rows.push(row)
    }
    return csv.stringify(rows)
}

export fn calculate_kpis(inventory, orders, transactions, products) {
    let delivered_orders = 0
    for order in orders {
        if order.get("status") == "delivered" {
            delivered_orders = delivered_orders + 1
        }
    }
    let fill_rate = 0.0
    if len(orders) > 0 {
        fill_rate = float(delivered_orders) / float(len(orders))
    }

    let low_stock_count = 0
    for product in products {
        let pid = string(product.get("id"))
        if inventory.get(pid, 0) < int(product.get("reorder_point", 0)) {
            low_stock_count = low_stock_count + 1
        }
    }
    let stockout_rate = 0.0
    if len(products) > 0 {
        stockout_rate = float(low_stock_count) / float(len(products))
    }

    let total_sales = 0.0
    for tx in transactions {
        if tx.get("type") == 1 { // Sale
            total_sales = total_sales + float(tx.get("quantity", 0))
        }
    }
    
    let total_stock = 0.0
    for pid in inventory {
        total_stock = total_stock + float(inventory.get(pid, 0))
    }
    let avg_inventory = total_stock / float(math.max(1, len(inventory)))
    
    let inventory_turns = 0.0
    if avg_inventory > 0.0 {
        inventory_turns = total_sales / avg_inventory
    }

    let total_order_val = 0.0
    for order in orders {
        total_order_val = total_order_val + float(order.get("total", 0.0))
    }
    let avg_order_value = 0.0
    if len(orders) > 0 {
        avg_order_value = total_order_val / float(len(orders))
    }

    return {
        "fill_rate": fill_rate,
        "stockout_rate": stockout_rate,
        "inventory_turns": inventory_turns,
        "avg_order_value": avg_order_value
    }
}
