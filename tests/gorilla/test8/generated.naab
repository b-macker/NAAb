    total_passed = total_passed + r13[0]
    total_tests = total_tests + r13[1]
    print("test_update_properties: " + string(r13[0]) + "/" + string(r13[1]))

    let r14 = test_get_degree()
    total_passed = total_passed + r14[0]
    total_tests = total_tests + r14[1]
    print("test_get_degree: " + string(r14[0]) + "/" + string(r14[1]))

    let r15 = test_chained_operations()
    total_passed = total_passed + r15[0]
    total_tests = total_tests + r15[1]
    print("test_chained_operations: " + string(r15[0]) + "/" + string(r15[1]))

    print("")
    print("Total: " + string(total_passed) + "/" + string(total_tests))

    if total_passed == total_tests {
        print("ALL TESTS PASSED")
    }

    // --- Simulation: Build and analyze a network graph ---
    print("")
    print("--- Simulation ---")

    let net = {"nodes": [], "edges": []}
    net = add_node(net, create_node(1, "router", {"location": "dc1"}))
    net = add_node(net, create_node(2, "switch", {"ports": "48"}))
    net = add_node(net, create_node(3, "server", {"cpu": "16core"}))
    net = add_node(net, create_node(4, "server", {"cpu": "8core"}))
    net = add_node(net, create_node(5, "client", {"os": "linux"}))

    net = add_edge(net, 1, 2, 10, "fiber")
    net = add_edge(net, 1, 3, 10, "fiber")
    net = add_edge(net, 2, 3, 1, "copper")
    net = add_edge(net, 2, 4, 1, "copper")
    net = add_edge(net, 3, 4, 1, "internal")
    net = add_edge(net, 4, 5, 1, "ethernet")
    net = add_edge(net, 1, 5, 10, "vpn")

    let stats = aggregate_graph(net)
    print("Nodes: " + string(stats.get("node_count")))
    print("Edges: " + string(stats.get("edge_count")))
    print("Avg degree: " + string(stats.get("avg_degree")))

    let servers = filter_nodes_by_label(net, "server")
    print("Servers: " + string(len(servers)))

    let bfs_order = traverse_bfs(net, 1, fn(x) { })
    print("BFS from node 1: " + string(bfs_order))

    let sub = get_subgraph(net, [1, 2, 3])
    let sub_stats = aggregate_graph(sub)
    print("Subgraph(1,2,3) edges: " + string(sub_stats.get("edge_count")))

    let cat1 = classify_node(create_node(1, "server", {"cpu": "fast"}))
    print("Server category: " + cat1)

    let cat2 = classify_node(create_node(2, "client", {}))
    print("Client category: " + cat2)

    print("")
    print("Simulation complete.")
}
