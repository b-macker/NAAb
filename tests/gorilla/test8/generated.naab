// =============================================================================
// Graph Database Engine — Gorilla Test #8
// Adversarial scanner evasion test: 12 hidden quality issues
// =============================================================================

use array
use string
use math

// --- Evasion K: Custom debug function wrapping print() ---
// debug_leftovers only checks \bprint\s*\( for NAAb
// The print() INSIDE log() will be caught, but all log() CALLS are invisible
fn log(message) {
    print("[GRAPH] " + string(message))
}

// --- Core: Node Creation ---
fn create_node(id, label, properties) {
    if id == null {
        throw { "code": "NULL_ID", "message": "Node id cannot be null" }
    }
    if label == null || label == "" {
        throw { "code": "INVALID_LABEL", "message": "Node label cannot be empty" }
    }
    let node = {
        "id": id,
        "label": label,
        "properties": properties ?? {}
    }
    return node
}

// --- Core: Edge Creation ---
fn create_edge(from_id, to_id, weight, label) {
    if from_id == null || to_id == null {
        throw { "code": "NULL_ENDPOINT", "message": "Edge endpoints cannot be null" }
    }
    let edge_weight = weight ?? 1
    if edge_weight < 0 {
        edge_weight = 0
    }
    let edge = {
        "from": from_id,
        "to": to_id,
        "weight": edge_weight,
        "label": label ?? "default"
    }
    return edge
}

// --- Evasion A: Bad function parameter names ---
// generic_variable_names var_pat only matches let/var/const assignments
// Function parameters g, nd are NEVER checked
fn add_node(g, nd) {
    let nodes = g.get("nodes") ?? []
    let node_id = nd.get("id")
    let exists = false
    for existing in nodes {
        if existing.get("id") == node_id {
            exists = true
        }
    }
    if !exists {
        nodes.push(nd)
        g["nodes"] = nodes
    }
    // Evasion K: log() calls invisible to debug_leftovers
    log("add_node: id=" + string(node_id) + " exists=" + string(exists))
    return g
}

// --- Evasion A: More bad parameter names ---
// f=from, t=to, w=weight, l=label — all single-letter, all invisible
fn add_edge(g, f, t, w, l) {
    let edge = create_edge(f, t, w, l)
    let edges = g.get("edges") ?? []
    edges.push(edge)
    g["edges"] = edges
    log("add_edge: " + string(f) + " -> " + string(t))
    return g
}

// --- Clean: Neighbor Lookup ---
fn find_neighbors(graph, node_id) {
    let edges = graph.get("edges") ?? []
    let neighbors = []
    for edge in edges {
        let from_id = edge.get("from")
        let to_id = edge.get("to")
        if from_id == node_id {
            let already = false
            for nb in neighbors {
                if nb == to_id { already = true }
            }
            if !already {
                neighbors.push(to_id)
            }
        }
        if to_id == node_id {
            let already = false
            for nb in neighbors {
                if nb == from_id { already = true }
            }
            if !already {
                neighbors.push(from_id)
            }
        }
    }
    return neighbors
}

// --- Evasion B: Catch that swallows exception via assignment evades empty_catch ---
// catch_empty regex requires { } on ONE line. Multi-line catch with trivial
// assignment (let ignored = e) passes governance but still swallows exception.
fn get_edge_weight(graph, from_id, to_id) {
    let edges = graph.get("edges") ?? []
    let found_weight = -1
    for edge in edges {
        if edge.get("from") == from_id && edge.get("to") == to_id {
            found_weight = edge.get("weight") ?? 1
        }
        if edge.get("to") == from_id && edge.get("from") == to_id {
            found_weight = edge.get("weight") ?? 1
        }
    }
    if found_weight < 0 {
        try {
            let alt_edges = graph.get("edges") ?? []
            for ae in alt_edges {
                if ae.get("to") == from_id && ae.get("from") == to_id {
                    found_weight = ae.get("weight") ?? 1
                }
            }
        } catch (e) {
            let ignored = e
        }
    }
    return found_weight
}

// --- Evasion C: Dict bracket access with 2-char variable key ---
// pat3 requires key variable to be 3+ chars: [a-z_]\w{2,}
// "pn" is only 2 chars — below threshold
fn get_node_property(node, pn) {
    let props = node.get("properties") ?? {}
    let has_key = false
    let keys = props.keys()
    for kn in keys {
        if kn == pn {
            has_key = true
        }
    }
    if has_key {
        let val = props[pn]
        return val
    }
    return "unknown"
}

// --- Evasion D: Value semantics via bracket access (not .get()) ---
// get_pat only triggers on .get(), bracket access creates same copy but unchecked
fn update_node_properties(graph, node_id, new_props) {
    let nodes = graph["nodes"]
    let found = false
    let target_idx = -1
    let idx_counter = 0
    for nd in nodes {
        if nd.get("id") == node_id {
            found = true
            target_idx = idx_counter
        }
        idx_counter = idx_counter + 1
    }
    if found && target_idx >= 0 {
        let target = nodes[target_idx]
        let keys = new_props.keys()
        for key in keys {
            target[key] = new_props.get(key) ?? "none"
        }
        // BUG: Never writes back — graph["nodes"] is a copy!
        // target is a copy of nodes[target_idx] which is a copy of graph["nodes"][idx]
        // Mutations to target are lost
    }
    return graph
}

// --- Evasion E: Chained .get() bypasses missing_null_check ---
// Regex requires line to END after .get(). Chaining breaks the match.
fn get_node_label(graph, node_id) {
    let nodes = graph.get("nodes") ?? []
    let found_label = "unknown"
    for nd in nodes {
        if nd.get("id") == node_id {
            found_label = nd.get("label") ?? "unknown"
        }
    }
    return found_label
}

// --- Evasion F: Two-line wrapper evades over_abstraction ---
// over_abstraction requires exactly 1 non-brace body line with return call()
// Two-line wrappers (assign + return) have non_brace.size() == 2
fn get_graph_nodes(graph) {
    let nodes = graph.get("nodes") ?? []
    return nodes
}

fn get_graph_edges(graph) {
    let edges = graph.get("edges") ?? []
    return edges
}

// --- Evasion L: Single-char variable evades single_use_variable ---
// vname.size() < 2 check explicitly skips 1-char names
fn get_degree(graph, node_id) {
    let r = len(find_neighbors(graph, node_id))
    return r
}

fn get_node_count(graph) {
    let c = len(graph.get("nodes") ?? [])
    return c
}

// --- Evasion G: Trivial constant aliases not in word_to_num ---
// word_to_num only has: zero-ten, hundred, thousand
// "pair", "dozen", "single", "half" not in dictionary
fn filter_nodes_by_label(graph, label) {
    let pair = 2
    let single = 1
    let nodes = graph.get("nodes") ?? []
    let filtered = []
    let match_count = 0
    for nd in nodes {
        let nd_label = nd.get("label") ?? ""
        if nd_label == label {
            filtered.push(nd)
            match_count = match_count + single
        }
    }
    // Use pair as minimum threshold
    if match_count >= pair {
        log("filter: found " + string(match_count) + " nodes with label " + label)
    }
    return filtered
}

// --- Evasion H: Dead conditional via expression ---
// dead_conditional only checks literal true/false/True/False/1/0
// "1 == 1" and "null != null" are expressions, not literals
fn classify_node(node) {
    let label = node.get("label") ?? "unknown"
    let props = node.get("properties") ?? {}
    let category = "general"

    // Dead conditional: 1 == 1 is always true — adds complexity for nothing
    if 1 == 1 {
        let prop_keys = props.keys()
        if len(prop_keys) > 0 {
            category = "rich"
        }
    }

    // Dead conditional: null != null is always false — dead branch
    if null != null {
        category = "impossible"
        let special_flag = true
    }

    if label == "server" || label == "router" {
        category = "infrastructure"
    }
    if label == "client" || label == "user" {
        category = "endpoint"
    }

    return category
}

// --- Evasion I: Hedging/apologetic comments not in pattern ---
// apology_pat missing: "may have", "not thoroughly", "could potentially", "probably"
// may have edge cases with disconnected subgraphs
// not thoroughly tested for large graphs
fn aggregate_graph(graph) {
    let nodes = graph.get("nodes") ?? []
    let edges = graph.get("edges") ?? []
    let node_count = len(nodes)
    let edge_count = len(edges)

    // could potentially be slow for dense graphs
    let total_degree = 0
    for nd in nodes {
        let nd_id = nd.get("id")
        let degree = len(find_neighbors(graph, nd_id))
        total_degree = total_degree + degree
    }

    let avg_degree = 0
    if node_count > 0 {
        avg_degree = total_degree / node_count
    }

    // probably works for most cases
    let result = {
        "node_count": node_count,
        "edge_count": edge_count,
        "avg_degree": avg_degree
    }
    return result
}

// --- Evasion J: Recursive with guard word but no actual guard ---
// guard_pat matches \bdepth\b — scanner thinks it's a depth guard
// But depth is passed unchanged — no check, no decrement
fn find_connected(graph, node_id, depth) {
    let neighbors = find_neighbors(graph, node_id)
    if len(neighbors) == 0 {
        return [node_id]
    }
    let result = [node_id]
    for nb in neighbors {
        // depth passed unchanged — NOT used as recursion guard!
        // Scanner sees "depth" word and assumes it's guarded
        let sub = find_connected(graph, nb, depth)
        for item in sub {
            let already_in = false
            for existing in result {
                if existing == item {
                    already_in = true
                }
            }
            if !already_in {
                result.push(item)
            }
        }
    }
    return result
}

// --- Evasion A (more): Bad parameter names in BFS ---
// g=graph, s=start, cb=callback — terrible parameter names
fn traverse_bfs(g, s, cb) {
    let queue = [s]
    let visited_set = {}
    let order = []
    while len(queue) > 0 {
        let current = queue[0]
        let new_queue = []
        for qi in 1..len(queue) {
            new_queue.push(queue[qi])
        }
        queue = new_queue
        let key = string(current)
        if visited_set.get(key) != null {
            continue
        }
        visited_set[key] = true
        order.push(current)
        cb(current)
        let neighbors = find_neighbors(g, current)
        for nb in neighbors {
            let nb_key = string(nb)
            if visited_set.get(nb_key) == null {
                queue.push(nb)
            }
        }
    }
    return order
}

// --- Clean: Subgraph Extraction ---
fn get_subgraph(graph, node_ids) {
    let sub_nodes = []
    let sub_edges = []
    let nodes = graph.get("nodes") ?? []
    let edges = graph.get("edges") ?? []

    let id_set = {}
    for nid in node_ids {
        id_set[string(nid)] = true
    }

    for nd in nodes {
        let nd_id = nd.get("id")
        if id_set.get(string(nd_id)) != null {
            sub_nodes.push(nd)
        }
    }

    for edge in edges {
        let from_id = edge.get("from")
        let to_id = edge.get("to")
        if id_set.get(string(from_id)) != null && id_set.get(string(to_id)) != null {
            sub_edges.push(edge)
        }
    }

    return {"nodes": sub_nodes, "edges": sub_edges}
}

// --- Evasion E (concrete): Chained .get() ---
// missing_null_check regex requires line to END after .get()
// Chaining .get().keys() or .get().get() means regex \s*$ fails after first .get()
fn get_chained_property(graph, node_id, prop_name) {
    // Evasion E: chained .get() — if "nodes" key missing, .get("nodes")
    // returns null, then the for-loop silently gets empty iteration
    let nodes = graph.get("nodes") ?? []
    let found_val = "not_found"
    for nd in nodes {
        if nd.get("id") == node_id {
            // This line has .get() NOT at end of line — evades missing_null_check
            let prop_val = nd.get("properties").get(prop_name)
            found_val = prop_val ?? "not_found"
        }
    }
    return found_val
}

