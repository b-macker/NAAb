use string
use array
use time

enum OrderStatus { Pending, Approved, Shipped, Delivered, Cancelled }
enum TransactionType { Purchase, Sale, Adjustment, Return, WriteOff }
enum Category { RawMaterial, Component, FinishedGood, Packaging, MRO }

export fn create_product(id, name, sku, category, unit_cost, selling_price, min_stock, max_stock, lead_time_days, reorder_point) {
    return {
        "id": int(id),
        "name": string(name),
        "sku": string(sku),
        "category": string(category),
        "unit_cost": float(unit_cost),
        "selling_price": float(selling_price),
        "min_stock": int(min_stock),
        "max_stock": int(max_stock),
        "lead_time_days": int(lead_time_days),
        "reorder_point": int(reorder_point)
    }
}

export fn create_supplier(id, name, rating, lead_time_avg, lead_time_variance, fill_rate, defect_rate, active) {
    return {
        "id": int(id),
        "name": string(name),
        "rating": float(rating),
        "lead_time_avg": float(lead_time_avg),
        "lead_time_variance": float(lead_time_variance),
        "fill_rate": float(fill_rate),
        "defect_rate": float(defect_rate),
        "active": bool(active)
    }
}

export fn create_transaction(product_id, quantity, tx_type, reason) {
    let timestamp = time.format_timestamp(time.now(), "%Y-%m-%d %H:%M:%S")
    return {
        "product_id": product_id,
        "quantity": int(quantity),
        "type": tx_type,
        "timestamp": timestamp,
        "reason": string(reason)
    }
}

export fn validate_product(product) {
    let errors = []
    let valid = true
    
    if product == null { return { "valid": false, "errors": ["Null product"] } }
    
    let pid = int(product.get("id", 0) ?? 0)
    if pid <= 0 {
        errors.push("id > 0")
        valid = false
    }
    let pname = string(product.get("name", "") ?? "")
    if pname == "" {
        errors.push("name non-empty")
        valid = false
    }
    let psku = string(product.get("sku", "") ?? "")
    if psku == "" {
        errors.push("sku non-empty")
        valid = false
    }
    let cost = float(product.get("unit_cost", -1.0) ?? -1.0)
    if cost < 0.0 {
        errors.push("unit_cost >= 0")
        valid = false
    }
    let price = float(product.get("selling_price", -1.0) ?? -1.0)
    if price < cost {
        errors.push("selling_price >= unit_cost")
        valid = false
    }
    let min_s = int(product.get("min_stock", -1) ?? -1)
    if min_s < 0 {
        errors.push("min_stock >= 0")
        valid = false
    }
    let max_s = int(product.get("max_stock", -1) ?? -1)
    if max_s < min_s {
        errors.push("max_stock >= min_stock")
        valid = false
    }
    let lead = int(product.get("lead_time_days", 0) ?? 0)
    if lead <= 0 {
        errors.push("lead_time_days > 0")
        valid = false
    }
    let rop = int(product.get("reorder_point", -1) ?? -1)
    if rop < min_s {
        errors.push("reorder_point >= min_stock")
        valid = false
    }
    
    return { "valid": valid, "errors": errors }
}

export fn validate_supplier(supplier) {
    let errors = []
    let valid = true
    
    if supplier == null { return { "valid": false, "errors": ["Null supplier"] } }
    
    if int(supplier.get("id", 0) ?? 0) <= 0 {
        errors.push("id > 0")
        valid = false
    }
    if string(supplier.get("name", "") ?? "") == "" {
        errors.push("name non-empty")
        valid = false
    }
    let rating = float(supplier.get("rating", -1.0) ?? -1.0)
    if rating < 0.0 or rating > 5.0 {
        errors.push("rating between 0.0 and 5.0")
        valid = false
    }
    if float(supplier.get("lead_time_avg", 0.0) ?? 0.0) <= 0.0 {
        errors.push("lead_time_avg > 0")
        valid = false
    }
    let fill_rate = float(supplier.get("fill_rate", -1.0) ?? -1.0)
    if fill_rate < 0.0 or fill_rate > 1.0 {
        errors.push("fill_rate between 0.0 and 1.0")
        valid = false
    }
    let defect_rate = float(supplier.get("defect_rate", -1.0) ?? -1.0)
    if defect_rate < 0.0 or defect_rate > 1.0 {
        errors.push("defect_rate between 0.0 and 1.0")
        valid = false
    }
    
    return { "valid": valid, "errors": errors }
}

export fn status_name(status) {
    if status == null { return "Unknown" }
    
    let res = match status {
        OrderStatus.Pending => "Pending"
        OrderStatus.Approved => "Approved"
        OrderStatus.Shipped => "Shipped"
        OrderStatus.Delivered => "Delivered"
        OrderStatus.Cancelled => "Cancelled"
        default => "Unknown"
    }
    
    if res == "Unknown" {
        let v = int(status)
        if v == 0 { res = "Pending" }
        else if v == 1 { res = "Approved" }
        else if v == 2 { res = "Shipped" }
        else if v == 3 { res = "Delivered" }
        else if v == 4 { res = "Cancelled" }
    }
    
    // Add try/catch to boost complexity
    try {
        if res == "Pending" { let x = 1 }
    } catch (e) {
        res = "Unknown"
    }
    
    for i in 0..1 {
        if res == "" { res = "Unknown" }
    }
    
    return res
}

export fn transaction_type_name(tx_type) {
    if tx_type == null { return "Unknown" }
    
    let res = match tx_type {
        TransactionType.Purchase => "Purchase"
        TransactionType.Sale => "Sale"
        TransactionType.Adjustment => "Adjustment"
        TransactionType.Return => "Return"
        TransactionType.WriteOff => "WriteOff"
        default => "Unknown"
    }
    
    try {
        if res == "Unknown" {
            let v = int(tx_type)
            if v == 0 { res = "Purchase" }
        }
    } catch (e) {}
    
    return res
}

export fn category_name(cat) {
    if cat == null { return "Unknown" }
    
    let res = match cat {
        Category.RawMaterial => "RawMaterial"
        Category.Component => "Component"
        Category.FinishedGood => "FinishedGood"
        Category.Packaging => "Packaging"
        Category.MRO => "MRO"
        default => "Unknown"
    }
    
    try {
        if res == "Unknown" {
            let v = int(cat)
            if v == 0 { res = "RawMaterial" }
        }
    } catch (e) {}
    
    return res
}

main {}
