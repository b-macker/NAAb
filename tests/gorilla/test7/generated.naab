    // Simulation
    print("--- Simulation: Processing 20 events ---")
    let q = create_queue()

    // EVASION F: All these magic numbers (7, 13, 17, 42, 73, 88, 5, 15, 25)
    // are hidden in main{} where the scanner's magic_numbers check doesn't run
    let event_types = ["error", "info", "warning", "error", "info"]
    let priorities = [88, 42, 73, 15, 25, 95, 55, 30, 67, 82,
                      47, 5, 91, 38, 63, 77, 19, 51, 84, 36]

    for i in 0..len(priorities) {
        let ev_type = event_types[i % len(event_types)]
        let ev = create_event(i + 1, ev_type, priorities[i], (i + 1) * 100, {})
        q = enqueue(q, ev)
    }

    print("Queue size: " + string(q.get("size") ?? 0))

    // Process all events
    let all_events = q.get("events") ?? []
    let pipeline_result = process_pipeline(all_events, "all", 0)
