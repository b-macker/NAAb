    let agg = aggregate_events(all_events)
    print("Total events: " + string(agg.get("total") ?? 0))
    print("Avg priority: " + string(int(agg.get("avg_priority") ?? 0)))

    let counts = agg.get("count_by_type") ?? {}
    for event_type in counts {
        let count_val = counts.get(event_type) ?? 0
        print("  " + event_type + ": " + string(count_val))
    }

    // Anomaly detection
    let anomalies = detect_anomalies(all_events)
    print("Anomalies detected: " + string(len(anomalies)))

    // Scoring
    let score_sum = 0
    for i in 0..len(all_events) {
        let ev_score = get_event_score(all_events[i])
        score_sum = score_sum + int(ev_score)
    }
    print("Total event scores: " + string(score_sum))

    // EVASION J: Variable key access — should throw but scanner won't catch it
    // The scanner's dict_bracket_access only detects quoted string keys like dict["key"]
    // Using a variable key bypasses the regex entirely
    let field = "nonexistent_field"
    try {
        let ev_test = create_event(99, "test", 50, 0, {})
        let field_val = get_event_field(ev_test, "type")
        print("Field access result: " + string(field_val))
    } catch (e) {
        print("Field access error: " + string(e))
    }

    print("")
    print("=== Simulation Complete ===")
}
