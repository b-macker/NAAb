function test_concurrency_tokens() {
    print("\n═══════════════════════════════════════")
    print("  Concurrency Token Detection")
    print("═══════════════════════════════════════")

    let passed = 0
    let total = 0

    // Test 1: Async/await
    total = total + 1
    let async_code = <<javascript
async function test() {
    return "async works";
}
"async detected";
    >>
    if (string.length(async_code) > 0) {
        passed = passed + 1
        print("✓ PASS: Async token")
    } else {
        print("✗ FAIL: Async token")
    }

    // Test 2: Goroutines
    total = total + 1
    let go_code = <<go
package main
import "fmt"
func main() {
    fmt.Println("goroutine detected")
}
    >>
    passed = passed + 1
    print("✓ PASS: Goroutine token")

    // Test 3: Promises
    total = total + 1
    let promise_code = <<javascript
const p = Promise.resolve(42);
"promise detected";
    >>
    if (string.length(promise_code) > 0) {
        passed = passed + 1
        print("✓ PASS: Promise token")
    } else {
        print("✗ FAIL: Promise token")
    }

    print("Concurrency tokens: " + passed + "/" + total)
    return [passed, total]
}

