function test_parsing_tokens() {
    print("\n═══════════════════════════════════════")
    print("  Parsing/Serialization Token Detection")
    print("═══════════════════════════════════════")

    let passed = 0
    let total = 0

    // Test 1: JSON parsing
    total = total + 1
    let json_code = <<javascript
const data = JSON.parse('{"key": "value"}');
data.key;
    >>
    if (json_code == "value") {
        passed = passed + 1
        print("✓ PASS: JSON parse token")
    } else {
        print("✗ FAIL: JSON parse token")
    }

    // Test 2: JSON serialization
    total = total + 1
    let serialize_code = <<python
import json
data = {"key": "value"}
json.dumps(data)
    >>
    if (string.length(serialize_code) > 0) {
        passed = passed + 1
        print("✓ PASS: JSON serialize token")
    } else {
        print("✗ FAIL: JSON serialize token")
    }

    // Test 3: CSV parsing
    total = total + 1
    let csv_code = <<python
"csv,data,here".split(",")
    >>
    if (len(csv_code) == 3) {
        passed = passed + 1
        print("✓ PASS: CSV token")
    } else {
        print("✗ FAIL: CSV token")
    }

    print("Parsing tokens: " + passed + "/" + total)
    return [passed, total]
}

function test_shell_tokens() {
    print("\n═══════════════════════════════════════")
    print("  Shell Command Token Detection")
    print("═══════════════════════════════════════")

    let passed = 0
    let total = 0

    // Test 1: Grep command
    total = total + 1
    let grep_cmd = <<shell
echo "hello" | grep "hello"
    >>
    if (string.length(grep_cmd) > 0) {
        passed = passed + 1
        print("✓ PASS: Grep command token")
    } else {
        print("✗ FAIL: Grep command token")
    }

    // Test 2: Pipe operations
    total = total + 1
    let pipe_cmd = <<shell
echo "hello world" | tr 'a-z' 'A-Z'
    >>
    if (pipe_cmd == "HELLO WORLD") {
        passed = passed + 1
        print("✓ PASS: Pipe + tr token")
    } else {
        print("✗ FAIL: Pipe + tr token (got: " + pipe_cmd + ")")
    }

    // Test 3: Echo command
    total = total + 1
    let echo_cmd = <<shell
echo "output"
    >>
    if (string.length(echo_cmd) > 0) {
        passed = passed + 1
        print("✓ PASS: Echo command token")
    } else {
        print("✗ FAIL: Echo command token")
    }

    print("Shell tokens: " + passed + "/" + total)
    return [passed, total]
}

// ============================================================================
// MAIN: Run All Tests
// ============================================================================

main {
    print("╔═══════════════════════════════════════════════════════╗")
    print("║       Lexical Detector Unit Tests                    ║")
    print("║       Token patterns across all categories           ║")
    print("╚═══════════════════════════════════════════════════════╝")

    let total_passed = 0
    let total_run = 0

    let r1 = test_numerical_tokens()
    total_passed = total_passed + r1[0]
    total_run = total_run + r1[1]

    let r2 = test_string_tokens()
    total_passed = total_passed + r2[0]
    total_run = total_run + r2[1]

    let r3 = test_file_io_tokens()
    total_passed = total_passed + r3[0]
    total_run = total_run + r3[1]

    let r4 = test_network_tokens()
    total_passed = total_passed + r4[0]
    total_run = total_run + r4[1]

    let r5 = test_concurrency_tokens()
    total_passed = total_passed + r5[0]
    total_run = total_run + r5[1]

    let r6 = test_datastructure_tokens()
    total_passed = total_passed + r6[0]
    total_run = total_run + r6[1]

    let r7 = test_parsing_tokens()
    total_passed = total_passed + r7[0]
    total_run = total_run + r7[1]

    let r8 = test_shell_tokens()
    total_passed = total_passed + r8[0]
    total_run = total_run + r8[1]

    let total_failed = total_run - total_passed

    print("\n╔═══════════════════════════════════════════════════════╗")
    print("║                    TEST SUMMARY                       ║")
    print("╠═══════════════════════════════════════════════════════╣")
    print("║  Total tests:    " + total_run)
    print("║  Passed:         " + total_passed)
    print("║  Failed:         " + total_failed)
    print("╠═══════════════════════════════════════════════════════╣")

    if (total_failed == 0) {
        print("║  Result: ✓ ALL TESTS PASSED                          ║")
    } else {
        print("║  Result: ✗ SOME TESTS FAILED                         ║")
    }

    print("╚═══════════════════════════════════════════════════════╝")
}
