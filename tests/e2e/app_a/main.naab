    avg(20.0)
    let avg_r = avg(30.0)
    r = check(assert_eq(avg_r, 20.0, "P2.16 running avg"), "P2.16", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.17: Threshold counter
    let tc = analytics.make_threshold_counter(100.0)
    tc(50.0)
    tc(150.0)
    let tc_r = tc(200.0)
    r = check(assert_eq(tc_r[0], 2, "P2.17 above threshold"), "P2.17", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.18: Compute total
    r = check(assert_eq(analytics.compute_total(port.transactions), total_expected, "P2.18 total"), "P2.18", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.19: Compute average
    let avg_exp = total_expected / 5.0
    r = check(assert_eq(analytics.compute_average(port.transactions), avg_exp, "P2.19 average"), "P2.19", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.20: Find max
    let max_t = analytics.find_max_transaction(port.transactions)
    r = check(assert_eq(max_t.amount, 15000.0, "P2.20 max txn"), "P2.20", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.21: Count by risk
    let risk_counts = analytics.count_by_risk(port.transactions)
    r = check(assert_eq(risk_counts["critical"], 1, "P2.21 crit count"), "P2.21", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.22: Empty generator
    let empty = []
    for t in analytics.filter_by_category(port.transactions, "nonexistent") {
        empty = array.push(empty, t)
    }
    r = check(assert_eq(array.length(empty), 0, "P2.22 empty gen"), "P2.22", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.23: Generator reuse (fresh state)
    let run1 = []
    for t in analytics.take_n(port.transactions, 2) { run1 = array.push(run1, t) }
    let run2 = []
    for t in analytics.take_n(port.transactions, 3) { run2 = array.push(run2, t) }
    r = check(assert_true(array.length(run1) == 2 && array.length(run2) == 3, "P2.23 gen reuse"), "P2.23", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.24: Analyze stream (generator + match + f-string)
    let analysis_lines = []
    for line in analytics.analyze_stream(port.transactions) {
        analysis_lines = array.push(analysis_lines, line)
    }
    r = check(assert_eq(array.length(analysis_lines), 5, "P2.24 analyze stream"), "P2.24", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.25: Analysis line content
    r = check(assert_true(string.contains(analysis_lines[0], "TX-0001"), "P2.25 line content"), "P2.25", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.26: Generator with break
    let break_count = 0
    for t in analytics.transaction_stream(port.transactions) {
        break_count = break_count + 1
        if break_count == 3 { break }
    }
    r = check(assert_eq(break_count, 3, "P2.26 gen+break"), "P2.26", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.27: Match with default
    r = check(assert_eq(analytics.classify_category("unknown"), "other", "P2.27 default match"), "P2.27", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.28: Multiple closure instances independent
    let acc2 = analytics.make_accumulator()
    acc2(1000.0)
    let prev = acc(50.0)
    r = check(assert_eq(prev[0], 350.0, "P2.28 closure indep"), "P2.28", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.29: Risk score unknown
    r = check(assert_eq(analytics.risk_score("NONE"), 0.0, "P2.29 unknown score"), "P2.29", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.30: Classify income
    r = check(assert_eq(analytics.classify_category("salary"), "income", "P2.30 salary income"), "P2.30", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    let p2_pass = passed - p1_pass
    let p2_fail = failed - p1_fail
    print(f"    Phase 2: {p2_pass}/{p2_pass + p2_fail}")

    // ──────── Phase 3: Reporting / Stdlib (35 assertions) ────────
    print("  Phase 3: Reporting / Stdlib")
    let p3_start_pass = passed
    let p3_start_fail = failed

    // P3.1: Format currency
    let curr = reporting.format_currency(1234.56, "USD")
    r = check(assert_true(string.contains(curr, "USD"), "P3.1 currency format"), "P3.1", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.2: Format percentage
    let pct = reporting.format_percentage(0.8567)
    r = check(assert_true(string.contains(pct, "%"), "P3.2 percentage"), "P3.2", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.3: Truncate
    r = check(assert_eq(reporting.truncate("hello world", 5), "hello...", "P3.3 truncate"), "P3.3", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.4: Truncate no-op
    r = check(assert_eq(reporting.truncate("hi", 10), "hi", "P3.4 truncate noop"), "P3.4", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.5: JSON stringify
    let j1 = reporting.to_json_report({"key": "value"})
    r = check(assert_true(string.contains(j1, "key"), "P3.5 json stringify"), "P3.5", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.6: JSON parse
    let j2 = reporting.parse_json_config("{\"name\": \"test\"}")
    r = check(assert_eq(j2["name"], "test", "P3.6 json parse"), "P3.6", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.7: JSON roundtrip
    let orig = {"a": 1, "b": "two", "c": true}
    let rt = reporting.json_roundtrip(orig)
    r = check(assert_eq(rt["a"], 1, "P3.7 json roundtrip"), "P3.7", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.8: Stddev
    let sd = reporting.compute_stddev([2.0, 4.0, 4.0, 4.0, 5.0, 5.0, 7.0, 9.0])
    r = check(assert_true(sd > 1.9 && sd < 2.1, "P3.8 stddev"), "P3.8", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.9: Clamp
    r = check(assert_eq(reporting.clamp(150.0, 0.0, 100.0), 100.0, "P3.9 clamp high"), "P3.9", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.10: Clamp low
    r = check(assert_eq(reporting.clamp(-5.0, 0.0, 100.0), 0.0, "P3.10 clamp low"), "P3.10", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.11: Unique categories
    let cats = reporting.unique_categories(port.transactions)
    r = check(assert_true(array.length(cats) >= 4, "P3.11 unique cats"), "P3.11", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.12: Path join
    let pp = reporting.build_report_path("/reports", "output.csv")
    r = check(assert_true(string.contains(pp, "output.csv"), "P3.12 path join"), "P3.12", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.13: Path extension
    r = check(assert_eq(reporting.get_report_extension("report.csv"), ".csv", "P3.13 extension"), "P3.13", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.14: Path basename
    r = check(assert_eq(reporting.get_report_basename("/home/reports/out.txt"), "out.txt", "P3.14 basename"), "P3.14", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.15: Regex validate TX ID (valid)
    r = check(assert_eq(reporting.validate_tx_id("TX-0001"), true, "P3.15 valid id"), "P3.15", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.16: Regex validate TX ID (invalid)
    r = check(assert_eq(reporting.validate_tx_id("INVALID"), false, "P3.16 invalid id"), "P3.16", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.17: Crypto hash
    let h = reporting.hash_report("test data")
    r = check(assert_true(string.length(h) == 64, "P3.17 sha256 len"), "P3.17", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.18: Hash deterministic
    let h2 = reporting.hash_report("test data")
    r = check(assert_eq(h, h2, "P3.18 hash deterministic"), "P3.18", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.19: Time now
    let t1 = reporting.get_timestamp()
    r = check(assert_true(t1 > 0, "P3.19 time now"), "P3.19", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.20: Generate summary report
    let results_list = [
        models.make_result(0.9, "HIGH", "test1", "food"),
        models.make_result(0.3, "LOW", "test2", "rent")
    ]
    let summary = reporting.generate_summary(results_list, "Test Report")
    r = check(assert_true(string.contains(summary, "Test Report"), "P3.20 summary title"), "P3.20", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.21: Summary contains data
    r = check(assert_true(string.contains(summary, "food"), "P3.21 summary data"), "P3.21", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.22: CSV generation
    let csv = reporting.generate_csv(["id", "amount"], [["TX-0001", "500"], ["TX-0002", "1500"]])
    r = check(assert_true(string.contains(csv, "TX-0001"), "P3.22 csv"), "P3.22", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.23: String operations - upper
    r = check(assert_eq(string.upper("hello"), "HELLO", "P3.23 upper"), "P3.23", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.24: String operations - lower
    r = check(assert_eq(string.lower("HELLO"), "hello", "P3.24 lower"), "P3.24", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.25: String operations - split
    let parts = string.split("a,b,c", ",")
    r = check(assert_eq(array.length(parts), 3, "P3.25 split"), "P3.25", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.26: String operations - join
    r = check(assert_eq(string.join(["x", "y", "z"], "-"), "x-y-z", "P3.26 join"), "P3.26", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.27: String operations - trim
    r = check(assert_eq(string.trim("  hi  "), "hi", "P3.27 trim"), "P3.27", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.28: String operations - contains
    r = check(assert_eq(string.contains("hello world", "world"), true, "P3.28 contains"), "P3.28", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.29: String operations - replace
    r = check(assert_eq(string.replace("foo bar", "bar", "baz"), "foo baz", "P3.29 replace"), "P3.29", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.30: String operations - starts_with
    r = check(assert_eq(string.starts_with("/usr/bin", "/usr"), true, "P3.30 starts_with"), "P3.30", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.31: Math operations
    r = check(assert_eq(math.abs(-42), 42, "P3.31 abs"), "P3.31", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.32: Math floor
    r = check(assert_eq(math.floor(3.7), 3, "P3.32 floor"), "P3.32", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.33: Math sqrt
    r = check(assert_eq(math.sqrt(16.0), 4.0, "P3.33 sqrt"), "P3.33", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.34: Array operations
    let arr = [3, 1, 4, 1, 5]
    let sorted = array.sort(arr)
    r = check(assert_eq(sorted[0], 1, "P3.34 sort"), "P3.34", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P3.35: Array reverse
    let rev = array.reverse([1, 2, 3])
    r = check(assert_eq(rev[0], 3, "P3.35 reverse"), "P3.35", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    let p3_pass = passed - p3_start_pass
    let p3_fail = failed - p3_start_fail
    print(f"    Phase 3: {p3_pass}/{p3_pass + p3_fail}")

    // ──────── Phase 4: Integration Pipeline (25 assertions) ────────
    print("  Phase 4: Integration Pipeline")
    let p4_start_pass = passed
    let p4_start_fail = failed

    // Build full dataset
    let txns = [
        models.make_transaction("TX-1001", 50.0, "USD", "food", 100),
        models.make_transaction("TX-1002", 1200.0, "USD", "rent", 200),
        models.make_transaction("TX-1003", 30.0, "USD", "entertainment", 300),
        models.make_transaction("TX-1004", 6000.0, "USD", "salary", 400),
        models.make_transaction("TX-1005", 12000.0, "EUR", "bonus", 500),
        models.make_transaction("TX-1006", 85.0, "USD", "food", 600),
        models.make_transaction("TX-1007", 2500.0, "GBP", "rent", 700),
        models.make_transaction("TX-1008", 150.0, "USD", "entertainment", 800),
        models.make_transaction("TX-1009", 8000.0, "USD", "salary", 900),
        models.make_transaction("TX-1010", 45.0, "USD", "food", 1000)
    ]

    // P4.1: Dataset size
    r = check(assert_eq(array.length(txns), 10, "P4.1 dataset size"), "P4.1", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.2: Stream all
    let all_count = 0
    for t in analytics.transaction_stream(txns) { all_count = all_count + 1 }
    r = check(assert_eq(all_count, 10, "P4.2 stream all"), "P4.2", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.3: Filter food
    let food_txns = []
    for t in analytics.filter_by_category(txns, "food") {
        food_txns = array.push(food_txns, t)
    }
    r = check(assert_eq(array.length(food_txns), 3, "P4.3 food txns"), "P4.3", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.4: Filter salary
    let salary_txns = []
    for t in analytics.filter_by_category(txns, "salary") {
        salary_txns = array.push(salary_txns, t)
    }
    r = check(assert_eq(array.length(salary_txns), 2, "P4.4 salary txns"), "P4.4", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.5: Risk classification on dataset
    let risks = analytics.count_by_risk(txns)
    r = check(assert_true(risks["low"] > 0, "P4.5 has low risk"), "P4.5", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.6: Has critical
    r = check(assert_true(risks["critical"] > 0, "P4.6 has critical"), "P4.6", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.7: Total computation
    let total = analytics.compute_total(txns)
    let expected_total = 50.0 + 1200.0 + 30.0 + 6000.0 + 12000.0 + 85.0 + 2500.0 + 150.0 + 8000.0 + 45.0
    r = check(assert_eq(total, expected_total, "P4.7 total"), "P4.7", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.8: Average
    let avg_val = analytics.compute_average(txns)
    r = check(assert_eq(avg_val, expected_total / 10.0, "P4.8 average"), "P4.8", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.9: Max transaction
    let max_tx = analytics.find_max_transaction(txns)
    r = check(assert_eq(max_tx.id, "TX-1005", "P4.9 max tx id"), "P4.9", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.10: Build portfolio from filtered
    let salary_port = models.make_portfolio("SalaryPort")
    for t in analytics.filter_by_category(txns, "salary") {
        salary_port = models.add_transaction(salary_port, t)
    }
    r = check(assert_eq(salary_port.balance, 14000.0, "P4.10 salary balance"), "P4.10", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.11: Validate all IDs
    let all_valid = true
    for t in txns {
        if !reporting.validate_tx_id(t.id) { all_valid = false }
    }
    r = check(assert_true(all_valid, "P4.11 all ids valid"), "P4.11", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.12: Hash report
    let report_data = reporting.to_json_report({"total": total, "count": 10})
    let report_hash = reporting.hash_report(report_data)
    r = check(assert_true(string.length(report_hash) == 64, "P4.12 hash length"), "P4.12", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.13: Build output path
    let out_path = reporting.build_report_path("/output", "report.csv")
    r = check(assert_true(string.contains(out_path, "report.csv"), "P4.13 output path"), "P4.13", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.14: Full analysis stream
    let full_analysis = []
    for line in analytics.analyze_stream(txns) {
        full_analysis = array.push(full_analysis, line)
    }
    r = check(assert_eq(array.length(full_analysis), 10, "P4.14 full analysis"), "P4.14", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.15: Analysis content check
    r = check(assert_true(string.contains(full_analysis[4], "CRITICAL"), "P4.15 critical in analysis"), "P4.15", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.16: Summary report generation
    let analysis_results = [
        models.make_result(0.25, "LOW", "Small purchase", "food"),
        models.make_result(0.75, "HIGH", "Large payment", "salary"),
        models.make_result(1.0, "CRITICAL", "Huge transfer", "bonus")
    ]
    let final_report = reporting.generate_summary(analysis_results, "Financial Summary")
    r = check(assert_true(string.contains(final_report, "Financial Summary"), "P4.16 report title"), "P4.16", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.17: Report contains all categories
    r = check(assert_true(string.contains(final_report, "food") && string.contains(final_report, "salary"), "P4.17 report cats"), "P4.17", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.18: CSV export
    let csv_data = reporting.generate_csv(["id", "amount", "risk"], [
        ["TX-1001", "50.0", "LOW"],
        ["TX-1005", "12000.0", "CRITICAL"]
    ])
    r = check(assert_true(string.contains(csv_data, "CRITICAL"), "P4.18 csv export"), "P4.18", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.19: Cross-module struct survival
    let cross_tx = models.make_transaction("TX-9999", 999.0, "JPY", "food", 9999)
    let cross_risk = analytics.classify_risk(cross_tx.amount)
    let cross_display = models.display_transaction(cross_tx)
    r = check(assert_true(cross_risk == "LOW" && string.contains(cross_display, "TX-9999"), "P4.19 cross-module"), "P4.19", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.20: Unique categories from dataset
    let uniq_cats = reporting.unique_categories(txns)
    r = check(assert_true(array.length(uniq_cats) >= 4, "P4.20 unique categories"), "P4.20", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.21: Format currency on computed value
    let fmt_total = reporting.format_currency(total, "USD")
    r = check(assert_true(string.contains(fmt_total, "USD"), "P4.21 format total"), "P4.21", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.22: Portfolio from all txns
    let full_port = models.make_portfolio("FullPort")
    for t in txns { full_port = models.add_transaction(full_port, t) }
    r = check(assert_eq(full_port.balance, expected_total, "P4.22 full portfolio"), "P4.22", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.23: Compute matches balance
    let computed = models.compute_portfolio(full_port)
    r = check(assert_eq(computed, full_port.balance, "P4.23 compute=balance"), "P4.23", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.24: Display full portfolio
    let full_disp = models.display_portfolio(full_port)
    r = check(assert_true(string.contains(full_disp, "10 txns"), "P4.24 display count"), "P4.24", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P4.25: Hash changes with data
    let hash_a = reporting.hash_report("data A")
    let hash_b = reporting.hash_report("data B")
    r = check(assert_true(hash_a != hash_b, "P4.25 hash differs"), "P4.25", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    let p4_pass = passed - p4_start_pass
    let p4_fail = failed - p4_start_fail
    print(f"    Phase 4: {p4_pass}/{p4_pass + p4_fail}")

    // ──────── Phase 5: Edge Cases (20 assertions) ────────
    print("  Phase 5: Edge Cases")
    let p5_start_pass = passed
    let p5_start_fail = failed

    // P5.1: Division by zero (try/catch)
    let div_ok = false
    try { let x = 1 / 0 } catch (e) { div_ok = true }
    r = check(assert_true(div_ok, "P5.1 div by zero"), "P5.1", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.2: Empty array average
    r = check(assert_eq(analytics.compute_average([]), 0.0, "P5.2 empty avg"), "P5.2", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.3: Empty array total
    r = check(assert_eq(analytics.compute_total([]), 0.0, "P5.3 empty total"), "P5.3", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.4: Large number
    let big = 999999999.0
    r = check(assert_true(big > 0, "P5.4 large number"), "P5.4", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.5: Negative amount risk
    r = check(assert_eq(analytics.classify_risk(-100.0), "LOW", "P5.5 negative risk"), "P5.5", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.6: F-string with special chars
    let special = "hello \"world\""
    let fs = f"msg: {special}"
    r = check(assert_true(string.contains(fs, "hello"), "P5.6 fstring special"), "P5.6", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.7: Recursive function
    fn factorial(n: int) -> int {
        if n <= 1 { return 1 }
        return n * factorial(n - 1)
    }
    r = check(assert_eq(factorial(5), 120, "P5.7 factorial"), "P5.7", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.8: Nested try/catch
    let nested_ok = false
    try {
        try {
            let x = 1 / 0
        } catch (e1) {
            nested_ok = true
        }
    } catch (e2) {
        nested_ok = false
    }
    r = check(assert_true(nested_ok, "P5.8 nested try/catch"), "P5.8", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.9: Generator in try/catch
    let gen_ok = true
    try {
        for t in analytics.take_n(txns, 2) {
            // Just iterate
        }
    } catch (e) {
        gen_ok = false
    }
    r = check(assert_true(gen_ok, "P5.9 gen in try"), "P5.9", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.10: Match wildcard always matches
    let wild = match "anything" { _ => "matched" }
    r = check(assert_eq(wild, "matched", "P5.10 wildcard"), "P5.10", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.11: Type error caught
    let type_caught = false
    try {
        fn typed_fn(x: int) -> int { return x }
        typed_fn("string_arg")
    } catch (e) {
        type_caught = true
    }
    r = check(assert_true(type_caught, "P5.11 type error caught"), "P5.11", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.12: Struct in dict
    let tx_dict = {"first": txns[0], "last": txns[9]}
    r = check(assert_eq(tx_dict["first"].id, "TX-1001", "P5.12 struct in dict"), "P5.12", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.13: For-in over array (not generator)
    let sum_arr = 0
    for x in [10, 20, 30] { sum_arr = sum_arr + x }
    r = check(assert_eq(sum_arr, 60, "P5.13 for-in array"), "P5.13", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.14: Boolean in f-string
    let b = true
    r = check(assert_eq(f"flag={b}", "flag=true", "P5.14 bool fstring"), "P5.14", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.15: Boolean in match
    let bm = match true { true => "yes", false => "no", _ => "?" }
    r = check(assert_eq(bm, "yes", "P5.15 bool match"), "P5.15", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.16: Multiple returns from try
    let try_val = 0
    try { try_val = 42 } catch (e) { try_val = -1 }
    r = check(assert_eq(try_val, 42, "P5.16 try success"), "P5.16", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.17: Closure survives scope
    fn make_adder(n) { return fn(x) { return x + n } }
    let add5 = make_adder(5)
    r = check(assert_eq(add5(10), 15, "P5.17 closure scope"), "P5.17", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.18: Null coalesce
    let maybe_null = null
    let safe = maybe_null ?? "default"
    r = check(assert_eq(safe, "default", "P5.18 null coalesce"), "P5.18", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.19: String length
    r = check(assert_eq(string.length("hello"), 5, "P5.19 str length"), "P5.19", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P5.20: Array slice
    let sliced = array.slice([1, 2, 3, 4, 5], 1, 3)
    r = check(assert_eq(array.length(sliced), 2, "P5.20 slice"), "P5.20", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    let p5_pass = passed - p5_start_pass
    let p5_fail = failed - p5_start_fail
    print(f"    Phase 5: {p5_pass}/{p5_pass + p5_fail}")

    // ──────── Final Summary ────────
    print("")
    print(f"E2E RESULT: {passed}/{passed + failed} passed, {failed} failed")
    if failed > 0 {
        print("ERRORS:")
        for e in errors {
            print(f"  - {e}")
        }
    }
}
