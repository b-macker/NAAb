    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.15: Accumulator count
    r = check(assert_eq(acc_r[1], 2, "P2.15 accumulator count"), "P2.15", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.16: Running average
    let avg = analytics.make_running_avg()
