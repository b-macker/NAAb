        first_two = array.push(first_two, t)
    }
    r = check(assert_eq(array.length(first_two), 2, "P2.4 take 2"), "P2.4", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.5: Enumerate
    let indices = []
    for pair in analytics.enumerate_items(["a", "b", "c"]) {
        indices = array.push(indices, pair[0])
    }
    r = check(assert_eq(indices[2], 2, "P2.5 enumerate idx"), "P2.5", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.6: Chain filter + take
    let chained = []
    for t in analytics.chain_filter_take(port.transactions, "food", 1) {
        chained = array.push(chained, t)
    }
    r = check(assert_eq(array.length(chained), 1, "P2.6 chain"), "P2.6", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.7-P2.11: Risk classification
    r = check(assert_eq(analytics.classify_risk(100.0), "LOW", "P2.7 risk LOW"), "P2.7", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]
    r = check(assert_eq(analytics.classify_risk(2000.0), "MEDIUM", "P2.8 risk MED"), "P2.8", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]
    r = check(assert_eq(analytics.classify_risk(7000.0), "HIGH", "P2.9 risk HIGH"), "P2.9", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]
    r = check(assert_eq(analytics.classify_risk(20000.0), "CRITICAL", "P2.10 risk CRIT"), "P2.10", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]
    r = check(assert_eq(analytics.classify_risk(1000.0), "LOW", "P2.11 boundary 1000"), "P2.11", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.12: Category classification
    r = check(assert_eq(analytics.classify_category("food"), "essential", "P2.12 cat food"), "P2.12", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.13: Risk score
    r = check(assert_eq(analytics.risk_score("CRITICAL"), 1.0, "P2.13 score crit"), "P2.13", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.14: Closure accumulator
    let acc = analytics.make_accumulator()
    acc(100.0)
    let acc_r = acc(200.0)
