// E2E App A: Financial Analytics Engine (STRICT Governance)
// Comprehensive conformance test — exercises every v0.6.0 feature

import "modules/data_models.naab" as models
import "modules/analytics.naab" as analytics
import "modules/reporting.naab" as reporting

use string
use array
use math
use json
use regex
use crypto
use path
use time

fn assert_eq(actual, expected, label) {
    if actual == expected { return true }
    print(f"  FAIL: {label} — expected [{expected}] got [{actual}]")
    return false
}

fn assert_true(cond, label) {
    if cond { return true }
    print(f"  FAIL: {label}")
    return false
}

fn check(result, label, passed, failed, errors) {
    if result {
        return [passed + 1, failed, errors]
    } else {
        return [passed, failed + 1, array.push(errors, label)]
    }
}

main {
    let passed = 0
    let failed = 0
    let errors = []
    let r = null

    print("=== E2E App A: STRICT Governance ===")

    // ──────── Phase 1: Data Models (20 assertions) ────────
    print("  Phase 1: Data Models")

    // P1.1: Create transaction
    let tx1 = models.make_transaction("TX-0001", 500.0, "USD", "food", 1000)
    r = check(assert_eq(tx1.id, "TX-0001", "P1.1 tx id"), "P1.1", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.2: Transaction amount
    r = check(assert_eq(tx1.amount, 500.0, "P1.2 tx amount"), "P1.2", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.3: Display transaction
    let d1 = models.display_transaction(tx1)
    r = check(assert_true(string.contains(d1, "TX-0001"), "P1.3 display contains id"), "P1.3", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.4: Create portfolio
    let port = models.make_portfolio("TestPort")
    r = check(assert_eq(port.name, "TestPort", "P1.4 portfolio name"), "P1.4", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.5: Add transaction to portfolio
    port = models.add_transaction(port, tx1)
    r = check(assert_eq(array.length(port.transactions), 1, "P1.5 portfolio txn count"), "P1.5", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.6: Portfolio balance
    r = check(assert_eq(port.balance, 500.0, "P1.6 portfolio balance"), "P1.6", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.7: Portfolio display
    let pd = models.display_portfolio(port)
    r = check(assert_true(string.contains(pd, "TestPort"), "P1.7 display has name"), "P1.7", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.8: Portfolio compute (interface method)
    let comp = models.compute_portfolio(port)
    r = check(assert_eq(comp, 500.0, "P1.8 compute total"), "P1.8", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.9: Make result struct
    let res1 = models.make_result(0.85, "HIGH", "High risk detected", "food")
    r = check(assert_eq(res1.score, 0.85, "P1.9 result score"), "P1.9", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.10: Display result
    let rd = models.display_result(res1)
    r = check(assert_true(string.contains(rd, "0.85"), "P1.10 result display"), "P1.10", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.11: Enum risk label
    r = check(assert_eq(models.get_risk_label("LOW"), "LOW", "P1.11 risk LOW"), "P1.11", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.12: Enum tx type
    r = check(assert_eq(models.get_tx_type_label("CREDIT"), "CREDIT", "P1.12 tx type"), "P1.12", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.13: Multiple transactions in portfolio
    let tx2 = models.make_transaction("TX-0002", 1500.0, "EUR", "rent", 2000)
    let tx3 = models.make_transaction("TX-0003", 250.0, "USD", "entertainment", 3000)
    port = models.add_transaction(port, tx2)
    port = models.add_transaction(port, tx3)
    r = check(assert_eq(array.length(port.transactions), 3, "P1.13 3 txns"), "P1.13", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.14: Balance accumulation
    r = check(assert_eq(port.balance, 2250.0, "P1.14 accumulated balance"), "P1.14", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.15: Struct field access chain
    let first_tx = port.transactions[0]
    r = check(assert_eq(first_tx.category, "food", "P1.15 nested field"), "P1.15", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P1.16-P1.20: Type enforcement
    let tx4 = models.make_transaction("TX-0004", 7500.0, "GBP", "salary", 4000)
    let tx5 = models.make_transaction("TX-0005", 15000.0, "USD", "bonus", 5000)
    r = check(assert_eq(tx4.currency, "GBP", "P1.16 tx4 currency"), "P1.16", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]
    r = check(assert_eq(tx5.amount, 15000.0, "P1.17 tx5 amount"), "P1.17", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // Add more txns for analytics phase
    port = models.add_transaction(port, tx4)
    port = models.add_transaction(port, tx5)
    r = check(assert_eq(array.length(port.transactions), 5, "P1.18 5 txns"), "P1.18", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    let total_expected = 500.0 + 1500.0 + 250.0 + 7500.0 + 15000.0
    r = check(assert_eq(port.balance, total_expected, "P1.19 total balance"), "P1.19", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    r = check(assert_eq(models.compute_portfolio(port), total_expected, "P1.20 compute matches"), "P1.20", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    print(f"    Phase 1: {passed}/{passed + failed}")
    let p1_pass = passed
    let p1_fail = failed

    // ──────── Phase 2: Analytics (30 assertions) ────────
    print("  Phase 2: Analytics")

    // P2.1: Generator stream count
    let stream_count = 0
    for t in analytics.transaction_stream(port.transactions) { stream_count = stream_count + 1 }
    r = check(assert_eq(stream_count, 5, "P2.1 stream count"), "P2.1", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.2: Filter by category
    let food_items = []
    for t in analytics.filter_by_category(port.transactions, "food") {
        food_items = array.push(food_items, t)
    }
    r = check(assert_eq(array.length(food_items), 1, "P2.2 food filter"), "P2.2", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.3: Filter above threshold
    let big_items = []
    for t in analytics.filter_above(port.transactions, 5000.0) {
        big_items = array.push(big_items, t)
    }
    r = check(assert_eq(array.length(big_items), 2, "P2.3 above 5000"), "P2.3", passed, failed, errors)
    passed = r[0]; failed = r[1]; errors = r[2]

    // P2.4: Take N
    let first_two = []
