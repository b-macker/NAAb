// Test: BUG-R — Expression-level taint at sinks
// Verifies that complex expressions (not just bare identifiers) are blocked at sinks

use env

fn test_concat_at_env_sink() {
    let passed = 0
    let total = 0

    // Test 1: String concat with tainted var at env.set_var sink
    total = total + 1
    let tainted = env.get("HOME")
    try {
        env.set_var("NAAB_TEST_R1", "prefix_" + tainted)
        // Should not reach here — expression contains tainted data
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    // Test 2: Tainted var nested in string concat at shell sink
    total = total + 1
    let t2 = env.get("USER")
    let msg = "hello " + t2
    try {
        <<shell[msg]
echo $msg
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    // Test 3: Direct identifier at env.set_var (should still work as before)
    total = total + 1
    let t3 = env.get("HOME")
    try {
        env.set_var("NAAB_TEST_R3", t3)
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

main {
    let r = test_concat_at_env_sink()
    print("test_expression_sink_bypass: " + string(r[0]) + "/" + string(r[1]) + " passed")
    if r[0] == r[1] {
        print("PASS")
    } else {
        print("FAIL")
    }
}
