// Test: BUG-B/C/D — Taint propagation through expressions and function returns
// Verifies string concat, interpolation, and function return laundering

use env

fn get_tainted_data() {
    return env.get("HOME")
}

fn test_string_concat_propagation() {
    let passed = 0
    let total = 0

    // Test 1: String concatenation with tainted variable should propagate taint
    total = total + 1
    let t = env.get("HOME")
    let url = "http://" + t
    let blocked = false
    try {
        <<shell[url]
echo $url
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
        print("PASS: String concat propagates taint")
    } else {
        print("FAIL: String concat did NOT propagate taint")
    }

    return [passed, total]
}

fn test_function_return_taint() {
    let passed = 0
    let total = 0

    // Test 2: Function that returns tainted data should taint the result
    total = total + 1
    let data = get_tainted_data()
    let blocked = false
    try {
        <<shell[data]
echo $data
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
        print("PASS: Function return carries taint")
    } else {
        print("FAIL: Function return did NOT carry taint")
    }

    return [passed, total]
}

fn test_clean_function_no_taint() {
    let passed = 0
    let total = 0

    // Test 3: Function that returns clean data should NOT be tainted
    total = total + 1
    fn get_clean() {
        return "safe_value"
    }
    let clean = get_clean()
    let worked = false
    try {
        <<shell[clean]
echo $clean
>>
        worked = true
    } catch (e) {
        // Should not be blocked
    }
    if worked {
        passed = passed + 1
        print("PASS: Clean function return is not tainted")
    } else {
        print("FAIL: Clean function return was falsely tainted")
    }

    return [passed, total]
}

fn test_string_conversion_taint() {
    let passed = 0
    let total = 0

    // Test 4: string(tainted) should propagate taint
    total = total + 1
    let t = env.get("HOME")
    let s = string(t)
    let blocked = false
    try {
        <<shell[s]
echo $s
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
        print("PASS: string() propagates taint")
    } else {
        print("FAIL: string() did NOT propagate taint")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_string_concat_propagation()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_function_return_taint()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_clean_function_no_taint()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_string_conversion_taint()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print(string(total_passed) + "/" + string(total_tests) + " taint propagation tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
