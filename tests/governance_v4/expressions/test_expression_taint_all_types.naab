// Category 3: EXPRESSION TAINT DEPTH - Comprehensive Testing
// Tests expressionContainsTaint() for ALL 15 AST expression types
// Verifies BUG-S through BUG-Z fixes are complete

use env

// Helper struct for StructLiteralExpr test
struct Point {
    x: int
    y: int
}

fn test_identifier_expr() {
    let passed = 0
    let total = 0

    // Test 1: IdentifierExpr - Direct identifier reference
    total = total + 1
    let t = env.get("HOME")
    try {
        <<shell[t]
echo $t
>>
        print("FAIL: IdentifierExpr NOT detected as tainted")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: IdentifierExpr taint detected")
        }
    }

    return [passed, total]
}

