fn test_member_expr() {
    let passed = 0
    let total = 0

    // Test 4: MemberExpr - Dict access with tainted value
    total = total + 1
    let d = {"k": env.get("HOME")}
    try {
        let val = d.get("k")
        # Note: d.get("k") returns the tainted value
        # But it's a NEW variable, may not be tainted unless return taint works
        # Test the dict itself being passed
        <<shell[d]
echo test
>>
        print("FAIL: MemberExpr (dict) NOT detected as tainted")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: MemberExpr taint detected")
        }
    }

    return [passed, total]
}

