// Test: Nested function return taint chain
// Verifies taint propagates through multiple return layers via lastReturnTainted

use env

fn get_home() {
    return env.get("HOME")
}

fn wrap_home() {
    return get_home()
}

fn double_wrap() {
    return wrap_home()
}

fn test_nested_return_taint() {
    let passed = 0
    let total = 0

    // Test 1: Three-level deep return chain preserves taint
    total = total + 1
    let x = double_wrap()
    try {
        <<shell[x]
echo $x
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

main {
    let r = test_nested_return_taint()
    print("test_nested_return_taint: " + string(r[0]) + "/" + string(r[1]) + " passed")
    if r[0] == r[1] {
        print("PASS")
    } else {
        print("FAIL")
    }
}
