fn test_await_expr() {
    let passed = 0
    let total = 0

    // T12: AwaitExpr — await async returning tainted
    total = total + 1
    let r = await async_tainted()
    try {
        env.set_var("E17_T12", string(r))
        print("FAIL T12: AwaitExpr taint not caught")
    } catch (e) {
        passed = passed + 1
        print("PASS T12: AwaitExpr — async return taint blocked at sink")
    }

    return [passed, total]
}

fn test_match_expr() {
    let passed = 0
    let total = 0

    // T13: MatchExpr — match with tainted arm
    total = total + 1
    let t = env.get("HOME")
    let val = 1
    let result = match val {
        1 => t
        default => "safe"
    }
    try {
        env.set_var("E17_T13", string(result))
        print("FAIL T13: MatchExpr taint not caught")
    } catch (e) {
        passed = passed + 1
        print("PASS T13: MatchExpr — tainted arm blocked at sink")
    }

    return [passed, total]
}

fn test_null_coalesce_expr() {
    let passed = 0
    let total = 0

    // T14: NullCoalesce (BinaryExpr) — tainted ?? "fallback"
    total = total + 1
    let t = env.get("HOME")
    try {
        env.set_var("E17_T14", t ?? "fallback")
        print("FAIL T14: NullCoalesce taint not caught")
    } catch (e) {
        passed = passed + 1
        print("PASS T14: NullCoalesce — tainted left blocked at sink")
    }

    return [passed, total]
}

fn test_clean_expressions_pass() {
    let passed = 0
    let total = 0

    // T15: All clean expressions pass — baseline
    total = total + 1
    let clean = "safe"
    let results_pass = true
    try { env.set_var("E17_T15A", clean + "_suffix") } catch (e) { results_pass = false }
    try { env.set_var("E17_T15B", string(42)) } catch (e) { results_pass = false }
    try { env.set_var("E17_T15C", if true { "a" } else { "b" }) } catch (e) { results_pass = false }
    if results_pass {
        passed = passed + 1
        print("PASS T15: all clean expressions pass sink checks")
    } else {
        print("FAIL T15: some clean expressions blocked")
    }

    return [passed, total]
}

main {
    let tp = 0
    let tt = 0

    let r1 = test_identifier_expr()
    tp = tp + r1[0]
    tt = tt + r1[1]

    let r2 = test_binary_expr()
    tp = tp + r2[0]
    tt = tt + r2[1]

    let r3 = test_unary_expr()
    tp = tp + r3[0]
    tt = tt + r3[1]

    let r4 = test_call_expr()
    tp = tp + r4[0]
    tt = tt + r4[1]

    let r5 = test_member_expr()
    tp = tp + r5[0]
    tt = tt + r5[1]

    let r6 = test_literal_expr_interpolation()
    tp = tp + r6[0]
    tt = tt + r6[1]

    let r7 = test_if_expr()
    tp = tp + r7[0]
    tt = tt + r7[1]

    let r8 = test_list_expr()
    tp = tp + r8[0]
    tt = tt + r8[1]

    let r9 = test_dict_expr()
    tp = tp + r9[0]
    tt = tt + r9[1]

    let r10 = test_await_expr()
    tp = tp + r10[0]
    tt = tt + r10[1]

    let r11 = test_match_expr()
    tp = tp + r11[0]
    tt = tt + r11[1]

    let r12 = test_null_coalesce_expr()
    tp = tp + r12[0]
    tt = tt + r12[1]

    let r13 = test_clean_expressions_pass()
    tp = tp + r13[0]
    tt = tt + r13[1]

    print("Edge 17 - Expression Taint All: " + string(tp) + "/" + string(tt) + " passed")
}
