{
    "version": "3.0",
    "languages": {
        "allowed": ["python", "shell"]
    },
    "capabilities": {
        "env_access": true,
        "shell": true
    },
    "taint_tracking": {
        "enabled": true,
        "level": "advisory",
        "sources": ["env.get"],
        "sinks": ["shell_exec", "env.set_var"],
        "sanitizers": ["validate_", "sanitize_"]
    }
}
