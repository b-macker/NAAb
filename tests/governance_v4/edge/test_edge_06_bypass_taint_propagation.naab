fn test_await_propagation() {
    let passed = 0
    let total = 0

    // T13: Await — async fn returning tainted
    total = total + 1
    let r = await async_returns_tainted()
    try {
        env.set_var("E06_T13", string(r))
        print("FAIL T13: await taint not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T13: await propagates async return taint")
    }

    return [passed, total]
}

fn test_clean_propagation_baseline() {
    let passed = 0
    let total = 0

    // T14: All clean operations pass — baseline
    total = total + 1
    let clean = "safe"
    let all_pass = true
    try { env.set_var("E06_T14A", clean + "_suffix") } catch (e) { all_pass = false }
    let cond_val = if true { "a" } else { "b" }
    try { env.set_var("E06_T14B", string(cond_val)) } catch (e) { all_pass = false }
    try { env.set_var("E06_T14C", string(42)) } catch (e) { all_pass = false }
    try { env.set_var("E06_T14D", string(!true)) } catch (e) { all_pass = false }
    if all_pass {
        passed = passed + 1
        print("PASS T14: all clean propagation paths pass sinks")
    } else {
        print("FAIL T14: some clean operations blocked")
    }

    return [passed, total]
}

main {
    let tp = 0
    let tt = 0

    let r1 = test_binary_propagation()
    tp = tp + r1[0]
    tt = tt + r1[1]

    let r2 = test_member_propagation()
    tp = tp + r2[0]
    tt = tt + r2[1]

    let r3 = test_call_propagation()
    tp = tp + r3[0]
    tt = tt + r3[1]

    let r4 = test_if_expression_propagation()
    tp = tp + r4[0]
    tt = tt + r4[1]

    let r5 = test_collection_propagation()
    tp = tp + r5[0]
    tt = tt + r5[1]

    let r6 = test_unary_propagation()
    tp = tp + r6[0]
    tt = tt + r6[1]

    let r7 = test_match_propagation()
    tp = tp + r7[0]
    tt = tt + r7[1]

    let r8 = test_null_coalesce_propagation()
    tp = tp + r8[0]
    tt = tt + r8[1]

    let r9 = test_await_propagation()
    tp = tp + r9[0]
    tt = tt + r9[1]

    let r10 = test_clean_propagation_baseline()
    tp = tp + r10[0]
    tt = tt + r10[1]

    print("Edge 06 - Taint Propagation: " + string(tp) + "/" + string(tt) + " passed")
}
