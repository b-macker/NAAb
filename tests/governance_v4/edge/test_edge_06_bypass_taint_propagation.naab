}

fn test_call_propagation() {
    let passed = 0
    let total = 0

    // T5: Call with tainted arg — string(tainted)
    total = total + 1
    let t = env.get("HOME")
    let call_result = format_data(t)
    try {
        env.set_var("E06_T5", string(call_result))
        print("FAIL T5: call with tainted arg not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T5: call with tainted arg propagates (format_data not sanitizer)")
    }

    return [passed, total]
}

fn test_if_expression_propagation() {
    let passed = 0
    let total = 0

    // T6: If-expression — true branch tainted
    total = total + 1
    let t = env.get("HOME")
    let result = if true { t } else { "safe" }
    try {
        env.set_var("E06_T6", string(result))
        print("FAIL T6: if-expr (true branch tainted) not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T6: if-expression true branch propagates taint")
    }

    // T7: If-expression — else branch tainted
    total = total + 1
    let t2 = env.get("HOME")
    let result2 = if false { "safe" } else { t2 }
    try {
        env.set_var("E06_T7", string(result2))
        print("FAIL T7: if-expr (else branch tainted) not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T7: if-expression else branch propagates taint")
    }

    return [passed, total]
}

fn test_collection_propagation() {
    let passed = 0
    let total = 0

    // T8: List containing tainted — [tainted, "safe"]
    total = total + 1
    let t = env.get("HOME")
    let arr = [t, "safe"]
    try {
        env.set_var("E06_T8", string(arr))
        print("FAIL T8: list with tainted element not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T8: list containing tainted propagates")
    }

    // T9: Dict containing tainted — {"k": tainted}
    total = total + 1
    let t2 = env.get("HOME")
    let d = {"key": t2}
    try {
        env.set_var("E06_T9", string(d))
        print("FAIL T9: dict with tainted value not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T9: dict containing tainted value propagates")
    }

    return [passed, total]
}

