fn test_match_propagation() {
    let passed = 0
    let total = 0

    // T11: Match — tainted arm
    total = total + 1
    let t = env.get("HOME")
    let val = 1
    let result = match val {
        1 => t
        default => "safe"
    }
    try {
        env.set_var("E06_T11", string(result))
        print("FAIL T11: match with tainted arm not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T11: match expression tainted arm propagates")
    }

    return [passed, total]
}

