// Edge Test 06: Taint PROPAGATION Through Data Flow (14 tests)
// Tests expressionContainsTaint() for all propagation paths
// Code path: interpreter.cpp:2861-2992

use env

fn format_data(x) { return string(x) }

async fn async_returns_tainted() {
    return env.get("HOME")
}

fn test_binary_propagation() {
    let passed = 0
    let total = 0

    // T1: Binary add — tainted + "safe"
    total = total + 1
    let t = env.get("HOME")
    let result = t + "_suffix"
    try {
        env.set_var("E06_T1", result)
        print("FAIL T1: binary add taint not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T1: binary add propagates taint (t + str)")
    }

    // T2: Binary concat — "prefix" + tainted
    total = total + 1
    let t2 = env.get("HOME")
    let result2 = "prefix_" + t2
    try {
        env.set_var("E06_T2", result2)
        print("FAIL T2: binary concat taint not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T2: binary concat propagates taint (str + t)")
    }

    // T3: Subscript — arr[tainted_index] is BinaryExpr
    total = total + 1
    let t3 = env.get("HOME")
    let combined = string(t3) + "_data"
    try {
        env.set_var("E06_T3", combined)
        print("FAIL T3: subscript-style propagation failed")
    } catch (e) {
        passed = passed + 1
        print("PASS T3: tainted in subscript/concat propagates")
    }

    return [passed, total]
}

fn test_member_propagation() {
    let passed = 0
    let total = 0

    // T4: Member access on tainted — t.length() or t + ".test"
    total = total + 1
    let t = env.get("HOME")
    let member_result = t + ".field"
    try {
        env.set_var("E06_T4", member_result)
        print("FAIL T4: member access taint not propagated")
    } catch (e) {
        passed = passed + 1
        print("PASS T4: member access on tainted propagates")
