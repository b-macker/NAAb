// Edge Test 02: All-Language Polyglot Binding Taint (FIX-DX-2)
// Tests sink_type construction from language in InlineCodeExpr
// Code path: interpreter.cpp:7247-7264

use env

fn validate_input(x) { return string(x) }

fn test_shell_binding_tainted() {
    let passed = 0
    let total = 0

    // T1: Shell backward compat — <<shell[tainted]>> → sink_type="shell_exec"
    total = total + 1
    let t = env.get("HOME")
    try {
        <<shell[t]
echo "test"
>>
        print("FAIL T1: shell binding with tainted var not blocked")
    } catch (e) {
        passed = passed + 1
        print("PASS T1: shell binding tainted var blocked (shell_exec sink)")
    }

    // T2: Bash alias → sink_type="shell_exec"
    total = total + 1
    let t2 = env.get("HOME")
    try {
        <<bash[t2]
echo "test"
>>
        print("FAIL T2: bash binding with tainted var not blocked")
    } catch (e) {
        passed = passed + 1
        print("PASS T2: bash alias tainted var blocked (shell_exec sink)")
    }

    // T3: Sh alias → sink_type="shell_exec"
    total = total + 1
    let t3 = env.get("HOME")
    try {
        <<sh[t3]
echo "test"
>>
        print("FAIL T3: sh binding with tainted var not blocked")
    } catch (e) {
        passed = passed + 1
        print("PASS T3: sh alias tainted var blocked (shell_exec sink)")
    }

    return [passed, total]
}

fn test_python_binding_tainted() {
    let passed = 0
    let total = 0

    // T4: Python with python_exec sink — blocked
    total = total + 1
    let t = env.get("HOME")
    try {
        <<python[t]
print("test")
>>
        print("FAIL T4: python binding with tainted var not blocked")
    } catch (e) {
