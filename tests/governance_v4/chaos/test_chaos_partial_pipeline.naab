// CHAOS TEST 2: Partial Pipeline (maps to Distributed S2: Saga Partial Commit)
//
// A sequence of polyglot blocks can fail mid-way, leaving taint state
// inconsistent — some variables tainted, some cleared, some in between.
// This tests that taint state remains consistent after partial failure.

use env

fn test_pipeline_partial_failure_taint() {
    let passed = 0
    let total = 0

    // Test 1: Pre-existing taint survives partial pipeline failure
    total = total + 1
    let a = env.get("HOME")
    let b = "clean"
    try {
        <<python
print("step1_ok")
>>
        // Step 1 succeeded — now force failure
        <<python
raise Exception("step2_fail")
>>
        b = "never_reached"
    } catch (e) {
        // a should still be tainted after partial failure
        try {
            <<shell[a]
echo $a
>>
            print("FAIL: Pre-existing taint lost after partial pipeline failure")
        } catch (e2) {
            if string(e2).contains("aint") {
                passed = passed + 1
                print("PASS: Pre-existing taint survives partial pipeline failure")
            } else {
                print("FAIL: Wrong error: " + string(e2))
            }
        }
    }

    // Test 2: Catch block doesn't corrupt taint state
    total = total + 1
    let t = env.get("HOME")
    try {
        <<python
raise Exception("fail_here")
>>
    } catch (e) {
        // After catch, t should still be tainted
    }
    try {
        <<shell[t]
echo $t
>>
        print("FAIL: Taint corrupted by catch block")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Catch block doesn't corrupt taint state")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    // Test 3: Multiple sequential failures maintain taint consistency
    total = total + 1
    let x = env.get("HOME")
    for i in 0..3 {
        try {
            <<python
raise Exception("fail")
>>
        } catch (e) {
            // swallow
        }
    }
    try {
        <<shell[x]
echo $x
>>
        print("FAIL: Taint lost after multiple failures")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Multiple sequential failures maintain taint consistency")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_nested_try_taint_consistency() {
    let passed = 0
    let total = 0

    // Test 4: Nested try/catch with tainted variables at each level
    total = total + 1
    let outer_t = env.get("HOME")
    try {
        try {
            <<python
raise Exception("inner_fail")
>>
        } catch (inner_e) {
            // inner catch — outer_t should still be tainted
        }
        // After inner try/catch, verify outer taint intact
        try {
            <<shell[outer_t]
echo $outer_t
>>
            print("FAIL: Nested try/catch corrupted outer taint")
        } catch (e2) {
            if string(e2).contains("aint") {
                passed = passed + 1
                print("PASS: Nested try/catch preserves outer taint")
            } else {
                print("FAIL: Wrong error: " + string(e2))
            }
        }
    } catch (outer_e) {
        print("FAIL: Unexpected outer exception")
    }

    return [passed, total]
}

fn test_polyglot_success_then_failure() {
    let passed = 0
    let total = 0

    // Test 5: Sequential polyglot success then failure — taint state consistent
    // NOTE: Polyglot blocks in same CompoundStmt may be grouped.
    // Test that taint state is consistent across separate try blocks.
    total = total + 1
    let step1_ok = false
    try {
        <<python
print("step1_output")
>>
        step1_ok = true
    } catch (e) {
        // step 1 failed
    }
    let step2_failed = false
    try {
        <<python
raise Exception("step2_fails")
>>
    } catch (e) {
        step2_failed = true
    }
    if step1_ok {
        if step2_failed {
            passed = passed + 1
            print("PASS: Step 1 success and step 2 failure both recorded correctly")
        } else {
            print("FAIL: Step 2 should have failed")
        }
    } else {
        print("FAIL: Step 1 should have succeeded")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 2: PARTIAL PIPELINE (S2) ===")
    print("")

    let r1 = test_pipeline_partial_failure_taint()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_nested_try_taint_consistency()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_polyglot_success_then_failure()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " partial pipeline tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
