// CHAOS TEST 1: Stale Governance (maps to Distributed S1: Policy Cache Stale)
//
// NAAb's governance engine loads govern.json once at startup and never refreshes.
// This tests that governance works after loading and documents the load-once design.

use env

fn test_governance_loaded_at_start() {
    let passed = 0
    let total = 0

    // Test 1: Taint tracking is active — env.get creates tainted variable
    total = total + 1
    let t = env.get("HOME")
    try {
        <<shell[t]
echo $t
>>
        print("FAIL: Taint tracking not active at startup")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Governance taint tracking active at startup")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    // Test 2: Clean variable passes through
    total = total + 1
    let clean = "safe_value"
    try {
        <<shell[clean]
echo $clean
>>
        passed = passed + 1
        print("PASS: Clean variable passes governance check")
    } catch (e) {
        print("FAIL: Clean variable falsely blocked: " + string(e))
    }

    return [passed, total]
}

fn test_governance_not_reloaded() {
    let passed = 0
    let total = 0

    // Test 3: Document that governance is load-once design
    // NAAb has NO mechanism to reload governance mid-execution
    // This is equivalent to infinite cache TTL with no refresh
    total = total + 1

    // Verify governance is still active (hasn't been unloaded)
    let t = env.get("HOME")
    try {
        <<shell[t]
echo $t
>>
        print("FAIL: Governance became inactive mid-execution")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Governance remains active (load-once design)")
            print("  NOTE: govern.json is loaded once at startup")
            print("  NOTE: Changes to govern.json during execution are NOT picked up")
            print("  NOTE: This is equivalent to S1 (infinite cache TTL)")
        }
    }

    return [passed, total]
}

fn test_governance_survives_multiple_operations() {
    let passed = 0
    let total = 0

    // Test 4: Governance persists across many operations
    total = total + 1
    let still_works = true
    for i in 0..10 {
        let t = env.get("HOME")
        try {
            <<shell[t]
echo test
>>
            still_works = false
        } catch (e) {
            // Expected — taint blocked
        }
    }
    if still_works {
        passed = passed + 1
        print("PASS: Governance persists across 10 operations")
    } else {
        print("FAIL: Governance failed on some operations")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 1: STALE GOVERNANCE (S1) ===")
    print("")

    let r1 = test_governance_loaded_at_start()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_governance_not_reloaded()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_governance_survives_multiple_operations()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " stale governance tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
