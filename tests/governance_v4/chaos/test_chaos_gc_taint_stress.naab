// CHAOS TEST 10: GC Taint Stress (maps to Distributed S10: Resource Exhaustion)
//
// Stress taint_set_ with many tainted variables and verify GC doesn't
// interfere with taint state. Also tests taint tracking under load.

use env

fn test_many_tainted_variables() {
    let passed = 0
    let total = 0

    // Test 1: Create many tainted variables, verify all tracked
    total = total + 1
    let t0 = env.get("HOME")
    let t1 = env.get("HOME")
    let t2 = env.get("HOME")
    let t3 = env.get("HOME")
    let t4 = env.get("HOME")
    let t5 = env.get("HOME")
    let t6 = env.get("HOME")
    let t7 = env.get("HOME")
    let t8 = env.get("HOME")
    let t9 = env.get("HOME")

    let all_blocked = true
    try { <<shell[t0]
echo $t0
>>
    } catch (e) { }
    try { <<shell[t9]
echo $t9
>>
        all_blocked = false
    } catch (e) { }

    // Check first and last are both blocked
    let first_blocked = false
    try { <<shell[t0]
echo $t0
>>
    } catch (e) {
        if string(e).contains("aint") {
            first_blocked = true
        }
    }
    let last_blocked = false
    try { <<shell[t9]
echo $t9
>>
    } catch (e) {
        if string(e).contains("aint") {
            last_blocked = true
        }
    }

    if first_blocked {
        if last_blocked {
            passed = passed + 1
            print("PASS: 10 tainted variables all correctly tracked")
        } else {
            print("FAIL: Last tainted variable lost tracking")
        }
    } else {
        print("FAIL: First tainted variable lost tracking")
    }

    return [passed, total]
}

fn test_taint_after_heavy_allocation() {
    let passed = 0
    let total = 0

    // Test 2: Taint survives heavy allocation (potential GC trigger)
    total = total + 1
    let t = env.get("HOME")

    // Create many objects to potentially trigger GC
    let big_list = []
    for i in 0..100 {
        big_list.push({"key": "value_" + string(i), "data": [1, 2, 3]})
    }

    // t should still be tainted after heavy allocation
    try {
        <<shell[t]
echo $t
>>
        print("FAIL: Taint lost after heavy allocation (GC interference?)")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Taint survives heavy allocation (100 dict+list objects)")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_taint_after_function_churn() {
    let passed = 0
    let total = 0

    // Test 3: Taint survives many function calls (environment churn)
    total = total + 1
    let t = env.get("HOME")

    fn noop(x) {
        return x
    }

    // Call many functions to churn environments
    let dummy = "x"
    for i in 0..50 {
        dummy = noop(dummy)
    }

    // t should still be tainted
    try {
        <<shell[t]
echo $t
>>
        print("FAIL: Taint lost after function churn")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Taint survives 50 function calls (env churn)")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_clear_taint_under_load() {
    let passed = 0
    let total = 0

    // Test 4: Clearing taint works correctly under load
    total = total + 1
    let vars = []
    for i in 0..10 {
        vars.push(env.get("HOME"))
    }

    // All should be tainted; now reassign to clean
    let x = env.get("HOME")
    x = "clean_now"
    try {
        <<shell[x]
echo $x
>>
        passed = passed + 1
        print("PASS: Taint clearing works under load (10 tainted vars in scope)")
    } catch (e) {
        print("FAIL: Taint not cleared under load: " + string(e))
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 10: GC TAINT STRESS (S10) ===")
    print("")

    let r1 = test_many_tainted_variables()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_taint_after_heavy_allocation()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_taint_after_function_churn()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_clear_taint_under_load()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " GC taint stress tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
