// CHAOS TEST 9: Direct Bypass (maps to Distributed S9: Auth Bypass)
//
// Tests various paths that might bypass governance checks entirely:
// - NullCoalesceExpr and PipelineExpr in expressionContainsTaint()
// - Expression-level taint at different sink types

use env

fn test_null_coalesce_taint() {
    let passed = 0
    let total = 0

    // Test 1: Null coalesce with tainted LHS
    total = total + 1
    let t = env.get("HOME")
    let val = t ?? "fallback"
    try {
        <<shell[val]
echo $val
>>
        passed = passed + 1
        print("PASS (GAP CHECK): NullCoalesce with tainted LHS — new var escapes")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS (SECURE): NullCoalesce propagates taint from LHS")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_pipeline_taint() {
    let passed = 0
    let total = 0

    // Test 2: Pipeline with tainted input
    total = total + 1
    let t = env.get("HOME")
    fn identity(x) {
        return x
    }
    let val = t |> identity
    try {
        <<shell[val]
echo $val
>>
        passed = passed + 1
        print("PASS (GAP CHECK): Pipeline with tainted input — check lastReturnTainted")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS (SECURE): Pipeline propagates taint from input")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_env_set_var_sink() {
    let passed = 0
    let total = 0

    // Test 3: env.set_var as sink — tainted value blocked
    total = total + 1
    let t = env.get("HOME")
    try {
        env.set_var("CHAOS_TEST", t)
        print("FAIL: Tainted value passed to env.set_var sink")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: env.set_var correctly blocks tainted value")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_shell_binding_sink() {
    let passed = 0
    let total = 0

    // Test 4: Shell binding with tainted variable — primary sink check
    total = total + 1
    let t = env.get("HOME")
    try {
        <<shell[t]
echo "test"
>>
        print("FAIL: Tainted variable in shell binding not blocked")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Shell binding blocks tainted variable")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_multiple_bindings_one_tainted() {
    let passed = 0
    let total = 0

    // Test 5: Multiple shell bindings — one tainted, one clean
    total = total + 1
    let clean = "safe"
    let tainted = env.get("HOME")
    try {
        <<shell[clean, tainted]
echo $clean $tainted
>>
        print("FAIL: Shell with one tainted binding not blocked")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Shell blocks when ANY binding is tainted")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_clean_after_taint_cleared() {
    let passed = 0
    let total = 0

    // Test 6: Verify clean path works after taint operations
    total = total + 1
    let x = env.get("HOME")
    x = "now_clean"
    try {
        <<shell[x]
echo $x
>>
        passed = passed + 1
        print("PASS: Clean path works after taint cleared")
    } catch (e) {
        print("FAIL: Stale taint blocking clean variable: " + string(e))
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 9: DIRECT BYPASS (S9) ===")
    print("")

    let r1 = test_null_coalesce_taint()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_pipeline_taint()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_env_set_var_sink()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_shell_binding_sink()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_multiple_bindings_one_tainted()
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_clean_after_taint_cleared()
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " direct bypass tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
