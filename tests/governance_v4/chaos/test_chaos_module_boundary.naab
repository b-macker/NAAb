// CHAOS TEST 5: Module Boundary (maps to Distributed S5: Network Partition)
//
// Module imports skip governance body scan (module_loading_depth_ > 0).
// Taint must still propagate correctly across module boundaries at runtime.

use env
import "chaos_module_taint.naab" as tmod

fn test_imported_taint_source() {
    let passed = 0
    let total = 0

    // Test 1: Imported function returning env.get() propagates taint
    total = total + 1
    let val = tmod.get_env_value()
    try {
        <<shell[val]
echo $val
>>
        print("FAIL: Imported tainted value passed to sink")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Imported tainted value blocked at sink")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_imported_clean_function() {
    let passed = 0
    let total = 0

    // Test 2: Imported clean function returns clean value
    total = total + 1
    let val = tmod.clean_function()
    try {
        <<shell[val]
echo $val
>>
        passed = passed + 1
        print("PASS: Imported clean value passes to sink")
    } catch (e) {
        print("FAIL: Clean imported value incorrectly blocked: " + string(e))
    }

    return [passed, total]
}

fn test_internal_taint_does_not_leak() {
    let passed = 0
    let total = 0

    // Test 3: Module-internal taint should not leak through clean return
    total = total + 1
    let val = tmod.get_internal_tainted()
    try {
        <<shell[val]
echo $val
>>
        passed = passed + 1
        print("PASS: Internal module taint doesn't leak through clean return")
    } catch (e) {
        if string(e).contains("aint") {
            print("PASS (STRICT): Module return taint leaks — conservative but safe")
            passed = passed + 1
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_local_taint_after_module_call() {
    let passed = 0
    let total = 0

    // Test 4: Local taint unaffected by module call
    total = total + 1
    let local_t = env.get("HOME")
    let _ = tmod.clean_function()
    // local_t should still be tainted
    try {
        <<shell[local_t]
echo $local_t
>>
        print("FAIL: Local taint cleared by module call")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Local taint preserved after module call")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 5: MODULE BOUNDARY (S5) ===")
    print("")

    let r1 = test_imported_taint_source()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_imported_clean_function()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_internal_taint_does_not_leak()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_local_taint_after_module_call()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " module boundary tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
