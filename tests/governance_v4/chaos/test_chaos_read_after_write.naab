// CHAOS TEST 7: Read-After-Write (maps to Distributed S7: Consistency)
//
// After marking a variable tainted, immediate reads in expressions
// must see the taint. Tests that expressionContainsTaint() sees
// freshly-marked taint in all expression contexts.

use env

fn test_immediate_binary_taint() {
    let passed = 0
    let total = 0

    // Test 1: Binary expression with freshly tainted variable
    total = total + 1
    let x = env.get("HOME")
    let y = x + "_suffix"
    try {
        <<shell[y]
echo $y
>>
        passed = passed + 1
        print("PASS (NOTE): Binary expression with tainted operand — new name escapes")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Binary expression detects freshly tainted operand")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_immediate_if_expr_taint() {
    let passed = 0
    let total = 0

    // Test 2: If-expression with tainted branch
    total = total + 1
    let t = env.get("HOME")
    let val = if true { t } else { "clean" }
    try {
        <<shell[val]
echo $val
>>
        passed = passed + 1
        print("PASS (NOTE): If-expr taint — depends on expressionContainsTaint for val")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: If-expression propagates taint from branch")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_immediate_list_taint() {
    let passed = 0
    let total = 0

    // Test 3: List containing tainted value at sink
    total = total + 1
    let t = env.get("HOME")
    let arr = [t, "clean"]
    try {
        <<shell[arr]
echo $arr
>>
        passed = passed + 1
        print("PASS (NOTE): List with tainted element — depends on container sink check")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: List with tainted element blocked at sink")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_immediate_dict_taint() {
    let passed = 0
    let total = 0

    // Test 4: Dict containing tainted value at sink
    total = total + 1
    let t = env.get("HOME")
    let d = {"key": t}
    try {
        <<shell[d]
echo $d
>>
        passed = passed + 1
        print("PASS (NOTE): Dict with tainted value — depends on container sink check")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Dict with tainted value blocked at sink")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_immediate_interpolation_taint() {
    let passed = 0
    let total = 0

    // Test 5: String interpolation with tainted variable
    total = total + 1
    let t = env.get("HOME")
    let s = "path=${t}"
    try {
        <<shell[s]
echo $s
>>
        passed = passed + 1
        print("PASS (NOTE): Interpolation taint — depends on LiteralExpr scan")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: String interpolation with tainted var blocked at sink")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_taint_read_after_clear() {
    let passed = 0
    let total = 0

    // Test 6: Read-after-clear — variable should be clean
    total = total + 1
    let x = env.get("HOME")
    x = "clean_value"
    try {
        <<shell[x]
echo $x
>>
        passed = passed + 1
        print("PASS: Read-after-clear correctly sees clean state")
    } catch (e) {
        print("FAIL: Taint not cleared: " + string(e))
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 7: READ-AFTER-WRITE CONSISTENCY (S7) ===")
    print("")

    let r1 = test_immediate_binary_taint()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_immediate_if_expr_taint()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_immediate_list_taint()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_immediate_dict_taint()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_immediate_interpolation_taint()
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_taint_read_after_clear()
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " read-after-write tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
