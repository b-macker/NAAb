// CHAOS TEST 4: Taint Flip (maps to Distributed S4: Feature Flag Flip / TOCTOU)
//
// Taint can be cleared mid-function by reassignment or sanitizer prefix.
// Tests correct clearing behavior and documents the sanitizer bypass gap.

use env

fn test_taint_cleared_by_reassignment() {
    let passed = 0
    let total = 0

    // Test 1: Reassignment to literal clears taint (correct behavior)
    total = total + 1
    let x = env.get("HOME")
    x = "safe_value"
    try {
        <<shell[x]
echo $x
>>
        passed = passed + 1
        print("PASS: Reassignment to literal clears taint")
    } catch (e) {
        print("FAIL: Taint not cleared by reassignment: " + string(e))
    }

    return [passed, total]
}

fn test_taint_cleared_by_int_cast() {
    let passed = 0
    let total = 0

    // Test 2: int() is a sanitizer — clears taint
    total = total + 1
    let x = env.get("HOME")
    try {
        let y = int(42)
        // y is from int() which is a sanitizer
        try {
            <<shell[y]
echo $y
>>
            passed = passed + 1
            print("PASS: int() result is clean (sanitizer)")
        } catch (e) {
            print("FAIL: int() result falsely tainted: " + string(e))
        }
    } catch (e) {
        print("FAIL: int() threw: " + string(e))
    }

    return [passed, total]
}

fn validate_noop(val) {
    return val
}

fn validate_real(val) {
    return int(42)
}

fn test_sanitizer_prefix_bypass() {
    let passed = 0
    let total = 0

    // Test 3: validate_ prefix clears taint — DOCUMENTS BYPASS GAP
    total = total + 1
    let t = env.get("HOME")
    let clean = validate_noop(t)
    try {
        <<shell[clean]
echo $clean
>>
        passed = passed + 1
        print("PASS (BYPASS DOCUMENTED): validate_ prefix clears taint regardless of logic")
        print("  NOTE: validate_noop() passes value through unchanged")
        print("  NOTE: Taint cleared solely because function name starts with 'validate_'")
        print("  NOTE: This is a known design limitation of name-based sanitizer matching")
    } catch (e) {
        if string(e).contains("aint") {
            print("PASS (SECURE): validate_ prefix does NOT auto-clear taint")
            passed = passed + 1
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_real_vs_fake_sanitizer() {
    let passed = 0
    let total = 0

    // Test 4: Both real and fake sanitizers have same taint behavior
    total = total + 1
    let t1 = env.get("HOME")
    let t2 = env.get("HOME")
    let from_fake = validate_noop(t1)
    let from_real = validate_real(t2)

    let fake_blocked = false
    let real_blocked = false
    try {
        <<shell[from_fake]
echo $from_fake
>>
    } catch (e) {
        fake_blocked = true
    }
    try {
        <<shell[from_real]
echo $from_real
>>
    } catch (e) {
        real_blocked = true
    }

    if fake_blocked == real_blocked {
        passed = passed + 1
        if fake_blocked {
            print("PASS: Both sanitizers blocked equally (strict mode)")
        } else {
            print("PASS (GAP DOCUMENTED): Both sanitizers pass equally")
            print("  NOTE: No distinction between real and fake sanitizers")
        }
    } else {
        print("INTERESTING: Real and fake sanitizers differ!")
        print("  fake_blocked=" + string(fake_blocked) + " real_blocked=" + string(real_blocked))
        // Still count as pass — we're documenting behavior
        passed = passed + 1
    }

    return [passed, total]
}

fn test_taint_flip_sequence() {
    let passed = 0
    let total = 0

    // Test 5: Taint → clean → taint → clean sequence
    total = total + 1
    let x = env.get("HOME")
    x = "clean1"
    x = env.get("USER")
    x = "clean2"

    try {
        <<shell[x]
echo $x
>>
        passed = passed + 1
        print("PASS: Final clean state after taint flip sequence")
    } catch (e) {
        print("FAIL: Taint persisted after final clean assignment: " + string(e))
    }

    return [passed, total]
}

fn test_taint_flip_still_tainted() {
    let passed = 0
    let total = 0

    // Test 6: Taint → clean → taint leaves variable tainted
    total = total + 1
    let x = env.get("HOME")
    x = "clean"
    x = env.get("USER")

    try {
        <<shell[x]
echo $x
>>
        print("FAIL: Variable should be tainted after re-tainting")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Variable correctly tainted after re-tainting")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 4: TAINT FLIP / TOCTOU (S4) ===")
    print("")

    let r1 = test_taint_cleared_by_reassignment()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_taint_cleared_by_int_cast()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_sanitizer_prefix_bypass()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_real_vs_fake_sanitizer()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_taint_flip_sequence()
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_taint_flip_still_tainted()
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " taint flip tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
