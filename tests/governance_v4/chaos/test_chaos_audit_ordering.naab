// CHAOS TEST 11: Audit Ordering (maps to Distributed S11: Log Completeness)
//
// Governance audit logging must record taint decisions in order.
// Tests that taint events are logged and that audit log captures
// both allow and deny decisions.

use env

fn test_audit_deny_logged() {
    let passed = 0
    let total = 0

    // Test 1: Denied taint sink produces governance output
    total = total + 1
    let t = env.get("HOME")
    let was_denied = false
    try {
        <<shell[t]
echo $t
>>
    } catch (e) {
        if string(e).contains("aint") {
            was_denied = true
        }
    }
    if was_denied {
        passed = passed + 1
        print("PASS: Taint deny event occurred (audit would log this)")
    } else {
        print("FAIL: Expected taint denial")
    }

    return [passed, total]
}

fn test_audit_allow_logged() {
    let passed = 0
    let total = 0

    // Test 2: Allowed clean sink produces no governance error
    total = total + 1
    let clean = "safe_value"
    try {
        <<shell[clean]
echo $clean
>>
        passed = passed + 1
        print("PASS: Clean value passes sink (audit would log allow)")
    } catch (e) {
        print("FAIL: Clean value blocked: " + string(e))
    }

    return [passed, total]
}

fn test_audit_sequence_ordering() {
    let passed = 0
    let total = 0

    // Test 3: Multiple taint decisions happen in execution order
    total = total + 1
    let events = []

    let t = env.get("HOME")
    try {
        <<shell[t]
echo $t
>>
        events.push("allow_1")
    } catch (e) {
        events.push("deny_1")
    }

    let c = "clean"
    try {
        <<shell[c]
echo $c
>>
        events.push("allow_2")
    } catch (e) {
        events.push("deny_2")
    }

    try {
        <<shell[t]
echo $t
>>
        events.push("allow_3")
    } catch (e) {
        events.push("deny_3")
    }

    if events[0] == "deny_1" {
        if events[1] == "allow_2" {
            if events[2] == "deny_3" {
                passed = passed + 1
                print("PASS: Audit events in correct order: deny, allow, deny")
            } else {
                print("FAIL: Third event wrong: " + events[2])
            }
        } else {
            print("FAIL: Second event wrong: " + events[1])
        }
    } else {
        print("FAIL: First event wrong: " + events[0])
    }

    return [passed, total]
}

fn test_audit_taint_source_tracking() {
    let passed = 0
    let total = 0

    // Test 4: Multiple taint sources tracked independently
    total = total + 1
    let home = env.get("HOME")
    let user = env.get("USER")

    let home_blocked = false
    let user_blocked = false

    try {
        <<shell[home]
echo $home
>>
    } catch (e) {
        home_blocked = true
    }

    try {
        <<shell[user]
echo $user
>>
    } catch (e) {
        user_blocked = true
    }

    if home_blocked {
        if user_blocked {
            passed = passed + 1
            print("PASS: Multiple taint sources independently tracked and audited")
        } else {
            print("FAIL: USER taint not tracked")
        }
    } else {
        print("FAIL: HOME taint not tracked")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 11: AUDIT ORDERING (S11) ===")
    print("")

    let r1 = test_audit_deny_logged()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_audit_allow_logged()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_audit_sequence_ordering()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_audit_taint_source_tracking()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " audit ordering tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
