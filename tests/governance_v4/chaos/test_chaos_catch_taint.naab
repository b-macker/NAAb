// CHAOS TEST 8: Catch Taint (maps to Distributed S8: Error Handling Bypass)
//
// catch(e) clears taint on variable 'e' (line 3194 in interpreter.cpp).
// This means if a variable named 'e' was tainted before the catch,
// its taint is cleared — a potential bypass vector.

use env

fn test_catch_clears_same_name_taint() {
    let passed = 0
    let total = 0

    // Test 1: Variable 'e' tainted before catch — catch clears it
    total = total + 1
    let e = env.get("HOME")
    try {
        <<python
raise Exception("test_error")
>>
    } catch (e) {
        // catch(e) clears taint on name 'e'
    }
    try {
        <<shell[e]
echo $e
>>
        passed = passed + 1
        print("PASS (GAP DOCUMENTED): catch(e) clears pre-existing taint on 'e'")
        print("  NOTE: Name-based taint — clearTaint('e') clears ALL 'e' taint")
        print("  NOTE: This is a known bypass: tainted var same name as catch var")
    } catch (err) {
        if string(err).contains("aint") {
            passed = passed + 1
            print("PASS (SECURE): catch(e) does NOT clear pre-existing taint")
        } else {
            print("FAIL: Wrong error: " + string(err))
        }
    }

    return [passed, total]
}

fn test_catch_different_name_no_effect() {
    let passed = 0
    let total = 0

    // Test 2: catch(err) doesn't clear taint on 't'
    total = total + 1
    let t = env.get("HOME")
    try {
        <<python
raise Exception("test_error")
>>
    } catch (err) {
        // catch(err) should NOT affect 't'
    }
    try {
        <<shell[t]
echo $t
>>
        print("FAIL: Taint on 't' cleared by catch(err)")
    } catch (e2) {
        if string(e2).contains("aint") {
            passed = passed + 1
            print("PASS: catch(err) does NOT clear taint on different variable 't'")
        } else {
            print("FAIL: Wrong error: " + string(e2))
        }
    }

    return [passed, total]
}

fn test_catch_error_value_not_tainted() {
    let passed = 0
    let total = 0

    // Test 3: The caught error value itself is not tainted
    // NOTE: Use env.set_var sink since error strings contain special chars
    // that break shell export syntax
    total = total + 1
    try {
        <<python
raise Exception("innocent_error")
>>
    } catch (err) {
        try {
            env.set_var("CHAOS_TEST_ERR", string(err))
            passed = passed + 1
            print("PASS: Caught error value is not tainted (expected)")
        } catch (e2) {
            if string(e2).contains("aint") {
                print("PASS (INTERESTING): Caught error IS tainted")
                print("  NOTE: Error value marked tainted — conservative but safe")
                passed = passed + 1
            } else {
                print("FAIL: Wrong error: " + string(e2))
            }
        }
    }

    return [passed, total]
}

fn test_catch_preserves_other_taint() {
    let passed = 0
    let total = 0

    // Test 4: Multiple tainted vars — catch only clears its name
    total = total + 1
    let a = env.get("HOME")
    let b = env.get("USER")
    try {
        <<python
raise Exception("error")
>>
    } catch (a) {
        // catch(a) clears taint on 'a' but not 'b'
    }
    let b_blocked = false
    try {
        <<shell[b]
echo $b
>>
    } catch (e) {
        b_blocked = true
    }
    if b_blocked {
        passed = passed + 1
        print("PASS: catch(a) preserves taint on 'b'")
    } else {
        print("FAIL: catch(a) somehow cleared taint on 'b'")
    }

    return [passed, total]
}

fn test_nested_catch_taint_interaction() {
    let passed = 0
    let total = 0

    // Test 5: Nested catch blocks with overlapping names
    total = total + 1
    let x = env.get("HOME")
    try {
        try {
            <<python
raise Exception("inner")
>>
        } catch (x) {
            // Inner catch clears 'x' taint
        }
        // x should now be the error string, not tainted HOME
        try {
            <<shell[x]
echo $x
>>
            passed = passed + 1
            print("PASS (GAP DOCUMENTED): Nested catch clears taint via name collision")
        } catch (e) {
            if string(e).contains("aint") {
                passed = passed + 1
                print("PASS (SECURE): Nested catch preserves taint")
            } else {
                print("FAIL: Wrong error: " + string(e))
            }
        }
    } catch (outer_e) {
        print("FAIL: Unexpected outer exception")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    print("=== CHAOS TEST 8: CATCH TAINT BYPASS (S8) ===")
    print("")

    let r1 = test_catch_clears_same_name_taint()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_catch_different_name_no_effect()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_catch_error_value_not_tainted()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_catch_preserves_other_taint()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_nested_catch_taint_interaction()
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    print("")
    print(string(total_passed) + "/" + string(total_tests) + " catch taint tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
