// Test: BUG-S — String interpolation taint detection
// Verifies that ${tainted_var} in string literals is detected as tainted

use env

fn test_interpolation_tainted() {
    let passed = 0
    let total = 0

    // Test 1: String interpolation with tainted var should be blocked at shell sink
    total = total + 1
    let t = env.get("HOME")
    let msg = "path: ${t}"
    try {
        <<shell[msg]
echo $msg
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    // Test 2: String interpolation with clean literal should be allowed
    total = total + 1
    let safe_msg = "value: ${42}"
    try {
        <<shell[safe_msg]
echo $safe_msg
>>
        passed = passed + 1
    } catch (e) {
        // Should NOT reach here — 42 is not tainted
    }

    return [passed, total]
}

main {
    let r = test_interpolation_tainted()
    print("test_interpolation_taint: " + string(r[0]) + "/" + string(r[1]) + " passed")
    if r[0] == r[1] {
        print("PASS")
    } else {
        print("FAIL")
    }
}
