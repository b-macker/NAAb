// Test: TEST-A — Override flag with soft enforcement
// Run with: ./build/naab-lang --governance-override tests/governance_v4/test_override_soft.naab
// Uses soft_govern.json — soft + override should allow taint violations (warn only)

use env

fn add_stock(inventory, product_id, quantity, tx_type) {
    let inv = inventory
    inv[product_id] = quantity
    return {"inventory": inv, "transaction": {"id": product_id, "qty": quantity, "type": tx_type}}
}

fn test_soft_taint_with_override() {
    let passed = 0
    let total = 0

    // Test 1: Soft taint + --governance-override → taint violation should WARN only
    total = total + 1
    let t = env.get("HOME")
    try {
        <<shell[t]
echo $t
>>
        // With soft + override, should reach here (warn but allow)
        passed = passed + 1
    } catch (e) {
        let err_str = string(e)
        // Soft + override should not block
        // If it does block, test fails
    }

    return [passed, total]
}

fn test_soft_contract_with_override() {
    let passed = 0
    let total = 0

    // Test 2: Soft contract + --governance-override → contract violation warned
    total = total + 1
    let inv = {}
    try {
        let result = add_stock(inv, "prod1", "wrong_type", "buy")
        // With soft + override, should execute
        passed = passed + 1
    } catch (e) {
        // Soft + override should not block
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_soft_taint_with_override()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_soft_contract_with_override()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    print("test_override_soft: " + string(total_passed) + "/" + string(total_tests) + " passed")
    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL")
    }
}
