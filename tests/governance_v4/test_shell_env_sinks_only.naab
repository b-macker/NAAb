// Test: BUG-F/G — Shell and env.set_var sink checks
// Verifies shell_exec and env.set_var block tainted data
// NOTE: http and file.write sinks are tested in sinks/test_all_sinks_comprehensive.naab

use env

fn test_shell_sink_blocked() {
    let passed = 0
    let total = 0

    // Test 1: Shell exec with tainted variable should be blocked
    total = total + 1
    let cmd = env.get("HOME")
    let blocked = false
    try {
        <<shell[cmd]
echo $cmd
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
        print("PASS: Shell sink blocks tainted data")
    } else {
        print("FAIL: Shell sink did NOT block tainted data")
    }

    return [passed, total]
}

fn test_env_set_var_sink() {
    let passed = 0
    let total = 0

    // Test 2: env.set_var with tainted value should be blocked
    total = total + 1
    let secret = env.get("HOME")
    let blocked = false
    try {
        env.set_var("LEAKED", secret)
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
        print("PASS: env.set_var blocks tainted value")
    } else {
        print("FAIL: env.set_var did NOT block tainted value")
    }

    return [passed, total]
}

fn test_clean_shell_allowed() {
    let passed = 0
    let total = 0

    // Test 3: Shell exec with clean variable should work
    total = total + 1
    let safe = "hello_world"
    let worked = false
    try {
        <<shell[safe]
echo $safe
>>
        worked = true
    } catch (e) {
        // Should not be blocked
    }
    if worked {
        passed = passed + 1
        print("PASS: Clean variable allowed in shell")
    } else {
        print("FAIL: Clean variable blocked in shell")
    }

    return [passed, total]
}

fn test_clean_env_set_allowed() {
    let passed = 0
    let total = 0

    // Test 4: env.set_var with clean value should work
    total = total + 1
    let safe = "safe_value"
    let worked = false
    try {
        env.set_var("TEST_CLEAN", safe)
        worked = true
    } catch (e) {
        // Should not be blocked
    }
    if worked {
        passed = passed + 1
        print("PASS: Clean value allowed in env.set_var")
    } else {
        print("FAIL: Clean value blocked in env.set_var")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_shell_sink_blocked()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_env_set_var_sink()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_clean_shell_allowed()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_clean_env_set_allowed()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print(string(total_passed) + "/" + string(total_tests) + " taint sink tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
