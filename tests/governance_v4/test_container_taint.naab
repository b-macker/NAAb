// Test: BUG-U/V — Container literal taint detection
// Verifies that [tainted] and {"k": tainted} are detected as tainted

use env

fn test_list_taint() {
    let passed = 0
    let total = 0

    // Test 1: List containing tainted value should taint the variable
    total = total + 1
    let t = env.get("HOME")
    let arr = [t, "safe"]
    try {
        <<shell[arr]
echo $arr
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    // Test 2: Clean list should NOT be tainted
    total = total + 1
    let clean_arr = ["safe", "clean"]
    // Just verify the variable is created without taint error
    // (Don't pass arrays to shell — they serialize poorly)
    let first = clean_arr[0]
    try {
        <<shell[first]
echo $first
>>
        passed = passed + 1
    } catch (e) {
        // Should not block — clean value
    }

    return [passed, total]
}

fn test_dict_taint() {
    let passed = 0
    let total = 0

    // Test 3: Dict containing tainted value should taint the variable
    total = total + 1
    let t = env.get("HOME")
    let d = {"key": t}
    try {
        <<shell[d]
echo $d
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_list_taint()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_dict_taint()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    print("test_container_taint: " + string(total_passed) + "/" + string(total_tests) + " passed")
    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL")
    }
}
