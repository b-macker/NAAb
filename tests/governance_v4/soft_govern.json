{
    "version": "4.0",
    "description": "Soft enforcement — taint and contracts both soft",
    "languages": {
        "allowed": ["python", "shell"],
        "blocked": ["javascript"]
    },
    "capabilities": {
        "network": false,
        "filesystem": "read"
    },
    "taint_tracking": {
        "enabled": true,
        "level": "soft",
        "sources": ["env.get", "io.read_line", "file.read", "polyglot_output"],
        "sinks": ["shell_exec", "file.write", "file.append", "http.", "env.set_var"],
        "sanitizers": ["validate_", "sanitize_", "escape_", "int(", "float("]
    },
    "contracts": {
        "level": "soft",
        "validate_inputs": true,
        "functions": {
            "add_stock": {
                "params": ["inventory:dict", "product_id:any", "quantity:int", "tx_type:any"],
                "return_type": "dict"
            }
        }
    },
    "audit": {
        "level": "basic",
        "output_file": ".governance-audit-soft.jsonl"
    }
}
