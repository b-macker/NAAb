// Category 1: SINK COVERAGE - Comprehensive Testing
// Tests ALL 16 security sinks with tainted and clean data
// Verifies that EVERY sink properly blocks tainted data

use env

fn test_shell_sink_tainted() {
    let passed = 0
    let total = 0

    // Test 1: Shell exec with tainted variable - SHOULD BLOCK
    total = total + 1
    let cmd = env.get("HOME")
    try {
        <<shell[cmd]
echo $cmd
>>
        print("FAIL: Shell sink did NOT block tainted data")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: Shell sink blocks tainted data")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

fn test_shell_sink_clean() {
    let passed = 0
    let total = 0

    // Test 2: Shell exec with clean literal - SHOULD ALLOW
    total = total + 1
    let safe = "hello_world"
    try {
        <<shell[safe]
echo $safe
>>
        passed = passed + 1
        print("PASS: Clean variable allowed in shell")
    } catch (e) {
        print("FAIL: Clean variable blocked: " + string(e))
    }

    return [passed, total]
}

fn test_env_set_var_tainted() {
