// Test: Null coalesce (??) taint propagation
// ?? is a BinaryExpr — expressionContainsTaint should detect taint in either operand

use env

fn test_null_coalesce_taint() {
    let passed = 0
    let total = 0

    // Test 1: Tainted LHS with ?? should taint result
    total = total + 1
    let t = env.get("HOME")
    let x = t ?? "fallback"
    try {
        <<shell[x]
echo $x
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    // Test 2: Clean null ?? clean fallback should be allowed
    total = total + 1
    let y = null ?? "safe"
    try {
        <<shell[y]
echo $y
>>
        passed = passed + 1
    } catch (e) {
        // Should NOT block
    }

    return [passed, total]
}

main {
    let r = test_null_coalesce_taint()
    print("test_null_coalesce_taint: " + string(r[0]) + "/" + string(r[1]) + " passed")
    if r[0] == r[1] {
        print("PASS")
    } else {
        print("FAIL")
    }
}
