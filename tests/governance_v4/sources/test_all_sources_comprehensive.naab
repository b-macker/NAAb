// Category 2: SOURCE COVERAGE - Comprehensive Testing
// Tests ALL 12 taint sources to verify they properly propagate taint
// Verifies that every source marks variables as tainted

use env

fn test_env_get_source() {
    let passed = 0
    let total = 0

    // Test 1: env.get() should taint the variable
    total = total + 1
    let tainted = env.get("HOME")
    try {
        <<shell[tainted]
echo $tainted
>>
        print("FAIL: env.get() did NOT taint variable")
    } catch (e) {
        if string(e).contains("aint") {
            passed = passed + 1
            print("PASS: env.get() properly taints variable")
        } else {
            print("FAIL: Wrong error: " + string(e))
        }
    }

    return [passed, total]
}

