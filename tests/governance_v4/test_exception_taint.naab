// Test: BUG-AB — Exception path taint handling
// Verifies that catch variable clears stale taint from same-named variable

use env

fn test_catch_clears_taint() {
    let passed = 0
    let total = 0

    // Test 1: Pre-existing tainted 'e' should not taint catch variable 'e'
    total = total + 1
    let e = env.get("HOME")
    // 'e' is now tainted
    try {
        // Force an error
        let x = int("not_a_number")
    } catch (e) {
        // 'e' is now the error dict — BUG-AB fix should clear stale taint
        // The catch variable is a fresh error object, not user-tainted data
        let err_msg = string(e)
        // If we got here without crash, the catch body executed fine
        passed = passed + 1
    }

    // Test 2: Catch with different variable name — outer tainted var unaffected
    total = total + 1
    let t = env.get("HOME")
    try {
        let x = int("bad")
    } catch (err) {
        // 'err' is a fresh error object, 't' is still tainted
        let err_msg = string(err)
    }
    // 't' should still be tainted (catch used 'err', not 't')
    try {
        <<shell[t]
echo $t
>>
    } catch (err2) {
        let err_str = string(err2)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

main {
    let r = test_catch_clears_taint()
    print("test_exception_taint: " + string(r[0]) + "/" + string(r[1]) + " passed")
    if r[0] == r[1] {
        print("PASS")
    } else {
        print("FAIL")
    }
}
