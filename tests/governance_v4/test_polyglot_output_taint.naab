// Test: TEST-M — Polyglot output as taint source
// Verifies that polyglot block output is treated as tainted

fn test_polyglot_output_tainted() {
    let passed = 0
    let total = 0

    // Test 1: Python output should be tainted (polyglot_output is in sources)
    total = total + 1
    let out = <<python
print("untrusted data")
>>
    try {
        <<shell[out]
echo $out
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    // Test 2: Shell output should also be tainted
    total = total + 1
    let shell_out = <<shell
echo "shell data"
>>
    try {
        <<shell[shell_out]
echo $shell_out
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

main {
    let r = test_polyglot_output_tainted()
    print("test_polyglot_output_taint: " + string(r[0]) + "/" + string(r[1]) + " passed")
    if r[0] == r[1] {
        print("PASS")
    } else {
        print("FAIL")
    }
}
