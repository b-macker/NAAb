// Test: TEST-X — Input contract type mismatch
// Verifies that input contracts check parameter types

fn add_stock(inventory, product_id, quantity, tx_type) {
    // Contract in govern.json: quantity:int
    let inv = inventory
    inv[product_id] = quantity
    return {"inventory": inv, "transaction": {"id": product_id, "qty": quantity, "type": tx_type}}
}

fn test_input_contract_pass() {
    let passed = 0
    let total = 0

    // Test 1: Correct types should pass contract
    total = total + 1
    let inv = {}
    try {
        let result = add_stock(inv, "prod1", 5, "buy")
        passed = passed + 1
    } catch (e) {
        // Should NOT block — types match contract
    }

    return [passed, total]
}

fn test_input_contract_fail() {
    let passed = 0
    let total = 0

    // Test 2: Wrong type for quantity (string instead of int) should be caught
    total = total + 1
    let inv = {}
    try {
        let result = add_stock(inv, "prod1", "not_an_int", "buy")
        // Contract says quantity:int — "not_an_int" is string
        // If soft enforcement, may still execute but warn
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("ontract") or err_str.contains("type") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_input_contract_pass()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_input_contract_fail()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    print("test_input_contract_types: " + string(total_passed) + "/" + string(total_tests) + " passed")
    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL")
    }
}
