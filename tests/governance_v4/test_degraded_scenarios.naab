// Test: Degraded governance scenarios
// TEST-1 through TEST-7 — partial config, conflicting levels, edge cases

use math

fn add_stock(inventory, product_id, quantity, tx_type) {
    return {"inventory": inventory, "transaction": {}}
}

fn test_basic_execution() {
    let passed = 0
    let total = 0

    // Test 1: Basic function execution always works
    total = total + 1
    let result = add_stock({}, "prod_1", 10, "restock")
    if result.get("inventory") != null {
        passed = passed + 1
        print("PASS: Basic execution works")
    } else {
        print("FAIL: Basic execution broken")
    }

    return [passed, total]
}

fn test_math_operations() {
    let passed = 0
    let total = 0

    // Test 2: Math operations unaffected by governance
    total = total + 1
    let x = math.max(0, -5)
    let y = math.min(10, 20)
    let z = math.abs(-42)
    if x == 0 and y == 10 and z == 42 {
        passed = passed + 1
        print("PASS: Math operations work")
    } else {
        print("FAIL: Math operations broken")
    }

    return [passed, total]
}

fn test_polyglot_works() {
    let passed = 0
    let total = 0

    // Test 3: Python polyglot should execute (python is in allowed list)
    total = total + 1
    let val = <<python
print(42)
>>
    if string(val) == "42" {
        passed = passed + 1
        print("PASS: Python polyglot works")
    } else {
        print("FAIL: Python returned " + string(val))
    }

    return [passed, total]
}

fn test_array_operations() {
    let passed = 0
    let total = 0

    // Test 4: Array operations work under governance
    total = total + 1
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    for x in arr {
        sum = sum + x
    }
    if sum == 15 {
        passed = passed + 1
        print("PASS: Array operations work")
    } else {
        print("FAIL: Array sum = " + string(sum))
    }

    return [passed, total]
}

fn test_dict_operations() {
    let passed = 0
    let total = 0

    // Test 5: Dict operations work under governance
    total = total + 1
    let d = {"a": 1, "b": 2, "c": 3}
    let keys = d.keys()
    if keys.length() == 3 {
        passed = passed + 1
        print("PASS: Dict operations work")
    } else {
        print("FAIL: Dict keys count = " + string(keys.length()))
    }

    return [passed, total]
}

fn test_string_operations() {
    let passed = 0
    let total = 0

    // Test 6: String operations work under governance
    total = total + 1
    let s = "Hello World"
    let upper = s.upper()
    let lower = s.lower()
    if upper == "HELLO WORLD" and lower == "hello world" {
        passed = passed + 1
        print("PASS: String operations work")
    } else {
        print("FAIL: String operations broken")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_basic_execution()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_math_operations()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_polyglot_works()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_array_operations()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_dict_operations()
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_string_operations()
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    print(string(total_passed) + "/" + string(total_tests) + " degraded scenario tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
