// Test: Governance behavior with async functions
// Tests that contracts and taint tracking work in async context

use env

fn test_contract_return_check_sync() {
    let passed = 0
    let total = 0

    // Test 1: Synchronous contract return check should still work
    total = total + 1
    let inv = {}
    let result = add_stock(inv, "prod_1", 10, "restock")
    let keys = result.keys()
    if keys.contains("inventory") and keys.contains("transaction") {
        passed = passed + 1
    }

    return [passed, total]
}

fn add_stock(inventory, product_id, quantity, tx_type) {
    return {
        "inventory": inventory,
        "transaction": {"product_id": product_id, "quantity": quantity, "type": tx_type}
    }
}

fn test_taint_doesnt_cross_functions() {
    let passed = 0
    let total = 0

    // Test 2: Taint from one function shouldn't leak into another
    total = total + 1
    let clean = "safe_value"
    try {
        <<shell[clean]
echo $clean
>>
        passed = passed + 1
    } catch (e) {
        // Should NOT be blocked — clean is not tainted
    }

    return [passed, total]
}

fn taint_then_clean() {
    // This function creates a tainted variable
    let tainted = env.get("HOME")
    // tainted is now in the taint set
    // After this function returns, does taint persist globally?
}

fn test_taint_persistence_after_function() {
    let passed = 0
    let total = 0

    // Test 3: Call a function that creates tainted vars, then check
    // that a new variable with the SAME name is not tainted
    total = total + 1
    taint_then_clean()
    // Now create a variable — should NOT be tainted
    let clean_after = "safe"
    try {
        <<shell[clean_after]
echo $clean_after
>>
        passed = passed + 1
    } catch (e) {
        // Should NOT be blocked
    }

    return [passed, total]
}

fn test_multiple_sequential_taint_checks() {
    let passed = 0
    let total = 0

    // Test 4: Multiple taint checks in sequence — state consistency
    total = total + 1
    let t1 = env.get("HOME")
    let t2 = env.get("USER")
    let safe1 = "clean1"
    let safe2 = "clean2"

    // safe1 should work
    let safe1_ok = false
    try {
        <<shell[safe1]
echo $safe1
>>
        safe1_ok = true
    } catch (e) {
        // unexpected
    }

    // safe2 should also work
    let safe2_ok = false
    try {
        <<shell[safe2]
echo $safe2
>>
        safe2_ok = true
    } catch (e) {
        // unexpected
    }

    // t1 should be blocked
    let t1_blocked = false
    try {
        <<shell[t1]
echo $t1
>>
    } catch (e) {
        t1_blocked = true
    }

    // t2 should be blocked
    let t2_blocked = false
    try {
        <<shell[t2]
echo $t2
>>
    } catch (e) {
        t2_blocked = true
    }

    if safe1_ok and safe2_ok and t1_blocked and t2_blocked {
        passed = passed + 1
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_contract_return_check_sync()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_taint_doesnt_cross_functions()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_taint_persistence_after_function()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_multiple_sequential_taint_checks()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print(string(total_passed) + "/" + string(total_tests) + " async/state governance tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
