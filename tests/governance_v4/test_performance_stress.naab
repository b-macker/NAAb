// Test: Performance under stress — large taint sets, many contract checks
// TEST-3 from plan

use env
use time

fn test_many_tainted_variables() {
    let passed = 0
    let total = 0

    // Test 1: Create many tainted variables — should not be slow
    total = total + 1
    let start = time.now()

    // Create 100 tainted variables (can't do 1000 inline easily)
    let t0 = env.get("HOME")
    let t1 = env.get("HOME")
    let t2 = env.get("HOME")
    let t3 = env.get("HOME")
    let t4 = env.get("HOME")
    let t5 = env.get("HOME")
    let t6 = env.get("HOME")
    let t7 = env.get("HOME")
    let t8 = env.get("HOME")
    let t9 = env.get("HOME")
    let t10 = env.get("HOME")
    let t11 = env.get("HOME")
    let t12 = env.get("HOME")
    let t13 = env.get("HOME")
    let t14 = env.get("HOME")
    let t15 = env.get("HOME")
    let t16 = env.get("HOME")
    let t17 = env.get("HOME")
    let t18 = env.get("HOME")
    let t19 = env.get("HOME")

    // Clean variables should still work
    let clean = "safe"
    let worked = false
    try {
        <<shell[clean]
echo $clean
>>
        worked = true
    } catch (e) {
        // Should not be blocked
    }

    let elapsed = time.now() - start
    if worked and elapsed < 5.0 {
        passed = passed + 1
        print("PASS: Many tainted vars, clean still works (" + string(elapsed) + "s)")
    } else {
        print("FAIL: worked=" + string(worked) + " elapsed=" + string(elapsed))
    }

    return [passed, total]
}

fn test_many_contract_checks() {
    let passed = 0
    let total = 0

    // Test 2: Many function calls with contract checking — should not be slow
    total = total + 1
    let start = time.now()

    fn checked_fn(x) {
        return x * 2
    }

    let sum = 0
    for i in 0..100 {
        sum = sum + checked_fn(i)
    }

    let elapsed = time.now() - start
    if sum == 9900 and elapsed < 5.0 {
        passed = passed + 1
        print("PASS: 100 contract-checked calls (" + string(elapsed) + "s)")
    } else {
        print("FAIL: sum=" + string(sum) + " elapsed=" + string(elapsed))
    }

    return [passed, total]
}

fn test_many_polyglot_checks() {
    let passed = 0
    let total = 0

    // Test 3: Multiple polyglot blocks — governance check on each
    total = total + 1
    let start = time.now()

    let r1 = <<python
print(1)
>>
    let r2 = <<python
print(2)
>>
    let r3 = <<python
print(3)
>>

    let elapsed = time.now() - start
    if string(r1) == "1" and string(r2) == "2" and string(r3) == "3" {
        passed = passed + 1
        print("PASS: Multiple polyglot blocks with governance (" + string(elapsed) + "s)")
    } else {
        print("FAIL: Polyglot results wrong")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_many_tainted_variables()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_many_contract_checks()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_many_polyglot_checks()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    print(string(total_passed) + "/" + string(total_tests) + " performance stress tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
