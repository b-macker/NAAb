// Test: Cross-module input contract validation
// Tests that function input parameters are validated against contracts

fn add_stock(inventory, product_id, quantity, tx_type) {
    let result = {
        "inventory": inventory,
        "transaction": {
            "product_id": product_id,
            "quantity": quantity,
            "type": tx_type
        }
    }
    return result
}

fn process_order(order_id, items) {
    return {"order_id": order_id, "items": items, "status": "processed"}
}

fn simple_func(x) {
    return x * 2
}

fn test_correct_args() {
    let passed = 0
    let total = 0

    // Test 1: Correct arg count and types — should pass
    total = total + 1
    try {
        let inv = {}
        let result = add_stock(inv, "prod_1", 10, "restock")
        passed = passed + 1
    } catch (e) {
        // Should NOT fail
    }

    return [passed, total]
}

fn test_wrong_arg_count() {
    let passed = 0
    let total = 0

    // Test 2: Wrong arg count — should fail (NAAb arity or contract check)
    total = total + 1
    try {
        let result = add_stock({}, "prod_1")
        // Should not reach here
    } catch (e) {
        // Either NAAb's own arity error or contract violation catches this
        passed = passed + 1
    }

    return [passed, total]
}

fn test_wrong_arg_type() {
    let passed = 0
    let total = 0

    // Test 3: Wrong arg type (string where dict expected) — should fail
    total = total + 1
    try {
        let result = add_stock("not_a_dict", "prod_1", 10, "restock")
        // Should not reach here with type checking
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("Contract") or err_str.contains("contract") or err_str.contains("type") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

fn test_any_type_accepts_all() {
    let passed = 0
    let total = 0

    // Test 4: "any" type params accept anything — should pass
    total = total + 1
    try {
        let result = add_stock({}, 42, 10, true)
        passed = passed + 1
    } catch (e) {
        // Should NOT fail — product_id is "any" type
    }

    return [passed, total]
}

fn test_no_contract_func() {
    let passed = 0
    let total = 0

    // Test 5: Function without input contract — no check, should pass
    total = total + 1
    try {
        let result = simple_func(42)
        passed = passed + 1
    } catch (e) {
        // Should NOT fail
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_correct_args()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_wrong_arg_count()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_wrong_arg_type()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_any_type_accepts_all()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_no_contract_func()
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    print(string(total_passed) + "/" + string(total_tests) + " input contract tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
