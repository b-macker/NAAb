// Test: BUG-A — Taint tracking on assignment path (x = value)
// Verifies that re-assignment from taint sources marks the variable as tainted

use env

fn test_assignment_taint_source() {
    let passed = 0
    let total = 0

    // Test 1: Assignment from taint source should mark variable as tainted
    total = total + 1
    let x = "safe"
    x = env.get("HOME")
    let blocked = false
    try {
        <<shell[x]
echo $x
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
        print("PASS: Assignment from taint source correctly blocked")
    } else {
        print("FAIL: Assignment from taint source was NOT blocked")
    }

    return [passed, total]
}

fn test_assignment_clears_taint() {
    let passed = 0
    let total = 0

    // Test 2: Re-assignment to clean value should clear taint
    total = total + 1
    let y = env.get("HOME")
    // y is now tainted
    y = "safe_value"
    // y should no longer be tainted
    let worked = false
    try {
        <<shell[y]
echo $y
>>
        worked = true
    } catch (e) {
        // Should NOT be blocked
    }
    if worked {
        passed = passed + 1
        print("PASS: Assignment to clean value cleared taint")
    } else {
        print("FAIL: Taint was NOT cleared by clean assignment")
    }

    return [passed, total]
}

fn test_assignment_propagation() {
    let passed = 0
    let total = 0

    // Test 3: Assignment from tainted variable should propagate
    total = total + 1
    let src = env.get("HOME")
    let dst = "safe"
    dst = src
    let blocked = false
    try {
        <<shell[dst]
echo $dst
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
        print("PASS: Taint propagated through assignment")
    } else {
        print("FAIL: Taint did NOT propagate through assignment")
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_assignment_taint_source()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_assignment_clears_taint()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_assignment_propagation()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    print(string(total_passed) + "/" + string(total_tests) + " assignment taint tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
