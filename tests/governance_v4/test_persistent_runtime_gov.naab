// Test: BUG-AA — Persistent runtime governance checks
// Verifies that persistent runtime .exec() respects governance rules

fn test_runtime_blocked_language() {
    let passed = 0
    let total = 0

    // Test 1: JavaScript is blocked in govern.json — runtime should respect this
    total = total + 1
    try {
        <<javascript
console.log("should be blocked")
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("blocked") or err_str.contains("not allowed") or err_str.contains("overnance") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

fn test_runtime_allowed_language() {
    let passed = 0
    let total = 0

    // Test 2: Python is allowed in govern.json — should execute
    total = total + 1
    let result = <<python
print("hello from python")
>>
    if result.contains("hello") {
        passed = passed + 1
    }

    return [passed, total]
}

fn test_runtime_polyglot_count() {
    let passed = 0
    let total = 0

    // Test 3: Multiple polyglot blocks should each be counted by governance
    total = total + 1
    let r1 = <<python
print("block 1")
>>
    let r2 = <<python
print("block 2")
>>
    if r1.contains("block 1") and r2.contains("block 2") {
        passed = passed + 1
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_runtime_blocked_language()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_runtime_allowed_language()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_runtime_polyglot_count()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    print("test_persistent_runtime_gov: " + string(total_passed) + "/" + string(total_tests) + " passed")
    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL")
    }
}
