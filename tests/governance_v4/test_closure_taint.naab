// Test: TEST-S — Closure taint capture
// Verifies that closures capturing tainted variables are detected

use env

fn test_closure_taint() {
    let passed = 0
    let total = 0

    // Test 1: Closure captures tainted variable
    total = total + 1
    let t = env.get("HOME")
    fn capture() {
        return t
    }
    let x = capture()
    try {
        <<shell[x]
echo $x
>>
    } catch (e) {
        let err_str = string(e)
        if err_str.contains("aint") {
            passed = passed + 1
        }
    }

    return [passed, total]
}

main {
    let r = test_closure_taint()
    print("test_closure_taint: " + string(r[0]) + "/" + string(r[1]) + " passed")
    if r[0] == r[1] {
        print("PASS")
    } else {
        print("FAIL")
    }
}
