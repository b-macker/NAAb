// Test: Recursive and re-entrant contract checks
// TEST-4, TEST-5 from plan

fn add_stock(inventory, product_id, quantity, tx_type) {
    return {
        "inventory": inventory,
        "transaction": {"product_id": product_id, "quantity": quantity, "type": tx_type}
    }
}

fn test_recursive_contracts() {
    let passed = 0
    let total = 0

    // Test 1: Recursive function — contract should fire on every call
    total = total + 1
    fn fibonacci(n) {
        if n <= 1 {
            return n
        }
        return fibonacci(n - 1) + fibonacci(n - 2)
    }
    let result = fibonacci(10)
    if result == 55 {
        passed = passed + 1
        print("PASS: Recursive function with governance works")
    } else {
        print("FAIL: Recursive fibonacci returned " + string(result))
    }

    return [passed, total]
}

fn test_mutual_recursion() {
    let passed = 0
    let total = 0

    // Test 2: Mutually recursive functions
    total = total + 1
    fn is_even(n) {
        if n == 0 { return true }
        return is_odd(n - 1)
    }
    fn is_odd(n) {
        if n == 0 { return false }
        return is_even(n - 1)
    }
    let result = is_even(10)
    if result == true {
        passed = passed + 1
        print("PASS: Mutually recursive functions work")
    } else {
        print("FAIL: Mutual recursion returned " + string(result))
    }

    return [passed, total]
}

fn test_reentrant_contracts() {
    let passed = 0
    let total = 0

    // Test 3: Function A (with contract) calls function B (with contract)
    total = total + 1
    let inv = {}
    let result = add_stock(inv, "prod_1", 10, "restock")
    let keys = result.keys()
    if keys.contains("inventory") and keys.contains("transaction") {
        passed = passed + 1
        print("PASS: Re-entrant contract checks work")
    } else {
        print("FAIL: Contract result missing expected keys")
    }

    return [passed, total]
}

fn test_deep_call_chain() {
    let passed = 0
    let total = 0

    // Test 4: Deep call chain — governance shouldn't stack overflow
    total = total + 1
    fn chain(n) {
        if n <= 0 { return 0 }
        return chain(n - 1) + 1
    }
    let result = chain(100)
    if result == 100 {
        passed = passed + 1
        print("PASS: Deep call chain (100 levels) works")
    } else {
        print("FAIL: Deep chain returned " + string(result))
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_recursive_contracts()
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_mutual_recursion()
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_reentrant_contracts()
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_deep_call_chain()
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print(string(total_passed) + "/" + string(total_tests) + " recursive contract tests passed")

    if total_passed == total_tests {
        print("PASS")
    } else {
        print("FAIL: " + string(total_tests - total_passed) + " tests failed")
    }
}
