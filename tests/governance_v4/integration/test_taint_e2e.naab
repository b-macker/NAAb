// End-to-end taint tracking integration test
// Exercises the FULL taint pipeline: sources, propagation, sinks, sanitizers
// Each test case verifies a specific taint path with real governance enforcement

use env
use array
use json

fn validate_input(x) {
    return x
}

fn sanitize_data(x) {
    return x
}

fn wrap_value(x) {
    return x
}

fn get_tainted_value() {
    let val = env.get("HOME")
    return val
}

// Test 1: Source marking — env.get() marks variable as tainted
fn test_source_marking() {
    let passed = 0
    let total = 0

    // env.get() is a taint source — binding to shell should be blocked
    total = total + 1
    let data = env.get("HOME")
    let blocked = false
    try {
        let r = <<shell[data]
echo $data
>>
        // Should not reach here — governance must block
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 2: Propagation via string concatenation
fn test_concat_propagation() {
    let passed = 0
    let total = 0

    total = total + 1
    let data = env.get("HOME")
    let msg = "prefix:" + data
    let blocked = false
    try {
        let r = <<shell[msg]
echo $msg
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 3: Propagation via function return
fn test_return_propagation() {
    let passed = 0
    let total = 0

    total = total + 1
    let result = get_tainted_value()
    let blocked = false
    try {
        let r = <<shell[result]
echo $result
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 4: Propagation via function wrapper (return taint chain)
fn test_wrapper_return_taint() {
    let passed = 0
    let total = 0

    total = total + 1
    let data = env.get("HOME")
    let wrapped = wrap_value(data)
    let blocked = false
    try {
        let r = <<shell[wrapped]
echo $wrapped
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 5: Propagation via dict subscript assignment
fn test_dict_subscript_taint() {
    let passed = 0
    let total = 0

    total = total + 1
    let data = env.get("HOME")
    let d = {"key": "clean"}
    d["key"] = data
    let blocked = false
    try {
        let r = <<shell[d]
echo $d
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 6: Propagation via array push
fn test_array_push_taint() {
    let passed = 0
    let total = 0

    total = total + 1
    let data = env.get("HOME")
    let arr = []
    arr.push(data)
    let blocked = false
    try {
        let r = <<shell[arr]
echo $arr
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 7: Sanitizer clears taint — sanitize_ prefix allows shell
fn test_sanitizer_clears_taint() {
    let passed = 0
    let total = 0

    // Use sanitize_ prefix function (not int() which throws on non-numeric strings)
    total = total + 1
    let data = env.get("HOME")
    let safe = sanitize_data(data)
    let allowed = false
    try {
        let r = <<shell[safe]
echo $safe
>>
        allowed = true
    } catch (e) {
        allowed = false
    }
    if allowed {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 8: Sanitizer via validate_ prefix
fn test_prefix_sanitizer() {
    let passed = 0
    let total = 0

    total = total + 1
    let data = env.get("HOME")
    let safe = validate_input(data)
    let allowed = false
    try {
        let r = <<shell[safe]
echo $safe
>>
        allowed = true
    } catch (e) {
        // Should not be blocked — validate_ is a sanitizer
        allowed = false
    }
    if allowed {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 9: For-loop taint propagation (BUG-2 fix)
fn test_for_loop_taint() {
    let passed = 0
    let total = 0

    // for item in [tainted_data] should mark item as tainted
    total = total + 1
    let data = env.get("HOME")
    let items = [data]
    let blocked = false
    for item in items {
        try {
            let r = <<shell[item]
echo $item
>>
        } catch (e) {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 10: Polyglot output as taint source
fn test_polyglot_output_taint() {
    let passed = 0
    let total = 0

    total = total + 1
    let py_result = <<python
"hello from python"
>>
    let blocked = false
    try {
        let r = <<shell[py_result]
echo $py_result
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 11: Python exec taint sink (DX-2 / BUG-4)
fn test_python_exec_taint_sink() {
    let passed = 0
    let total = 0

    // Tainted data bound to python block should be blocked (python_exec sink)
    total = total + 1
    let data = env.get("HOME")
    let blocked = false
    try {
        let r = <<python[data]
data
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 12: Clean data should NOT be blocked
// (Also validates FIX-A: after get_tainted_value(), the flag is consumed,
//  so this clean binding must NOT be falsely tainted)
fn test_clean_data_allowed() {
    let passed = 0
    let total = 0

    total = total + 1
    let clean = "hello world"
    let allowed = false
    try {
        let r = <<shell[clean]
echo $clean
>>
        allowed = true
    } catch (e) {
        allowed = false
    }
    if allowed {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 13: FIX-A — literal after tainted-return must NOT be tainted (consume-once)
fn test_no_stale_taint_on_literal() {
    let passed = 0
    let total = 0

    // get_tainted_value() sets lastReturnWasTainted=true
    // FIX-A: checkRhsTainted consumes the flag, so next let should be clean
    total = total + 1
    let tainted = get_tainted_value()
    let clean_num = 42
    let allowed = false
    try {
        let r = <<shell[clean_num]
echo $clean_num
>>
        allowed = true
    } catch (e) {
        allowed = false
    }
    if allowed {
        passed = passed + 1
    }

    return [passed, total]
}

// Test 14: FIX-A — clean function return after tainted-return must NOT be tainted
fn test_no_stale_taint_on_clean_return() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = get_tainted_value()
    let clean_result = wrap_value("safe string")
    let allowed = false
    try {
        let r = <<shell[clean_result]
echo $clean_result
>>
        allowed = true
    } catch (e) {
        allowed = false
    }
    if allowed {
        passed = passed + 1
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_source_marking()
    print("  test_source_marking: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_concat_propagation()
    print("  test_concat_propagation: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_return_propagation()
    print("  test_return_propagation: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_wrapper_return_taint()
    print("  test_wrapper_return_taint: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_dict_subscript_taint()
    print("  test_dict_subscript_taint: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_array_push_taint()
    print("  test_array_push_taint: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    let r7 = test_sanitizer_clears_taint()
    print("  test_sanitizer_clears_taint: " + string(r7[0]) + "/" + string(r7[1]))
    total_passed = total_passed + r7[0]
    total_tests = total_tests + r7[1]

    let r8 = test_prefix_sanitizer()
    print("  test_prefix_sanitizer: " + string(r8[0]) + "/" + string(r8[1]))
    total_passed = total_passed + r8[0]
    total_tests = total_tests + r8[1]

    let r9 = test_for_loop_taint()
    print("  test_for_loop_taint: " + string(r9[0]) + "/" + string(r9[1]))
    total_passed = total_passed + r9[0]
    total_tests = total_tests + r9[1]

    let r10 = test_polyglot_output_taint()
    print("  test_polyglot_output_taint: " + string(r10[0]) + "/" + string(r10[1]))
    total_passed = total_passed + r10[0]
    total_tests = total_tests + r10[1]

    let r11 = test_python_exec_taint_sink()
    print("  test_python_exec_taint_sink: " + string(r11[0]) + "/" + string(r11[1]))
    total_passed = total_passed + r11[0]
    total_tests = total_tests + r11[1]

    let r12 = test_clean_data_allowed()
    print("  test_clean_data_allowed: " + string(r12[0]) + "/" + string(r12[1]))
    total_passed = total_passed + r12[0]
    total_tests = total_tests + r12[1]

    let r13 = test_no_stale_taint_on_literal()
    print("  test_no_stale_taint_on_literal: " + string(r13[0]) + "/" + string(r13[1]))
    total_passed = total_passed + r13[0]
    total_tests = total_tests + r13[1]

    let r14 = test_no_stale_taint_on_clean_return()
    print("  test_no_stale_taint_on_clean_return: " + string(r14[0]) + "/" + string(r14[1]))
    total_passed = total_passed + r14[0]
    total_tests = total_tests + r14[1]

    print("")
    print("Taint E2E: " + string(total_passed) + "/" + string(total_tests))

    if total_passed != total_tests {
        print("FAIL: Some taint tests did not pass")
    }
}
