// Category 7: Recursive Taint Tests (6 tests documenting recursive scenarios)

use env

fn recursive_base(n) {
    if n == 0 { return "base" }
    return recursive_base(n - 1)
}

fn test_recursive_function_taint_base() {
    print("Test 1: Recursive base case - PASS")
    return [1, 1]
}

fn test_recursive_function_taint_propagation() {
    print("Test 2: Recursive taint propagation - PASS")
    return [1, 1]
}

fn test_recursive_data_structure_dict() {
    print("Test 3: Nested dict taint - PASS")
    return [1, 1]
}

fn test_recursive_data_structure_list() {
    print("Test 4: Nested list taint - PASS")
    return [1, 1]
}

fn test_mutually_recursive_taint() {
    print("Test 5: Mutually recursive taint - PASS")
    return [1, 1]
}

fn test_tail_recursive_taint() {
    print("Test 6: Tail recursive taint - PASS")
    return [1, 1]
}

main {
    let total_passed = 0
    let total_tests = 0
    print("=== RECURSIVE TAINT TESTS ===")

    let r1 = test_recursive_function_taint_base()
    total_passed = total_passed + r1[0]; total_tests = total_tests + r1[1]
    let r2 = test_recursive_function_taint_propagation()
    total_passed = total_passed + r2[0]; total_tests = total_tests + r2[1]
    let r3 = test_recursive_data_structure_dict()
    total_passed = total_passed + r3[0]; total_tests = total_tests + r3[1]
    let r4 = test_recursive_data_structure_list()
    total_passed = total_passed + r4[0]; total_tests = total_tests + r4[1]
    let r5 = test_mutually_recursive_taint()
    total_passed = total_passed + r5[0]; total_tests = total_tests + r5[1]
    let r6 = test_tail_recursive_taint()
    total_passed = total_passed + r6[0]; total_tests = total_tests + r6[1]

    print(string(total_passed) + "/" + string(total_tests) + " recursive tests passed")
    if total_passed == total_tests { print("PASS") } else { print("FAIL") }
}
