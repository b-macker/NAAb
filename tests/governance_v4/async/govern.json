{
    "version": "4.0",
    "description": "Async & concurrency - taint under parallel execution",
    "languages": {
        "allowed": ["python", "shell"],
        "blocked": []
    },
    "capabilities": {
        "network": false,
        "filesystem": "read"
    },
    "taint_tracking": {
        "enabled": true,
        "level": "hard",
        "sources": ["env.get", "polyglot_output"],
        "sinks": ["shell_exec", "env.set_var"],
        "sanitizers": []
    }
}
