// Meta-Test Layer 3: Sensitivity Testing
// 32 tests proving outputs depend on inputs.
// Each test verifies that different inputs produce different outputs.
// If any test fails, the function is constant (vacuous test).

use array
use string
use math
use json

// Helper functions for closure sensitivity
fn sens_make_adder(n) {
    return fn(x) { return x + n }
}

fn sens_make_counter() {
    let c = 0
    return fn() { c = c + 1; return c }
}

fn sens_conditional(x) {
    if x > 0 { return "pos" }
    return "neg"
}

// Struct/enum for flow sensitivity
struct SensPoint {
    x: int,
    y: int
}

// ── S3.1: Array Sensitivity (6 tests) ──
fn test_array_sensitivity() {
    let passed = 0
    let total = 0

    // 1. different array sizes give different lengths
    total = total + 1
    if array.length([1]) != array.length([1, 2]) { passed = passed + 1 }

    // 2. non-empty vs empty gives different lengths
    total = total + 1
    if array.length([1, 2, 3]) != array.length([]) { passed = passed + 1 }

    // 3. different arrays give different first elements
    total = total + 1
    if array.first([10, 20]) != array.first([30, 40]) { passed = passed + 1 }

    // 4. sorted array: first != last (proves sort isn't constant)
    total = total + 1
    let sorted = array.sort([3, 1, 2])
    if sorted[0] != sorted[2] { passed = passed + 1 }

    // 5. contains: present vs absent gives different results
    total = total + 1
    if array.contains([1, 2, 3], 1) != array.contains([1, 2, 3], 99) { passed = passed + 1 }

    // 6. join with different delimiters gives different results
    total = total + 1
    if array.join(["a", "b"], ",") != array.join(["a", "b"], "-") { passed = passed + 1 }

    return [passed, total]
}

// ── S3.2: String Sensitivity (6 tests) ──
fn test_string_sensitivity() {
    let passed = 0
    let total = 0

    // 1. different inputs give different upper results
    total = total + 1
    if string.upper("a") != string.upper("b") { passed = passed + 1 }

    // 2. different string lengths
    total = total + 1
    if string.length("hi") != string.length("hello") { passed = passed + 1 }

    // 3. different substring ranges give different results
    total = total + 1
    if string.substring("hello", 0, 2) != string.substring("hello", 0, 4) { passed = passed + 1 }

    // 4. different replacements give different results
    total = total + 1
    if string.replace("aaa", "a", "x") != string.replace("aaa", "a", "y") { passed = passed + 1 }

    // 5. different search targets give different indices
    total = total + 1
    if string.index_of("hello", "l") != string.index_of("hello", "o") { passed = passed + 1 }

    // 6. different pad widths give different results
    total = total + 1
    if string.pad_left("x", 3) != string.pad_left("x", 5) { passed = passed + 1 }

    return [passed, total]
}

// ── S3.3: Math Sensitivity (6 tests) ──
fn test_math_sensitivity() {
    let passed = 0
    let total = 0

    // 1. abs of different negatives gives different results
    total = total + 1
    if math.abs(-1) != math.abs(-2) { passed = passed + 1 }

    // 2. different exponents give different results
    total = total + 1
    if math.pow(2, 3) != math.pow(2, 4) { passed = passed + 1 }

    // 3. floor vs ceil of same value differ
    total = total + 1
    if math.floor(3.2) != math.ceil(3.2) { passed = passed + 1 }

    // 4. sqrt of different values differ
    total = total + 1
    if math.sqrt(4) != math.sqrt(9) { passed = passed + 1 }

    // 5. min vs max of same pair differ
    total = total + 1
    if math.min(1, 5) != math.max(1, 5) { passed = passed + 1 }

    // 6. round of different values differ
    total = total + 1
    if math.round(3.2) != math.round(3.8) { passed = passed + 1 }

    return [passed, total]
}

// ── S3.4: Operator Sensitivity (6 tests) ──
fn test_operator_sensitivity() {
    let passed = 0
    let total = 0

    // 1. addition with different operands
    total = total + 1
    if (3 + 4) != (3 + 5) { passed = passed + 1 }

    // 2. division with different divisors
    total = total + 1
    if (10 / 3) != (10 / 4) { passed = passed + 1 }

    // 3. modulo with different divisors
    total = total + 1
    if (5 % 3) != (5 % 4) { passed = passed + 1 }

    // 4. equality distinguishes values
    total = total + 1
    if (3 == 3) != (3 == 4) { passed = passed + 1 }

    // 5. negation distinguishes true/false
    total = total + 1
    if (!true) != (!false) { passed = passed + 1 }

    // 6. null coalesce: null vs non-null left operand
    total = total + 1
    if (null ?? "a") != ("x" ?? "a") { passed = passed + 1 }

    return [passed, total]
}

// ── S3.5: Closure Sensitivity (4 tests) ──
fn test_closure_sensitivity() {
    let passed = 0
    let total = 0

    // 1. different adder parameters give different results
    total = total + 1
    if sens_make_adder(1)(10) != sens_make_adder(2)(10) { passed = passed + 1 }

    // 2. counter called different times gives different results
    total = total + 1
    let c1 = sens_make_counter()
    c1()
    let after1 = c1()
    let c2 = sens_make_counter()
    c2()
    c2()
    c2()
    let after3 = c2()
    if after1 != after3 { passed = passed + 1 }

    // 3. closures over different values return different results
    total = total + 1
    let x1 = 1
    let x2 = 2
    let f1 = fn() { return x1 }
    let f2 = fn() { return x2 }
    if f1() != f2() { passed = passed + 1 }

    // 4. filter with different predicates gives different results
    total = total + 1
    let arr = [1, 2, 3, 4, 5]
    let r1 = array.filter_fn(arr, fn(x) { return x > 2 })
    let r2 = array.filter_fn(arr, fn(x) { return x > 3 })
    if array.length(r1) != array.length(r2) { passed = passed + 1 }

    return [passed, total]
}

// ── S3.6: Control Flow Sensitivity (4 tests) ──
fn test_flow_sensitivity() {
    let passed = 0
    let total = 0

    // 1. match different values fires different arms
    total = total + 1
    let m1 = match 1 {
        1 => "one"
        _ => "other"
    }
    let m2 = match 2 {
        1 => "one"
        _ => "other"
    }
    if m1 != m2 { passed = passed + 1 }

    // 2. loop break at different points gives different counts
    total = total + 1
    let count1 = 0
    for i in 0..10 {
        if i == 2 { break }
        count1 = count1 + 1
    }
    let count2 = 0
    for i in 0..10 {
        if i == 5 { break }
        count2 = count2 + 1
    }
    if count1 != count2 { passed = passed + 1 }

    // 3. conditional return: positive vs negative input
    total = total + 1
    if sens_conditional(5) != sens_conditional(-1) { passed = passed + 1 }

    // 4. struct with different field values
    total = total + 1
    let p1 = new SensPoint { x: 1, y: 2 }
    let p2 = new SensPoint { x: 3, y: 4 }
    if p1.x != p2.x { passed = passed + 1 }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_array_sensitivity()
    print("  S3.1 array_sensitivity: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_string_sensitivity()
    print("  S3.2 string_sensitivity: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_math_sensitivity()
    print("  S3.3 math_sensitivity: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_operator_sensitivity()
    print("  S3.4 operator_sensitivity: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_closure_sensitivity()
    print("  S3.5 closure_sensitivity: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_flow_sensitivity()
    print("  S3.6 flow_sensitivity: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    print("")
    print("Sensitivity: " + string(total_passed) + "/" + string(total_tests))
}
