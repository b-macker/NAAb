// Test 14: Math, JSON, Regex Stdlib — exhaustive coverage
// Tests math_impl.cpp, json_impl.cpp, regex_impl.cpp

use math
use json
use regex
use array
use string

// T14.1: Math constants
fn test_math_constants() {
    let passed = 0
    let total = 0

    total = total + 1
    if math.PI > 3.14 && math.PI < 3.15 { passed = passed + 1 }

    total = total + 1
    if math.E > 2.71 && math.E < 2.72 { passed = passed + 1 }

    // pi alias
    total = total + 1
    if math.pi > 3.14 && math.pi < 3.15 { passed = passed + 1 }

    // e alias
    total = total + 1
    if math.e > 2.71 && math.e < 2.72 { passed = passed + 1 }

    return [passed, total]
}

// T14.2: Math basic functions
fn test_math_basic() {
    let passed = 0
    let total = 0

    total = total + 1
    if math.abs(-5) == 5 { passed = passed + 1 }

    total = total + 1
    if math.abs(5) == 5 { passed = passed + 1 }

    total = total + 1
    let a = math.abs(-3.14)
    if a > 3.13 && a < 3.15 { passed = passed + 1 }

    total = total + 1
    if math.sqrt(9) == 3 { passed = passed + 1 }

    total = total + 1
    let s = math.sqrt(2)
    if s > 1.41 && s < 1.42 { passed = passed + 1 }

    total = total + 1
    if math.pow(2, 10) == 1024 { passed = passed + 1 }

    total = total + 1
    if math.pow(0, 0) == 1 { passed = passed + 1 }

    total = total + 1
    if math.floor(3.7) == 3 { passed = passed + 1 }

    total = total + 1
    if math.ceil(3.2) == 4 { passed = passed + 1 }

    total = total + 1
    if math.round(3.5) == 4 { passed = passed + 1 }

    return [passed, total]
}

// T14.3: Math min/max and trig
fn test_math_trig() {
    let passed = 0
    let total = 0

    total = total + 1
    if math.min(3, 7) == 3 { passed = passed + 1 }

    total = total + 1
    if math.max(3, 7) == 7 { passed = passed + 1 }

    total = total + 1
    if math.sin(0) == 0 { passed = passed + 1 }

    total = total + 1
    if math.cos(0) == 1 { passed = passed + 1 }

    total = total + 1
    if math.tan(0) == 0 { passed = passed + 1 }

    // sqrt(-1) throws
    total = total + 1
    let threw = false
    try {
        math.sqrt(-1)
    } catch (e) {
        threw = true
    }
    if threw { passed = passed + 1 }

    return [passed, total]
}

// T14.4: JSON roundtrip
fn test_json_roundtrip() {
    let passed = 0
    let total = 0

    // parse object
    total = total + 1
    let obj = json.parse("{\"a\":1}")
    if obj["a"] == 1 { passed = passed + 1 }

    // stringify contains expected content
    total = total + 1
    let s = json.stringify({"a": 1})
    if string.contains(s, "a") && string.contains(s, "1") { passed = passed + 1 }

    // roundtrip: parse then stringify then parse
    total = total + 1
    let original = {"name": "test", "value": 42}
    let json_str = json.stringify(original)
    let reparsed = json.parse(json_str)
    if reparsed["name"] == "test" && reparsed["value"] == 42 { passed = passed + 1 }

    // parse array
    total = total + 1
    let arr = json.parse("[1,2,3]")
    if array.length(arr) == 3 && arr[0] == 1 { passed = passed + 1 }

    // parse null
    total = total + 1
    let n = json.parse("null")
    if n == null { passed = passed + 1 }

    // parse string
    total = total + 1
    let str = json.parse("\"hello\"")
    if str == "hello" { passed = passed + 1 }

    // is_valid true
    total = total + 1
    if json.is_valid("{\"a\":1}") { passed = passed + 1 }

    // is_valid false
    total = total + 1
    if !json.is_valid("not json") { passed = passed + 1 }

    // parse invalid throws
    total = total + 1
    let threw = false
    try {
        json.parse("invalid")
    } catch (e) {
        threw = true
    }
    if threw { passed = passed + 1 }

    return [passed, total]
}

// T14.5: Regex operations
fn test_regex_ops() {
    let passed = 0
    let total = 0

    // matches full string
    total = total + 1
    if regex.matches("hello123", "^[a-z]+[0-9]+$") { passed = passed + 1 }

    // matches fails
    total = total + 1
    if !regex.matches("hello", "^[0-9]+$") { passed = passed + 1 }

    // search finds substring
    total = total + 1
    let found = regex.search("abc123def", "[0-9]+")
    if found != null { passed = passed + 1 }

    // replace
    total = total + 1
    let replaced = regex.replace("hello world", "o", "0")
    if string.contains(replaced, "0") { passed = passed + 1 }

    // split
    total = total + 1
    let parts = regex.split("a,b,,c", ",")
    if array.length(parts) >= 3 { passed = passed + 1 }

    // is_valid
    total = total + 1
    if regex.is_valid("[a-z]+") { passed = passed + 1 }

    return [passed, total]
}

// T14.6: JSON advanced — parse_object, parse_array, pretty
fn test_json_advanced() {
    let passed = 0
    let total = 0

    // parse_object
    total = total + 1
    let obj = json.parse_object("{\"name\": \"Alice\", \"age\": 30}")
    if obj["name"] == "Alice" { passed = passed + 1 }

    // parse_array
    total = total + 1
    let arr = json.parse_array("[1, 2, 3]")
    if array.length(arr) == 3 && arr[0] == 1 { passed = passed + 1 }

    // pretty
    total = total + 1
    let pretty_str = json.pretty({"a": 1})
    if string.contains(pretty_str, "a") { passed = passed + 1 }

    // parse_object with nested
    total = total + 1
    let nested = json.parse_object("{\"x\": {\"y\": 42}}")
    if nested["x"]["y"] == 42 { passed = passed + 1 }

    return [passed, total]
}

// T14.7: Regex advanced — find_all, replace_first, groups, find_groups, escape
fn test_regex_advanced() {
    let passed = 0
    let total = 0

    // find_all
    total = total + 1
    let all = regex.find_all("abc123def456", "[0-9]+")
    if array.length(all) == 2 { passed = passed + 1 }

    // replace_first (only first match)
    total = total + 1
    let r1 = regex.replace_first("aaa", "a", "b")
    if r1 == "baa" { passed = passed + 1 }

    // groups
    total = total + 1
    let g = regex.groups("2026-03-21", "(\\d{4})-(\\d{2})-(\\d{2})")
    if array.length(g) >= 3 { passed = passed + 1 }

    // escape special chars
    total = total + 1
    let esc = regex.escape("hello.world")
    if string.contains(esc, "\\") { passed = passed + 1 }

    // is_valid with invalid regex
    total = total + 1
    if !regex.is_valid("[invalid") { passed = passed + 1 }

    // find_groups returns array of matches (each with groups)
    total = total + 1
    let fg = regex.find_groups("test123end", "(\\w+)(\\d+)(\\w+)")
    if array.length(fg) >= 1 { passed = passed + 1 }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_math_constants()
    print("  T14.1 math_constants: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_math_basic()
    print("  T14.2 math_basic: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_math_trig()
    print("  T14.3 math_trig: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_json_roundtrip()
    print("  T14.4 json_roundtrip: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_regex_ops()
    print("  T14.5 regex_ops: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_json_advanced()
    print("  T14.6 json_advanced: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    let r7 = test_regex_advanced()
    print("  T14.7 regex_advanced: " + string(r7[0]) + "/" + string(r7[1]))
    total_passed = total_passed + r7[0]
    total_tests = total_tests + r7[1]

    print("")
    print("Stdlib Math/JSON/Regex: " + string(total_passed) + "/" + string(total_tests))
}
