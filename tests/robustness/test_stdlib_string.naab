// Test 13: String Stdlib — exhaustive coverage of all 20 string functions
// Tests every function in src/stdlib/string_impl.cpp

use string
use array

// T13.1: Basic string operations
fn test_basic_string() {
    let passed = 0
    let total = 0

    total = total + 1
    if string.length("hello") == 5 { passed = passed + 1 }

    total = total + 1
    if string.length("") == 0 { passed = passed + 1 }

    total = total + 1
    if string.upper("hello") == "HELLO" { passed = passed + 1 }

    total = total + 1
    if string.lower("HELLO") == "hello" { passed = passed + 1 }

    total = total + 1
    if string.trim("  hello  ") == "hello" { passed = passed + 1 }

    total = total + 1
    if string.trim("") == "" { passed = passed + 1 }

    total = total + 1
    if string.reverse("abcde") == "edcba" { passed = passed + 1 }

    total = total + 1
    if string.reverse("") == "" { passed = passed + 1 }

    return [passed, total]
}

// T13.2: Search operations
fn test_search() {
    let passed = 0
    let total = 0

    total = total + 1
    if string.contains("hello world", "world") { passed = passed + 1 }

    total = total + 1
    if !string.contains("hello", "xyz") { passed = passed + 1 }

    total = total + 1
    if string.contains("", "") { passed = passed + 1 }

    total = total + 1
    if string.starts_with("hello", "hel") { passed = passed + 1 }

    total = total + 1
    if !string.starts_with("hello", "xyz") { passed = passed + 1 }

    total = total + 1
    if string.ends_with("hello", "llo") { passed = passed + 1 }

    total = total + 1
    if string.index_of("hello", "ll") == 2 { passed = passed + 1 }

    total = total + 1
    if string.index_of("hello", "xyz") == -1 { passed = passed + 1 }

    return [passed, total]
}

// T13.3: Transform operations
fn test_transform() {
    let passed = 0
    let total = 0

    total = total + 1
    if string.substring("hello world", 0, 5) == "hello" { passed = passed + 1 }

    total = total + 1
    if string.substring("hello", 2, 4) == "ll" { passed = passed + 1 }

    // start >= end after clamping
    total = total + 1
    if string.substring("hello", 5, 10) == "" { passed = passed + 1 }

    // replace ALL occurrences
    total = total + 1
    if string.replace("aabaa", "a", "x") == "xxbxx" { passed = passed + 1 }

    // empty old_str is no-op
    total = total + 1
    if string.replace("hello", "", "x") == "hello" { passed = passed + 1 }

    total = total + 1
    if string.concat("foo", "bar") == "foobar" { passed = passed + 1 }

    // split normal
    total = total + 1
    let parts = string.split("a,b,c", ",")
    if array.length(parts) == 3 && parts[0] == "a" && parts[1] == "b" && parts[2] == "c" {
        passed = passed + 1
    }

    // split into chars
    total = total + 1
    let chars = string.split("hello", "")
    if array.length(chars) == 5 && chars[0] == "h" && chars[4] == "o" {
        passed = passed + 1
    }

    // split no delimiter found
    total = total + 1
    let no_split = string.split("no-delim", ",")
    if array.length(no_split) == 1 && no_split[0] == "no-delim" {
        passed = passed + 1
    }

    // join
    total = total + 1
    if string.join(["a", "b", "c"], "-") == "a-b-c" { passed = passed + 1 }

    return [passed, total]
}

// T13.4: Formatting operations
fn test_formatting() {
    let passed = 0
    let total = 0

    total = total + 1
    if string.repeat("ab", 3) == "ababab" { passed = passed + 1 }

    total = total + 1
    if string.repeat("x", 0) == "" { passed = passed + 1 }

    total = total + 1
    if string.char_at("hello", 0) == "h" { passed = passed + 1 }

    total = total + 1
    if string.char_at("hello", 4) == "o" { passed = passed + 1 }

    total = total + 1
    if string.pad_left("hi", 5) == "   hi" { passed = passed + 1 }

    total = total + 1
    if string.pad_right("hi", 5) == "hi   " { passed = passed + 1 }

    total = total + 1
    if string.pad_left("hi", 5, "0") == "000hi" { passed = passed + 1 }

    // already longer than width — no-op
    total = total + 1
    if string.pad_left("hello", 3) == "hello" { passed = passed + 1 }

    return [passed, total]
}

// T13.5: Edge cases and error cases
fn test_edge_cases() {
    let passed = 0
    let total = 0

    // char_at out of range throws
    total = total + 1
    let threw = false
    try {
        string.char_at("hello", 10)
    } catch (e) {
        threw = true
    }
    if threw { passed = passed + 1 }

    // char_at negative throws
    total = total + 1
    let threw2 = false
    try {
        string.char_at("hello", -1)
    } catch (e) {
        threw2 = true
    }
    if threw2 { passed = passed + 1 }

    // repeat negative throws
    total = total + 1
    let threw3 = false
    try {
        string.repeat("x", -1)
    } catch (e) {
        threw3 = true
    }
    if threw3 { passed = passed + 1 }

    // pad_left fill char must be 1 char
    total = total + 1
    let threw4 = false
    try {
        string.pad_left("x", 5, "ab")
    } catch (e) {
        threw4 = true
    }
    if threw4 { passed = passed + 1 }

    // substring with negative start clamped to 0
    total = total + 1
    let sub = string.substring("hello", -5, 3)
    if sub == "hel" { passed = passed + 1 }

    // ends_with suffix longer than string
    total = total + 1
    if !string.ends_with("hi", "hello") { passed = passed + 1 }

    return [passed, total]
}

// T13.6: format/fmt
fn test_format() {
    let passed = 0
    let total = 0

    // single substitution
    total = total + 1
    let r1 = string.format("Hello {}", "world")
    if r1 == "Hello world" { passed = passed + 1 }

    // multiple substitutions
    total = total + 1
    let r2 = string.format("{} + {} = {}", "1", "2", "3")
    if r2 == "1 + 2 = 3" { passed = passed + 1 }

    // no substitutions
    total = total + 1
    let r3 = string.format("no subs")
    if r3 == "no subs" { passed = passed + 1 }

    // fmt alias
    total = total + 1
    let r4 = string.fmt("Hi {}", "there")
    if r4 == "Hi there" { passed = passed + 1 }

    return [passed, total]
}

fn test_fstrings() {
    let passed = 0
    let total = 0

    // basic f-string interpolation
    total = total + 1
    let name = "world"
    if f"hello {name}" == "hello world" { passed = passed + 1 }

    // f-string with arithmetic expression
    total = total + 1
    if f"result: {2 + 3}" == "result: 5" { passed = passed + 1 }

    // f-string with no interpolation (plain text)
    total = total + 1
    if f"plain text" == "plain text" { passed = passed + 1 }

    // f-string with multiple interpolations
    total = total + 1
    let a = "foo"
    let b = "bar"
    if f"{a} and {b}" == "foo and bar" { passed = passed + 1 }

    // regular string ignores bare braces
    total = total + 1
    let regular = "no {interp}"
    if regular == "no {interp}" { passed = passed + 1 }

    // f-string with ${} also works (backward compat)
    total = total + 1
    if f"${name} too" == "world too" { passed = passed + 1 }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_basic_string()
    print("  T13.1 basic_string: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_search()
    print("  T13.2 search: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_transform()
    print("  T13.3 transform: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_formatting()
    print("  T13.4 formatting: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_edge_cases()
    print("  T13.5 edge_cases: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_format()
    print("  T13.6 format: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    let r7 = test_fstrings()
    print("  T13.7 fstrings: " + string(r7[0]) + "/" + string(r7[1]))
    total_passed = total_passed + r7[0]
    total_tests = total_tests + r7[1]

    print("")
    print("Stdlib String: " + string(total_passed) + "/" + string(total_tests))
}
