// Meta-Test Layer 2: Mutation Testing
// 43 deliberately WRONG assertions — each MUST evaluate to false.
// If any "wrong" assertion evaluates to true, the test framework is broken.
// Pattern: let wrong = <bad_assertion>; if !wrong { passed++ }

use array
use string
use math
use json
use regex

// ── M2.1: Array Mutations (8) ──
fn test_array_mutations() {
    let passed = 0
    let total = 0

    // 1. length should be 3, not 99
    total = total + 1
    let w1 = array.length([1, 2, 3]) == 99
    if !w1 { passed = passed + 1 }

    // 2. empty array length should be 0, not 1
    total = total + 1
    let w2 = array.length([]) == 1
    if !w2 { passed = passed + 1 }

    // 3. first should be 10, not 30
    total = total + 1
    let w3 = array.first([10, 20, 30]) == 30
    if !w3 { passed = passed + 1 }

    // 4. last should be 30, not 10
    total = total + 1
    let w4 = array.last([10, 20, 30]) == 10
    if !w4 { passed = passed + 1 }

    // 5. 99 is NOT in the array
    total = total + 1
    let w5 = array.contains([1, 2, 3], 99)
    if !w5 { passed = passed + 1 }

    // 6. sorted first should be 1, not 3
    total = total + 1
    let w6 = array.sort([3, 1, 2])[0] == 3
    if !w6 { passed = passed + 1 }

    // 7. reversed first should be 3, not 1
    total = total + 1
    let w7 = array.reverse([1, 2, 3])[0] == 1
    if !w7 { passed = passed + 1 }

    // 8. wrong delimiter in expected result
    total = total + 1
    let w8 = array.join(["a", "b"], ",") == "a-b"
    if !w8 { passed = passed + 1 }

    return [passed, total]
}

// ── M2.2: String Mutations (8) ──
fn test_string_mutations() {
    let passed = 0
    let total = 0

    // 1. upper("hello") should be "HELLO", not "hello"
    total = total + 1
    let w1 = string.upper("hello") == "hello"
    if !w1 { passed = passed + 1 }

    // 2. lower("HELLO") should be "hello", not "HELLO"
    total = total + 1
    let w2 = string.lower("HELLO") == "HELLO"
    if !w2 { passed = passed + 1 }

    // 3. length("abc") should be 3, not 0
    total = total + 1
    let w3 = string.length("abc") == 0
    if !w3 { passed = passed + 1 }

    // 4. trim should remove spaces
    total = total + 1
    let w4 = string.trim("  hi  ") == "  hi  "
    if !w4 { passed = passed + 1 }

    // 5. reverse("abc") should be "cba", not "abc"
    total = total + 1
    let w5 = string.reverse("abc") == "abc"
    if !w5 { passed = passed + 1 }

    // 6. "xyz" is NOT in "hello"
    total = total + 1
    let w6 = string.contains("hello", "xyz")
    if !w6 { passed = passed + 1 }

    // 7. "hello" does NOT start with "xyz"
    total = total + 1
    let w7 = string.starts_with("hello", "xyz")
    if !w7 { passed = passed + 1 }

    // 8. index_of "xyz" in "hello" should be -1, not 0
    total = total + 1
    let w8 = string.index_of("hello", "xyz") == 0
    if !w8 { passed = passed + 1 }

    return [passed, total]
}

// ── M2.3: Math/JSON Mutations (8) ──
fn test_math_json_mutations() {
    let passed = 0
    let total = 0

    // 1. abs(-5) should be 5, not -5
    total = total + 1
    let w1 = math.abs(-5) == -5
    if !w1 { passed = passed + 1 }

    // 2. sqrt(9) should be 3, not 2
    total = total + 1
    let w2 = math.sqrt(9) == 2
    if !w2 { passed = passed + 1 }

    // 3. floor(3.7) should be 3, not 4
    total = total + 1
    let w3 = math.floor(3.7) == 4
    if !w3 { passed = passed + 1 }

    // 4. ceil(3.2) should be 4, not 3
    total = total + 1
    let w4 = math.ceil(3.2) == 3
    if !w4 { passed = passed + 1 }

    // 5. min(3,7) should be 3, not 7
    total = total + 1
    let w5 = math.min(3, 7) == 7
    if !w5 { passed = passed + 1 }

    // 6. max(3,7) should be 7, not 3
    total = total + 1
    let w6 = math.max(3, 7) == 3
    if !w6 { passed = passed + 1 }

    // 7. "not json" is NOT valid JSON
    total = total + 1
    let w7 = json.is_valid("not json")
    if !w7 { passed = passed + 1 }

    // 8. pow(2,3) should be 8, not 9
    total = total + 1
    let w8 = math.pow(2, 3) == 9
    if !w8 { passed = passed + 1 }

    return [passed, total]
}

// ── M2.4: Operator Mutations (8) ──
fn test_operator_mutations() {
    let passed = 0
    let total = 0

    // 1. 3+4 should be 7, not 8
    total = total + 1
    let w1 = 3 + 4 == 8
    if !w1 { passed = passed + 1 }

    // 2. 10-3 should be 7, not 8
    total = total + 1
    let w2 = 10 - 3 == 8
    if !w2 { passed = passed + 1 }

    // 3. 6*7 should be 42, not 43
    total = total + 1
    let w3 = 6 * 7 == 43
    if !w3 { passed = passed + 1 }

    // 4. null is NOT equal to 0
    total = total + 1
    let w4 = null == 0
    if !w4 { passed = passed + 1 }

    // 5. null is NOT equal to false
    total = total + 1
    let w5 = null == false
    if !w5 { passed = passed + 1 }

    // 6. null is NOT equal to ""
    total = total + 1
    let w6 = null == ""
    if !w6 { passed = passed + 1 }

    // 7. "hello" + " world" has space, != "helloworld"
    total = total + 1
    let w7 = "hello" + " world" == "helloworld"
    if !w7 { passed = passed + 1 }

    // 8. !true should be false, not true
    total = total + 1
    let w8 = !true == true
    if !w8 { passed = passed + 1 }

    // 9. "def" < "abc" should be false (lexicographic)
    total = total + 1
    let w9 = "def" < "abc"
    if !w9 { passed = passed + 1 }

    // 10. "abc" > "def" should be false (lexicographic)
    total = total + 1
    let w10 = "abc" > "def"
    if !w10 { passed = passed + 1 }

    return [passed, total]
}

// ── M2.5: Closure/Scope Mutations (4) ──
fn mut_make_adder(n) {
    return fn(x) { return x + n }
}

fn mut_make_counter() {
    let c = 0
    return fn() { c = c + 1; return c }
}

fn test_closure_mutations() {
    let passed = 0
    let total = 0

    // 1. closure captures x=10, should return 10, not 99
    total = total + 1
    let x = 10
    let f = fn() { return x }
    let w1 = f() == 99
    if !w1 { passed = passed + 1 }

    // 2. make_adder(5)(3) should be 8, not 99
    total = total + 1
    let w2 = mut_make_adder(5)(3) == 99
    if !w2 { passed = passed + 1 }

    // 3. counter called 3 times should return 3, not 99
    total = total + 1
    let counter = mut_make_counter()
    counter()
    counter()
    let w3 = counter() == 99
    if !w3 { passed = passed + 1 }

    // 4. two independent counters: c1 called 3x returns 4 on next, c2 called 1x returns 2 on next — they differ
    total = total + 1
    let c1 = mut_make_counter()
    let c2 = mut_make_counter()
    c1()
    c1()
    c1()
    c2()
    let w4 = c1() == c2()
    if !w4 { passed = passed + 1 }

    return [passed, total]
}

// ── M2.6: Control Flow / Struct Mutations (4) ──
struct MutPoint {
    x: int,
    y: int
}

enum MutColor {
    Red,
    Green,
    Blue
}

fn test_flow_struct_mutations() {
    let passed = 0
    let total = 0

    // 1. struct Point{x:3,y:4}, p.x should be 3, not 99
    total = total + 1
    let p = new MutPoint { x: 3, y: 4 }
    let w1 = p.x == 99
    if !w1 { passed = passed + 1 }

    // 2. match Color.Red should return "red", not "green"
    total = total + 1
    let result = match MutColor.Red {
        MutColor.Red => "red"
        MutColor.Green => "green"
        MutColor.Blue => "blue"
        _ => "unknown"
    }
    let w2 = result == "green"
    if !w2 { passed = passed + 1 }

    // 3. value semantics: copy dict, modify copy, original should NOT change
    total = total + 1
    let orig = {"key": "original"}
    let copy = orig
    copy["key"] = "modified"
    let w3 = orig["key"] == "modified"
    if !w3 { passed = passed + 1 }

    // 4. for x in [] never executes body
    total = total + 1
    let ran = false
    for x in [] {
        ran = true
    }
    let w4 = ran == true
    if !w4 { passed = passed + 1 }

    return [passed, total]
}

// ── M2.7: Null Coalesce Edge Cases (3) ──
fn test_null_coalesce_mutations() {
    let passed = 0
    let total = 0

    // 1. false is NOT null — ?? should NOT trigger
    total = total + 1
    let w1 = (false ?? "default") == "default"
    if !w1 { passed = passed + 1 }

    // 2. 0 is NOT null — ?? should NOT trigger
    total = total + 1
    let w2 = (0 ?? "default") == "default"
    if !w2 { passed = passed + 1 }

    // 3. "" is NOT null — ?? should NOT trigger
    total = total + 1
    let w3 = ("" ?? "default") == "default"
    if !w3 { passed = passed + 1 }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_array_mutations()
    print("  M2.1 array_mutations: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_string_mutations()
    print("  M2.2 string_mutations: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_math_json_mutations()
    print("  M2.3 math_json_mutations: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_operator_mutations()
    print("  M2.4 operator_mutations: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_closure_mutations()
    print("  M2.5 closure_mutations: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_flow_struct_mutations()
    print("  M2.6 flow_struct_mutations: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    let r7 = test_null_coalesce_mutations()
    print("  M2.7 null_coalesce_mutations: " + string(r7[0]) + "/" + string(r7[1]))
    total_passed = total_passed + r7[0]
    total_tests = total_tests + r7[1]

    print("")
    print("Mutations: " + string(total_passed) + "/" + string(total_tests))
}
