// Test 5: PII / Memorized Data Leakage
// Maps to: env var exposure, file content leakage past governance

use env
use string

// T5.1: env.get tainted — cannot reach shell
fn test_env_var_leakage_blocked() {
    let passed = 0
    let total = 0

    total = total + 1
    let home = env.get("HOME")
    let blocked = false
    try {
        let r = <<shell[home]
echo $home
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T5.2: Sensitive env vars should be tainted
fn test_sensitive_env_vars() {
    let passed = 0
    let total = 0

    let sensitive_vars = ["HOME", "USER", "PATH", "SHELL"]
    for var_name in sensitive_vars {
        total = total + 1
        let val = env.get(var_name)
        let blocked = false
        try {
            let r = <<shell[val]
echo $val
>>
        } catch (e) {
            blocked = true
        }
        if blocked {
            passed = passed + 1
        } else {
            print("    DETAIL: env." + var_name + " reached shell sink")
        }
    }

    return [passed, total]
}

// T5.3: env.get of non-existent var should not crash
fn test_env_nonexistent() {
    let passed = 0
    let total = 0

    total = total + 1
    let no_crash = true
    try {
        let val = env.get("NAAB_NONEXISTENT_VAR_12345")
        // Should return null or empty string, not crash
        no_crash = true
    } catch (e) {
        // Even if it throws, no crash
        no_crash = true
    }
    if no_crash {
        passed = passed + 1
    }

    return [passed, total]
}

// T5.4: Polyglot output is tainted — cannot re-enter shell
fn test_polyglot_output_leakage() {
    let passed = 0
    let total = 0

    total = total + 1
    let secret = <<python
import os
os.environ.get("HOME", "unknown")
>>
    let blocked = false
    try {
        let r = <<shell[secret]
echo $secret
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T5.5: Chained polyglot output leakage (python → python → shell)
fn test_chained_polyglot_leakage() {
    let passed = 0
    let total = 0

    total = total + 1
    let step1 = <<python
"sensitive_data_step1"
>>
    let blocked = false
    try {
        let r = <<shell[step1]
echo $step1
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_env_var_leakage_blocked()
    print("  T5.1 env_var_leakage: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_sensitive_env_vars()
    print("  T5.2 sensitive_env_vars: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_env_nonexistent()
    print("  T5.3 env_nonexistent: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_polyglot_output_leakage()
    print("  T5.4 polyglot_output_leak: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_chained_polyglot_leakage()
    print("  T5.5 chained_polyglot_leak: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    print("")
    print("Data Leakage: " + string(total_passed) + "/" + string(total_tests))
}
