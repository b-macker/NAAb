// Test 18: Structs, Enums, Match, Value Semantics
// Tests struct creation/modification, enum variants, match patterns, copy behavior

use array

// Struct definitions (top-level only)
struct Point {
    x: int,
    y: int
}

struct Person {
    name: string,
    age: int
}

struct Nested {
    label: string,
    point: Point
}

enum Color {
    Red,
    Green,
    Blue
}

enum Status {
    Active,
    Inactive,
    Pending
}

// T18.1: Struct basics
fn test_struct_basics() {
    let passed = 0
    let total = 0

    // create and access
    total = total + 1
    let p = new Point { x: 3, y: 4 }
    if p.x == 3 && p.y == 4 { passed = passed + 1 }

    // modify field
    total = total + 1
    p.x = 10
    if p.x == 10 { passed = passed + 1 }

    // multiple fields
    total = total + 1
    let person = new Person { name: "Alice", age: 30 }
    if person.name == "Alice" && person.age == 30 { passed = passed + 1 }

    // modify string field
    total = total + 1
    person.name = "Bob"
    if person.name == "Bob" { passed = passed + 1 }

    // struct as function param
    total = total + 1
    let p2 = new Point { x: 1, y: 2 }
    let sum = point_sum(p2)
    if sum == 3 { passed = passed + 1 }

    // struct in array
    total = total + 1
    let points = [
        new Point { x: 0, y: 0 },
        new Point { x: 1, y: 1 },
        new Point { x: 2, y: 2 }
    ]
    if array.length(points) == 3 && points[1].x == 1 { passed = passed + 1 }

    return [passed, total]
}

fn point_sum(p) {
    return p.x + p.y
}

// T18.2: Enum basics
fn test_enum_basics() {
    let passed = 0
    let total = 0

    // access variant
    total = total + 1
    let c = Color.Red
    if c != null { passed = passed + 1 }

    // enum in match
    total = total + 1
    let name = match Color.Green {
        Color.Red => "red"
        Color.Green => "green"
        Color.Blue => "blue"
        _ => "unknown"
    }
    if name == "green" { passed = passed + 1 }

    // multiple enum types
    total = total + 1
    let s = Status.Active
    let s_name = match s {
        Status.Active => "active"
        Status.Inactive => "inactive"
        Status.Pending => "pending"
        _ => "unknown"
    }
    if s_name == "active" { passed = passed + 1 }

    // enum as function parameter
    total = total + 1
    let result = color_to_string(Color.Blue)
    if result == "blue" { passed = passed + 1 }

    // enum comparison
    total = total + 1
    let a = Color.Red
    let b = Color.Red
    if a == b { passed = passed + 1 }

    return [passed, total]
}

fn color_to_string(c) {
    return match c {
        Color.Red => "red"
        Color.Green => "green"
        Color.Blue => "blue"
        _ => "unknown"
    }
}

// T18.3: Advanced match patterns
fn test_match_advanced() {
    let passed = 0
    let total = 0

    // match on multiple int values
    total = total + 1
    let grade = match 85 {
        100 => "perfect"
        85 => "good"
        _ => "other"
    }
    if grade == "good" { passed = passed + 1 }

    // match on string
    total = total + 1
    let lang = match "python" {
        "python" => "snake"
        "rust" => "crab"
        _ => "unknown"
    }
    if lang == "snake" { passed = passed + 1 }

    // match with wildcard
    total = total + 1
    let r = match 42 {
        1 => "one"
        _ => "other"
    }
    if r == "other" { passed = passed + 1 }

    // match as expression (return value)
    total = total + 1
    let val = 3
    let text = match val {
        1 => "one"
        2 => "two"
        3 => "three"
        _ => "many"
    }
    if text == "three" { passed = passed + 1 }

    // match on boolean
    total = total + 1
    let bool_match = match true {
        true => "yes"
        false => "no"
        _ => "unknown"
    }
    if bool_match == "yes" { passed = passed + 1 }

    // match inside function
    total = total + 1
    let describe_num = fn(n) {
        return match n {
            0 => "zero"
            1 => "one"
            _ => "many"
        }
    }
    if describe_num(0) == "zero" && describe_num(5) == "many" { passed = passed + 1 }

    return [passed, total]
}

// T18.4: Value semantics — copy behavior
fn test_value_semantics() {
    let passed = 0
    let total = 0

    // dict assignment copies
    total = total + 1
    let a = {"x": 1, "y": 2}
    let b = a
    b["x"] = 99
    if a["x"] == 1 { passed = passed + 1 }

    // array assignment copies
    total = total + 1
    let arr1 = [1, 2, 3]
    let arr2 = arr1
    arr2.push(4)
    if array.length(arr1) == 3 { passed = passed + 1 }

    // dict modification doesn't affect copy
    total = total + 1
    let d1 = {"name": "Alice"}
    let d2 = d1
    d2["name"] = "Bob"
    if d1["name"] == "Alice" && d2["name"] == "Bob" { passed = passed + 1 }

    // array subscript assignment on copy
    total = total + 1
    let orig = [10, 20, 30]
    let copy = orig
    copy[0] = 99
    if orig[0] == 10 && copy[0] == 99 { passed = passed + 1 }

    return [passed, total]
}

// T18.5: Struct field types
fn test_struct_field_types() {
    let passed = 0
    let total = 0

    // int fields
    total = total + 1
    let p = new Point { x: 100, y: -50 }
    if p.x == 100 && p.y == -50 { passed = passed + 1 }

    // string field
    total = total + 1
    let person = new Person { name: "Test", age: 25 }
    if person.name == "Test" { passed = passed + 1 }

    // modify and verify
    total = total + 1
    person.age = 26
    if person.age == 26 && person.name == "Test" { passed = passed + 1 }

    // struct field arithmetic
    total = total + 1
    let p2 = new Point { x: 3, y: 4 }
    let dist_sq = p2.x * p2.x + p2.y * p2.y
    if dist_sq == 25 { passed = passed + 1 }

    return [passed, total]
}

// T18.6: Optional chaining (?.)
fn test_optional_chaining() {
    let passed = 0
    let total = 0

    // ?. on non-null struct returns value
    total = total + 1
    let p = new Point { x: 5, y: 10 }
    if p?.x == 5 { passed = passed + 1 }

    // ?. on null returns null
    total = total + 1
    let n = null
    let r = n?.name
    if r == null { passed = passed + 1 }

    // ?. chain propagates null
    total = total + 1
    let r2 = n?.foo?.bar
    if r2 == null { passed = passed + 1 }

    // ?. with ?? fallback
    total = total + 1
    let val = n?.x ?? 42
    if val == 42 { passed = passed + 1 }

    // ?. on non-null with ?? returns real value
    total = total + 1
    let val2 = p?.x ?? 42
    if val2 == 5 { passed = passed + 1 }

    // ?. method call on null
    total = total + 1
    let dict_null = null
    let v = dict_null?.get("key")
    if v == null { passed = passed + 1 }

    // ?. method call on non-null dict
    total = total + 1
    let d = {"a": 1}
    let v2 = d?.get("a")
    if v2 == 1 { passed = passed + 1 }

    // ?. on non-null string method
    total = total + 1
    let s = "hello"
    let u = s?.upper()
    if u == "HELLO" { passed = passed + 1 }

    // ?. on null with string method
    total = total + 1
    let ns = null
    let u2 = ns?.upper()
    if u2 == null { passed = passed + 1 }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_struct_basics()
    print("  T18.1 struct_basics: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_enum_basics()
    print("  T18.2 enum_basics: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_match_advanced()
    print("  T18.3 match_advanced: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_value_semantics()
    print("  T18.4 value_semantics: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_struct_field_types()
    print("  T18.5 struct_field_types: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_optional_chaining()
    print("  T18.6 optional_chaining: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    print("")
    print("Structs/Enums: " + string(total_passed) + "/" + string(total_tests))
}
