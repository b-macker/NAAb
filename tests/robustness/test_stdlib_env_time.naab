// Test 19: Env & Time Stdlib — exhaustive coverage
// Tests env_impl.cpp and time_impl.cpp

use env
use time
use string

// T19.1: Environment operations
fn test_env_ops() {
    let passed = 0
    let total = 0

    // get HOME returns non-empty
    total = total + 1
    let home = env.get("HOME")
    if home != null && home != "" { passed = passed + 1 }

    // get nonexistent returns null or empty
    total = total + 1
    let nope = env.get("NONEXISTENT_VAR_NAAB_TEST_12345")
    if nope == null || nope == "" { passed = passed + 1 }

    // has HOME
    total = total + 1
    if env.has("HOME") { passed = passed + 1 }

    // has nonexistent
    total = total + 1
    if !env.has("NONEXISTENT_VAR_NAAB_TEST_12345") { passed = passed + 1 }

    // set_var then get
    total = total + 1
    env.set_var("NAAB_TEST_VAR_42", "hello_naab")
    let val = env.get("NAAB_TEST_VAR_42")
    if val == "hello_naab" { passed = passed + 1 }

    // delete_var then has
    total = total + 1
    env.delete_var("NAAB_TEST_VAR_42")
    if !env.has("NAAB_TEST_VAR_42") { passed = passed + 1 }

    // get_all returns dict with HOME
    total = total + 1
    let all = env.get_all()
    if all != null { passed = passed + 1 }

    return [passed, total]
}

// T19.2: Time operations
fn test_time_ops() {
    let passed = 0
    let total = 0

    // now returns positive int
    total = total + 1
    let ts = time.now()
    if ts > 0 { passed = passed + 1 }

    // now_millis returns positive int
    total = total + 1
    let ms = time.now_millis()
    if ms > 0 { passed = passed + 1 }

    // now_millis > now (millis are bigger numbers)
    total = total + 1
    let s = time.now()
    let m = time.now_millis()
    if m > s { passed = passed + 1 }

    // year >= 2026
    total = total + 1
    let y = time.year(time.now())
    if y >= 2026 { passed = passed + 1 }

    // month 1-12
    total = total + 1
    let mo = time.month(time.now())
    if mo >= 1 && mo <= 12 { passed = passed + 1 }

    // day 1-31
    total = total + 1
    let d = time.day(time.now())
    if d >= 1 && d <= 31 { passed = passed + 1 }

    // sleep doesn't crash (10ms)
    total = total + 1
    let before = time.now_millis()
    time.sleep(0.01)
    let after = time.now_millis()
    if after >= before { passed = passed + 1 }

    // two now() calls: second >= first
    total = total + 1
    let t1 = time.now()
    let t2 = time.now()
    if t2 >= t1 { passed = passed + 1 }

    return [passed, total]
}

// T19.3: Env advanced — get_int, get_float, get_bool, get_args, list
fn test_env_advanced() {
    let passed = 0
    let total = 0

    // set a numeric var, then get_int
    total = total + 1
    env.set_var("NAAB_TEST_INT", "42")
    let vi = env.get_int("NAAB_TEST_INT")
    if vi == 42 { passed = passed + 1 }

    // get_int with default for missing var
    total = total + 1
    let vi2 = env.get_int("NAAB_MISSING_999", 99)
    if vi2 == 99 { passed = passed + 1 }

    // set a float var, then get_float
    total = total + 1
    env.set_var("NAAB_TEST_FLOAT", "3.14")
    let vf = env.get_float("NAAB_TEST_FLOAT")
    if vf > 3.13 && vf < 3.15 { passed = passed + 1 }

    // set a bool var, then get_bool
    total = total + 1
    env.set_var("NAAB_TEST_BOOL", "true")
    let vb = env.get_bool("NAAB_TEST_BOOL")
    if vb == true { passed = passed + 1 }

    // list returns array of env var names
    total = total + 1
    let names = env.list()
    if names != null { passed = passed + 1 }

    // parse_env_file parses env content string
    total = total + 1
    let parsed = env.parse_env_file("FOO=bar\nBAZ=qux")
    if parsed["FOO"] == "bar" && parsed["BAZ"] == "qux" { passed = passed + 1 }

    // parse_env_file skips comments and empty lines
    total = total + 1
    let parsed2 = env.parse_env_file("# comment\n\nKEY=val")
    if parsed2["KEY"] == "val" { passed = passed + 1 }

    // load_dotenv lenient mode returns empty on missing file
    total = total + 1
    let dotenv_result = env.load_dotenv("/tmp/naab_nonexistent_dotenv_file_99999")
    if dotenv_result != null { passed = passed + 1 }

    // get_args returns an array
    total = total + 1
    let args = env.get_args()
    if args != null { passed = passed + 1 }

    // cleanup
    env.delete_var("NAAB_TEST_INT")
    env.delete_var("NAAB_TEST_FLOAT")
    env.delete_var("NAAB_TEST_BOOL")

    return [passed, total]
}

// T19.4: Time advanced — hour, minute, second, weekday, format_timestamp
fn test_time_advanced() {
    let passed = 0
    let total = 0

    let ts = time.now()

    // hour 0-23
    total = total + 1
    let h = time.hour(ts)
    if h >= 0 && h <= 23 { passed = passed + 1 }

    // minute 0-59
    total = total + 1
    let m = time.minute(ts)
    if m >= 0 && m <= 59 { passed = passed + 1 }

    // second 0-59
    total = total + 1
    let s = time.second(ts)
    if s >= 0 && s <= 59 { passed = passed + 1 }

    // weekday 0-6
    total = total + 1
    let wd = time.weekday(ts)
    if wd >= 0 && wd <= 6 { passed = passed + 1 }

    // format_timestamp
    total = total + 1
    let formatted = time.format_timestamp(ts, "%Y")
    if formatted == "2026" { passed = passed + 1 }

    // format_timestamp with month
    total = total + 1
    let fmt2 = time.format_timestamp(ts, "%Y-%m")
    if string.length(fmt2) >= 6 { passed = passed + 1 }

    // parse_datetime parses date string to timestamp
    total = total + 1
    let parsed_ts = time.parse_datetime("2026-01-15 10:00:00", "%Y-%m-%d %H:%M:%S")
    if parsed_ts > 0 { passed = passed + 1 }

    // parse_datetime roundtrip: parse then extract year
    total = total + 1
    let pt2 = time.parse_datetime("2025-06-15", "%Y-%m-%d")
    let pt2_year = time.year(pt2)
    if pt2_year == 2025 { passed = passed + 1 }

    // parse_datetime throws on bad format
    total = total + 1
    let pd_threw = false
    try {
        time.parse_datetime("not-a-date", "%Y-%m-%d")
    } catch (e) {
        pd_threw = true
    }
    if pd_threw { passed = passed + 1 }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_env_ops()
    print("  T19.1 env_ops: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_time_ops()
    print("  T19.2 time_ops: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_env_advanced()
    print("  T19.3 env_advanced: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_time_advanced()
    print("  T19.4 time_advanced: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    print("")
    print("Stdlib Env/Time: " + string(total_passed) + "/" + string(total_tests))
}
