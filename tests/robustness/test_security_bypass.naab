// Test 11: Security / Authorization Bypasses
// Maps to: privilege escalation, governance override, secret exposure

use env
use string

fn sanitize_cmd(x) {
    return x
}

// T11.1: Governance override flag NOT active (should block)
fn test_no_override_active() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = env.get("HOME")
    let blocked = false
    try {
        let r = <<shell[tainted]
echo $tainted
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T11.2: Sanitizer must be actual function call, not just name prefix
fn test_sanitizer_requires_call() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = env.get("HOME")
    // Just assigning to a variable named sanitize_* should NOT clear taint
    let sanitize_result = tainted
    let blocked = false
    try {
        let r = <<shell[sanitize_result]
echo $sanitize_result
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T11.3: Double-hop taint — tainted → clean var → shell
fn test_double_hop_taint() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = env.get("HOME")
    let hop1 = tainted
    let hop2 = hop1
    let blocked = false
    try {
        let r = <<shell[hop2]
echo $hop2
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T11.4: Taint via string interpolation
fn test_taint_via_interpolation() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = env.get("HOME")
    let interpolated = "path: ${tainted}"
    let blocked = false
    try {
        let r = <<shell[interpolated]
echo $interpolated
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T11.5: Sanitizer actually clears taint (positive test)
fn test_sanitizer_clears() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = env.get("HOME")
    let clean = sanitize_cmd(tainted)
    let allowed = false
    try {
        let r = <<shell[clean]
echo $clean
>>
        allowed = true
    } catch (e) {
        allowed = false
    }
    if allowed {
        passed = passed + 1
    }

    return [passed, total]
}

// T11.6: Filesystem access blocked (mode: none)
fn test_filesystem_blocked() {
    let passed = 0
    let total = 0

    total = total + 1
    let blocked = false
    try {
        let r = <<python
with open("/etc/hostname", "r") as f:
    print(f.read())
>>
    } catch (e) {
        blocked = true
    }
    // Python may error due to permissions or governance blocks file access
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T11.7: env_access disabled — env.get should still work but result is tainted
fn test_env_access_taint() {
    let passed = 0
    let total = 0

    total = total + 1
    let val = env.get("USER")
    // env.get works (it's a NAAb stdlib function)
    // but the result must be tainted
    let blocked = false
    try {
        let r = <<python[val]
print(val)
>>
    } catch (e) {
        blocked = true
    }
    if blocked {
        passed = passed + 1
    }

    return [passed, total]
}

// T11.8: Multiple sinks — tainted data blocked at ALL sink types
fn test_multi_sink_block() {
    let passed = 0
    let total = 0

    let tainted = env.get("HOME")

    // Shell sink
    total = total + 1
    let shell_blocked = false
    try {
        let r = <<shell[tainted]
echo $tainted
>>
    } catch (e) {
        shell_blocked = true
    }
    if shell_blocked {
        passed = passed + 1
    }

    // Python sink
    total = total + 1
    let py_blocked = false
    try {
        let r = <<python[tainted]
print(tainted)
>>
    } catch (e) {
        py_blocked = true
    }
    if py_blocked {
        passed = passed + 1
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_no_override_active()
    print("  T11.1 no_override: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_sanitizer_requires_call()
    print("  T11.2 sanitizer_requires_call: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_double_hop_taint()
    print("  T11.3 double_hop_taint: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_taint_via_interpolation()
    print("  T11.4 taint_interpolation: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_sanitizer_clears()
    print("  T11.5 sanitizer_clears: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_filesystem_blocked()
    print("  T11.6 filesystem_blocked: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    let r7 = test_env_access_taint()
    print("  T11.7 env_access_taint: " + string(r7[0]) + "/" + string(r7[1]))
    total_passed = total_passed + r7[0]
    total_tests = total_tests + r7[1]

    let r8 = test_multi_sink_block()
    print("  T11.8 multi_sink_block: " + string(r8[0]) + "/" + string(r8[1]))
    total_passed = total_passed + r8[0]
    total_tests = total_tests + r8[1]

    print("")
    print("Security Bypass: " + string(total_passed) + "/" + string(total_tests))
}
