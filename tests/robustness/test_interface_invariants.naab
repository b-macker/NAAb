// Test T24: Interface Invariants
// Tests error paths, multi-struct, multi-interface, and interaction with v0.6.0 features

use string
use array

// === Interfaces ===

interface Describable {
    fn describe() -> string
}

interface Sizable {
    fn size() -> int
}

interface Displayable {
    fn display() -> string
    fn short_display() -> string
}

// === Structs ===

struct Box implements Describable, Sizable {
    width: int
    height: int
    label: string
}

fn Box.describe(b) -> string {
    return f"Box({b.label}: {b.width}x{b.height})"
}

fn Box.size(b) -> int {
    return b.width * b.height
}

struct Circle implements Describable, Sizable {
    radius: int
    name: string
}

fn Circle.describe(c) -> string {
    return f"Circle({c.name}: r={c.radius})"
}

fn Circle.size(c) -> int {
    return c.radius * c.radius * 3
}

struct Tag implements Describable {
    text: string
}

fn Tag.describe(t) -> string {
    return f"Tag({t.text})"
}

struct Card implements Displayable {
    title: string
    body: string
}

fn Card.display(c) -> string {
    return c.title + ": " + c.body
}

fn Card.short_display(c) -> string {
    return c.title
}

// === Test functions ===

fn test_interface_basic_contract() {
    let passed = 0
    let total = 0

    // T24.1.1: struct implements single interface — method works
    total = total + 1
    let t = new Tag { text: "hello" }
    if Tag.describe(t) == "Tag(hello)" { passed = passed + 1 }

    // T24.1.2: struct implements two interfaces — both methods work
    total = total + 1
    let b = new Box { width: 5, height: 3, label: "A" }
    if Box.describe(b) == "Box(A: 5x3)" { passed = passed + 1 }

    // T24.1.3: second interface method
    total = total + 1
    if Box.size(b) == 15 { passed = passed + 1 }

    // T24.1.4: multi-method interface — both methods work
    total = total + 1
    let c = new Card { title: "Hi", body: "World" }
    if Card.display(c) == "Hi: World" { passed = passed + 1 }

    // T24.1.5: second method of multi-method interface
    total = total + 1
    if Card.short_display(c) == "Hi" { passed = passed + 1 }

    return [passed, total]
}

fn test_interface_multiple_structs() {
    let passed = 0
    let total = 0

    // T24.2.1: two structs implementing same interface — different results
    total = total + 1
    let b = new Box { width: 4, height: 3, label: "X" }
    let c = new Circle { radius: 5, name: "O" }
    if Box.describe(b) != Circle.describe(c) { passed = passed + 1 }

    // T24.2.2: same interface, different size implementations
    total = total + 1
    if Box.size(b) == 12 && Circle.size(c) == 75 { passed = passed + 1 }

    // T24.2.3: method dispatch is struct-specific
    total = total + 1
    let b2 = new Box { width: 10, height: 10, label: "Big" }
    if Box.size(b2) == 100 { passed = passed + 1 }

    // T24.2.4: calling same-named method on different structs
    total = total + 1
    let desc_b = Box.describe(b)
    let desc_c = Circle.describe(c)
    if string.contains(desc_b, "Box") && string.contains(desc_c, "Circle") { passed = passed + 1 }

    // T24.2.5: method as first-class value across structs
    total = total + 1
    let fn_b = Box.describe
    let fn_c = Circle.describe
    if fn_b(b) == "Box(X: 4x3)" && fn_c(c) == "Circle(O: r=5)" { passed = passed + 1 }

    return [passed, total]
}

fn test_interface_error_paths() {
    let passed = 0
    let total = 0

    // T24.3.1: interface method declared but not implemented — caught at parse time
    // This is detected during Program visitor processing, so we test by verifying
    // that properly implemented interfaces work (positive test for error handling)
    total = total + 1
    let b = new Box { width: 1, height: 1, label: "ok" }
    if Box.describe(b) == "Box(ok: 1x1)" { passed = passed + 1 }

    // T24.3.2: interface with multiple methods — all present
    total = total + 1
    let c = new Card { title: "T", body: "B" }
    let d = Card.display(c)
    let sd = Card.short_display(c)
    if d == "T: B" && sd == "T" { passed = passed + 1 }

    // T24.3.3: calling non-existent method on struct (runtime error)
    total = total + 1
    let caught = false
    try {
        // Box has no "color" method
        let bad = Box.color
    } catch (e) {
        caught = true
    }
    if caught { passed = passed + 1 }

    // T24.3.4: struct fields accessible alongside interface methods
    total = total + 1
    let t = new Tag { text: "world" }
    if t.text == "world" && Tag.describe(t) == "Tag(world)" { passed = passed + 1 }

    // T24.3.5: interface method with f-string (cross-feature)
    total = total + 1
    let b2 = new Box { width: 7, height: 3, label: "test" }
    let desc = Box.describe(b2)
    if string.contains(desc, "7x3") { passed = passed + 1 }

    return [passed, total]
}

fn test_interface_interactions() {
    let passed = 0
    let total = 0

    // T24.4.1: interface method results used in match
    total = total + 1
    let b = new Box { width: 10, height: 10, label: "large" }
    let classification = match Box.size(b) {
        s if s > 50 => "large"
        s if s > 10 => "medium"
        _ => "small"
    }
    if classification == "large" { passed = passed + 1 }

    // T24.4.2: interface methods in array operations
    total = total + 1
    let boxes = [
        new Box { width: 1, height: 1, label: "s" },
        new Box { width: 5, height: 5, label: "m" },
        new Box { width: 10, height: 10, label: "l" }
    ]
    let sizes = []
    for b in boxes {
        sizes = array.push(sizes, Box.size(b))
    }
    if sizes[0] == 1 && sizes[1] == 25 && sizes[2] == 100 { passed = passed + 1 }

    // T24.4.3: interface method as callback argument
    total = total + 1
    let descs = array.map_fn(boxes, Box.describe)
    if string.contains(descs[0], "s:") { passed = passed + 1 }

    // T24.4.4: generator yielding interface method results
    total = total + 1
    fn describe_all(items) {
        for item in items {
            yield Box.describe(item)
        }
    }
    let all_descs = []
    for d in describe_all(boxes) {
        all_descs = array.push(all_descs, d)
    }
    if array.length(all_descs) == 3 { passed = passed + 1 }

    // T24.4.5: interface method with typed parameters
    total = total + 1
    fn get_big_boxes(items) {
        let result = []
        for b in items {
            if Box.size(b) > 20 {
                result = array.push(result, b)
            }
        }
        return result
    }
    let big = get_big_boxes(boxes)
    if array.length(big) == 2 { passed = passed + 1 }

    return [passed, total]
}

fn test_interface_struct_creation() {
    let passed = 0
    let total = 0

    // T24.5.1: struct with interface — fields initialized correctly
    total = total + 1
    let b = new Box { width: 42, height: 0, label: "" }
    if b.width == 42 && b.height == 0 && b.label == "" { passed = passed + 1 }

    // T24.5.2: multiple instances of same struct
    total = total + 1
    let b1 = new Box { width: 1, height: 1, label: "1" }
    let b2 = new Box { width: 2, height: 2, label: "2" }
    if Box.describe(b1) != Box.describe(b2) { passed = passed + 1 }

    // T24.5.3: struct instance passed to function
    total = total + 1
    fn box_area(b) {
        return Box.size(b)
    }
    let b3 = new Box { width: 6, height: 7, label: "test" }
    if box_area(b3) == 42 { passed = passed + 1 }

    // T24.5.4: struct instance stored in array
    total = total + 1
    let arr = [new Box { width: 1, height: 1, label: "a" }, new Box { width: 2, height: 2, label: "b" }]
    if Box.size(arr[0]) == 1 && Box.size(arr[1]) == 4 { passed = passed + 1 }

    // T24.5.5: struct instance stored in dict
    total = total + 1
    let d = {"box": new Box { width: 3, height: 4, label: "d" }}
    if Box.size(d["box"]) == 12 { passed = passed + 1 }

    return [passed, total]
}

main {
    print("=== T24: Interface Invariants ===")
    let total_passed = 0
    let total_tests = 0

    let r1 = test_interface_basic_contract()
    print("  T24.1 basic_contract: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_interface_multiple_structs()
    print("  T24.2 multiple_structs: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_interface_error_paths()
    print("  T24.3 error_paths: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_interface_interactions()
    print("  T24.4 interactions: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_interface_struct_creation()
    print("  T24.5 struct_creation: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    print("")
    print("Interface Invariants: " + string(total_passed) + "/" + string(total_tests))
}
