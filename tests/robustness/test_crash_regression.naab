// Test 10: Crash, Exception, or Performance Regressions
// Maps to: edge cases that could segfault, hang, or OOM

use string
use array
use math

// T10.1: Deeply nested data structures
fn test_deep_nesting() {
    let passed = 0
    let total = 0

    total = total + 1
    let no_crash = true
    try {
        let d = {"a": {"b": {"c": {"d": {"e": "deep"}}}}}
        let val = d["a"]["b"]["c"]["d"]["e"]
        if val == "deep" {
            no_crash = true
        }
    } catch (e) {
        no_crash = true
    }
    if no_crash {
        passed = passed + 1
    }

    return [passed, total]
}

// T10.2: Large array operations
fn test_large_array() {
    let passed = 0
    let total = 0

    total = total + 1
    let arr = []
    for i in 0..1000 {
        arr.push(i)
    }
    if array.length(arr) == 1000 {
        passed = passed + 1
    }

    return [passed, total]
}

// T10.3: Exception in exception handler
fn test_exception_in_handler() {
    let passed = 0
    let total = 0

    total = total + 1
    let caught_outer = false
    try {
        try {
            let x = 1 / 0
        } catch (e) {
            // Throw from inside catch
            let y = 1 / 0
        }
    } catch (e2) {
        caught_outer = true
    }
    if caught_outer {
        passed = passed + 1
    }

    return [passed, total]
}

// T10.4: Null/undefined value handling
fn test_null_handling() {
    let passed = 0
    let total = 0

    total = total + 1
    let x = null
    let no_crash = true
    try {
        let s = string(x)
        no_crash = true
    } catch (e) {
        no_crash = true
    }
    if no_crash {
        passed = passed + 1
    }

    // Null comparison
    total = total + 1
    if x == null {
        passed = passed + 1
    }

    // Null coalesce
    total = total + 1
    let val = x ?? "default"
    if val == "default" {
        passed = passed + 1
    }

    return [passed, total]
}

// T10.5: Stack overflow recovery
fn infinite_recurse(n) {
    return infinite_recurse(n + 1)
}

fn test_stack_overflow_recovery() {
    let passed = 0
    let total = 0

    total = total + 1
    let recovered = false
    try {
        infinite_recurse(0)
    } catch (e) {
        recovered = true
    }
    if recovered {
        passed = passed + 1
    }

    // Verify interpreter still works after recovery
    total = total + 1
    let x = 1 + 1
    if x == 2 {
        passed = passed + 1
    }

    return [passed, total]
}

// T10.6: Empty containers edge cases
fn test_empty_containers() {
    let passed = 0
    let total = 0

    // Empty array operations
    total = total + 1
    let arr = []
    if array.length(arr) == 0 {
        passed = passed + 1
    }

    // Empty dict
    total = total + 1
    let d = {}
    let no_crash = true
    try {
        let keys = d.keys()
        no_crash = true
    } catch (e) {
        no_crash = true
    }
    if no_crash {
        passed = passed + 1
    }

    return [passed, total]
}

// T10.7: Type mismatch operations
fn test_type_mismatch() {
    let passed = 0
    let total = 0

    // String + int (should concatenate or error, not crash)
    total = total + 1
    let no_crash = true
    try {
        let r = "hello" + string(42)
        no_crash = true
    } catch (e) {
        no_crash = true
    }
    if no_crash {
        passed = passed + 1
    }

    // Comparing different types
    total = total + 1
    try {
        let r = (42 == "42")
        no_crash = true
    } catch (e) {
        no_crash = true
    }
    if no_crash {
        passed = passed + 1
    }

    return [passed, total]
}

main {
    let total_passed = 0
    let total_tests = 0

    let r1 = test_deep_nesting()
    print("  T10.1 deep_nesting: " + string(r1[0]) + "/" + string(r1[1]))
    total_passed = total_passed + r1[0]
    total_tests = total_tests + r1[1]

    let r2 = test_large_array()
    print("  T10.2 large_array: " + string(r2[0]) + "/" + string(r2[1]))
    total_passed = total_passed + r2[0]
    total_tests = total_tests + r2[1]

    let r3 = test_exception_in_handler()
    print("  T10.3 exception_in_handler: " + string(r3[0]) + "/" + string(r3[1]))
    total_passed = total_passed + r3[0]
    total_tests = total_tests + r3[1]

    let r4 = test_null_handling()
    print("  T10.4 null_handling: " + string(r4[0]) + "/" + string(r4[1]))
    total_passed = total_passed + r4[0]
    total_tests = total_tests + r4[1]

    let r5 = test_stack_overflow_recovery()
    print("  T10.5 stack_overflow_recovery: " + string(r5[0]) + "/" + string(r5[1]))
    total_passed = total_passed + r5[0]
    total_tests = total_tests + r5[1]

    let r6 = test_empty_containers()
    print("  T10.6 empty_containers: " + string(r6[0]) + "/" + string(r6[1]))
    total_passed = total_passed + r6[0]
    total_tests = total_tests + r6[1]

    let r7 = test_type_mismatch()
    print("  T10.7 type_mismatch: " + string(r7[0]) + "/" + string(r7[1]))
    total_passed = total_passed + r7[0]
    total_tests = total_tests + r7[1]

    print("")
    print("Crash/Regression: " + string(total_passed) + "/" + string(total_tests))
}
