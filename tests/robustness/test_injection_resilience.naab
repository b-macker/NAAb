        if string(e).contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
    } else {
        print("    DETAIL: Taint laundering via concat was NOT detected")
    }

    return [passed, total]
}

// T3.6: Taint laundering via function wrapper (should still be tainted)
fn identity(x) {
    return x
}

fn test_taint_laundering_via_function() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = env.get("HOME")
    let laundered = identity(tainted)
    let blocked = false
    try {
        let r = <<shell[laundered]
echo $laundered
>>
    } catch (e) {
        if string(e).contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
    } else {
        print("    DETAIL: Taint laundering via function was NOT detected")
    }

    return [passed, total]
}

main {
