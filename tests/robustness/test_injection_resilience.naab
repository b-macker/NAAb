// Test 3: Prompt-injection / Jailbreak Resilience
// Maps to: governance bypass attempts, crafted input to override constraints

use env
use string

fn sanitize_input(x) {
    return x
}

// T3.1: Shell injection via variable interpolation
fn test_shell_injection_interpolation() {
    let passed = 0
    let total = 0

    total = total + 1
    let user_input = "hello; rm -rf /"
    let blocked = false
    try {
        let r = <<shell[user_input]
echo $user_input
>>
    } catch (e) {
        // Should be blocked by shell_injection check
        blocked = true
    }
    // Either blocked by governance OR executed safely (shell escaping)
    // We just verify no crash
    passed = passed + 1

    return [passed, total]
}

// T3.2: Python code injection via bound variable
fn test_python_injection_via_binding() {
    let passed = 0
    let total = 0

    total = total + 1
    let payload = "__import__('os').system('echo pwned')"
    let blocked = false
    try {
        let r = <<python[payload]
eval(payload)
>>
    } catch (e) {
        blocked = true
    }
    // Should be blocked: payload is tainted if from user, or python_exec sink
    passed = passed + 1

    return [passed, total]
}

// T3.3: Governance bypass via env.get → polyglot (taint must block)
fn test_taint_bypass_attempt() {
    let passed = 0
    let total = 0

    total = total + 1
    let tainted = env.get("HOME")
    let blocked = false
    try {
        let r = <<shell[tainted]
echo $tainted
>>
    } catch (e) {
        if string(e).contains("aint") {
            blocked = true
        }
    }
    if blocked {
        passed = passed + 1
    } else {
        print("    DETAIL: Tainted env.get() was NOT blocked at shell sink")
    }

    return [passed, total]
}

// T3.4: Attempt to escape polyglot block delimiter
fn test_delimiter_escape() {
    let passed = 0
    let total = 0

    total = total + 1
    let no_crash = true
    try {
        let r = <<python
x = "this has >> inside a string"
print(x)
>>
    } catch (e) {
        // Python might error, but NAAb should not crash
        no_crash = true
    }
    if no_crash {
        passed = passed + 1
    }

    return [passed, total]
}

// T3.5: Taint laundering via string concatenation (should still be tainted)
fn test_taint_laundering() {
    let passed = 0
