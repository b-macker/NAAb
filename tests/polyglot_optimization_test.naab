// ============================================================================
// MAIN: Run All Tests
// ============================================================================

main {
    print("╔═══════════════════════════════════════════════════════╗")
    print("║   Polyglot Optimization - Comprehensive Test Suite   ║")
    print("╚═══════════════════════════════════════════════════════╝")

    let total_passed = 0
    let total_run = 0

    let r1 = test_numerical_operations()
    total_passed = total_passed + r1[0]
    total_run = total_run + r1[1]

    let r2 = test_string_processing()
    total_passed = total_passed + r2[0]
    total_run = total_run + r2[1]

    let r3 = test_file_operations()
    total_passed = total_passed + r3[0]
    total_run = total_run + r3[1]

    let r4 = test_web_api_operations()
    total_passed = total_passed + r4[0]
    total_run = total_run + r4[1]

    let r5 = test_systems_programming()
    total_passed = total_passed + r5[0]
    total_run = total_run + r5[1]

    let r6 = test_concurrency()
    total_passed = total_passed + r6[0]
    total_run = total_run + r6[1]

    let r7 = test_language_mismatches()
    total_passed = total_passed + r7[0]
    total_run = total_run + r7[1]

    let r8 = test_composite_detection()
    total_passed = total_passed + r8[0]
    total_run = total_run + r8[1]

    let r9 = test_performance_comparisons()
    total_passed = total_passed + r9[0]
    total_run = total_run + r9[1]

    let r10 = test_edge_cases()
    total_passed = total_passed + r10[0]
    total_run = total_run + r10[1]

    let total_failed = total_run - total_passed

    print("\n╔═══════════════════════════════════════════════════════╗")
    print("║                    TEST SUMMARY                       ║")
    print("╠═══════════════════════════════════════════════════════╣")
    print("║  Total tests run:    " + total_run)
    print("║  Tests passed:       " + total_passed)
    print("║  Tests failed:       " + total_failed)
    print("╠═══════════════════════════════════════════════════════╣")

    if (total_failed == 0) {
        print("║  Result: ✓ ALL TESTS PASSED                          ║")
        print("║                                                       ║")
        print("║  The polyglot optimization system is working         ║")
        print("║  correctly across all detection layers!              ║")
    } else {
        print("║  Result: ✗ SOME TESTS FAILED                         ║")
        print("║                                                       ║")
        print("║  Please review failed tests above.                   ║")
    }

    print("╚═══════════════════════════════════════════════════════╝")
}
