def calculate_total(items):
    total = 0
    for item in items:
        total += item['price'] * item['quantity']
    return total

items = [{'price': 10, 'quantity': 2}, {'price': 5, 'quantity': 3}]
result = calculate_total(items)
str(result)
    >>
    print("✓ Complete implementation: " + py_complete)

